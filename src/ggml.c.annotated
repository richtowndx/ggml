// ggml_custom_4d - 4D自定义操作
// 允许用户创建具有自定义形状和操作函数的4D张量操作
struct ggml_tensor * ggml_custom_4d(                        // 定义4D自定义操作函数
        struct ggml_context * ctx,                          // 上下文指针
        enum ggml_type        type,                         // 输出张量数据类型
        int64_t               ne0,                          // 输出维度0
        int64_t               ne1,                          // 输出维度1
        int64_t               ne2,                          // 输出维度2
        int64_t               ne3,                          // 输出维度3
        struct ggml_tensor ** args,                         // 输入张量数组（指针数组）
        int                   n_args,                       // 输入张量数量
        ggml_custom_op_t      fun,                          // 自定义操作函数指针
        int                   n_tasks,                      // 并行任务数
        void                * userdata) {                   // 用户自定义数据指针
																			// 空行
    GGML_ASSERT(n_args < GGML_MAX_SRC);                     // 断言：参数数量不超过最大源张量数
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, type, ne0, ne1, ne2, ne3);  // 创建指定形状和类型的4D结果张量
																			// 空行
    struct ggml_custom_op_params params = {                 // 构建自定义操作参数结构体
        /*.fun      =*/ fun,                                // 自定义函数指针
        /*.n_tasks  =*/ n_tasks,                            // 并行任务数
        /*.userdata =*/ userdata                            // 用户数据指针
    };                                                      // 参数结构体初始化结束
    ggml_set_op_params(result, &params, sizeof(params));    // 设置操作参数
																			// 空行
    result->op = GGML_OP_CUSTOM;                            // 设置操作类型为CUSTOM
    for (int i = 0; i < n_args; i++) {                      // 遍历所有输入参数
        result->src[i] = args[i];                           // 将每个输入张量设置为源张量
    }                                                       // for循环结束
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_custom_inplace - 原地自定义操作
// 对已有张量执行自定义操作，结果直接写入输入张量
struct ggml_tensor * ggml_custom_inplace(                   // 定义原地自定义操作函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入/输出张量
        struct ggml_tensor ** args,                         // 额外输入张量数组
        int                   n_args,                       // 额外输入张量数量
        ggml_custom_op_t      fun,                          // 自定义操作函数指针
        int                   n_tasks,                      // 并行任务数
        void                * userdata) {                   // 用户自定义数据指针
																			// 空行
    GGML_ASSERT(n_args < GGML_MAX_SRC - 1);                 // 断言：参数数量不超过最大源张量数减1（因为a占一个位置）
																			// 空行
    struct ggml_tensor * result = ggml_view_tensor(ctx, a); // 创建输入张量的视图（原地操作）
																			// 空行
    struct ggml_custom_op_params params = {                 // 构建自定义操作参数结构体
        /*.fun      =*/ fun,                                // 自定义函数指针
        /*.n_tasks  =*/ n_tasks,                            // 并行任务数
        /*.userdata =*/ userdata                            // 用户数据指针
    };                                                      // 参数结构体初始化结束
    ggml_set_op_params(result, &params, sizeof(params));    // 设置操作参数
																			// 空行
    result->op = GGML_OP_CUSTOM;                            // 设置操作类型为CUSTOM
    result->src[0] = a;                                     // 设置第一个源张量为输入张量
    for (int i = 0; i < n_args; i++) {                      // 遍历所有额外输入参数
        result->src[i + 1] = args[i];                       // 将额外输入张量依次设置为源张量（从位置1开始）
    }                                                       // for循环结束
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
// ggml_cross_entropy_loss - 交叉熵损失函数
// 计算预测值和目标值之间的交叉熵损失
																													// 空行
struct ggml_tensor * ggml_cross_entropy_loss(               // 定义交叉熵损失函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 预测值张量（logits或概率）
        struct ggml_tensor  * b) {                          // 目标值张量（标签）
    GGML_ASSERT(ggml_are_same_shape(a, b));                 // 断言：预测值和目标值形状必须相同
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, a->type, 1);  // 创建标量结果张量（1个元素的1D张量）
																			// 空行
    result->op     = GGML_OP_CROSS_ENTROPY_LOSS;            // 设置操作类型为交叉熵损失
    result->src[0] = a;                                     // 设置源张量：预测值
    result->src[1] = b;                                     // 设置源张量：目标值
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_cross_entropy_loss_back - 交叉熵损失反向传播
// 计算交叉熵损失关于预测值的梯度
																													// 空行
struct ggml_tensor * ggml_cross_entropy_loss_back(          // 定义交叉熵损失反向传播函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 损失梯度（标量）
        struct ggml_tensor  * b,                            // 原预测值张量
        struct ggml_tensor  * c) {                          // 原目标值张量
    GGML_ASSERT(ggml_is_scalar(a));                         // 断言：损失梯度必须是标量
    GGML_ASSERT(ggml_are_same_shape(b, c));                 // 断言：预测值和目标值形状必须相同
																			// 空行
    struct ggml_tensor * result = ggml_dup_tensor(ctx, b);  // 复制预测值张量的形状和类型
																			// 空行
    result->op     = GGML_OP_CROSS_ENTROPY_LOSS_BACK;       // 设置操作类型为交叉熵损失反向传播
    result->src[0] = a;                                     // 设置源张量：损失梯度
    result->src[1] = b;                                     // 设置源张量：预测值
    result->src[2] = c;                                     // 设置源张量：目标值
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// opt_step_adamw - AdamW优化器步骤
// 执行AdamW优化算法的一次参数更新
																													// 空行
struct ggml_tensor * ggml_opt_step_adamw(                   // 定义AdamW优化步骤函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 待更新的参数张量
        struct ggml_tensor  * grad,                         // 梯度张量
        struct ggml_tensor  * m,                            // 一阶矩估计（动量）
        struct ggml_tensor  * v,                            // 二阶矩估计（未中心化方差）
        struct ggml_tensor  * adamw_params) {               // AdamW超参数张量（学习率、beta1、beta2、eps等）
    GGML_ASSERT(a->flags & GGML_TENSOR_FLAG_PARAM);         // 断言：参数张量必须标记为可训练参数
    GGML_ASSERT(ggml_are_same_shape(a, grad));              // 断言：参数和梯度形状必须相同
    GGML_ASSERT(ggml_are_same_shape(a, m));                 // 断言：参数和一阶矩形状必须相同
    GGML_ASSERT(ggml_are_same_shape(a, v));                 // 断言：参数和二阶矩形状必须相同
    GGML_ASSERT(adamw_params->type == GGML_TYPE_F32);       // 断言：AdamW超参数必须为F32类型
// 文件: ggml.c 第 6000-7000 行的中文注释版本
// 覆盖内容: 图构建继续、计算计划创建、图计算与线程调度、前向计算开始
// 说明: 保留原有英文注释，每行添加中文注释

	    GGML_ASSERT(n_args < GGML_MAX_SRC); // 断言：参数数量不得超过最大源张量数量
	                                                                    // 断言：确保自定义操作参数数量在允许范围内
	    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, type, ne0, ne1, ne2, ne3); // 创建一个四维结果张量
	                                                                    // 创建四维结果张量，用于存储自定义操作的输出
	    struct ggml_custom_op_params params = { // 初始化自定义操作参数结构体
	        /*.fun      =*/ fun,               // 设置自定义操作的函数指针
	        /*.n_tasks  =*/ n_tasks,            // 设置任务数量
	        /*.userdata =*/ userdata            // 设置用户数据指针
	    }; // 自定义操作参数结构体初始化结束
	    ggml_set_op_params(result, &params, sizeof(params)); // 将参数写入结果张量的操作参数字段
	                                                                    // 将自定义操作参数复制到结果张量中
	    result->op = GGML_OP_CUSTOM; // 设置结果张量的操作类型为自定义操作
	    for (int i = 0; i < n_args; i++) { // 遍历所有参数张量
	        result->src[i] = args[i]; // 将每个参数张量设置为结果张量的源张量
	    } // 参数遍历结束
	    return result; // 返回结果张量
} // ggml_custom 函数结束
	                                                                    // 空行
struct ggml_tensor * ggml_custom_inplace( // 定义原位自定义操作函数，返回张量指针
	        struct ggml_context * ctx,     // 上下文指针，用于内存分配
	        struct ggml_tensor  * a,       // 第一个输入张量（原位操作的目标）
	        struct ggml_tensor ** args,    // 参数张量数组
	        int                   n_args,  // 参数数量
	        ggml_custom_op_t      fun,     // 自定义操作函数指针
	        int                   n_tasks, // 任务数量
	        void                * userdata) { // 用户数据指针
	                                                                    // 函数参数声明结束
	    GGML_ASSERT(n_args < GGML_MAX_SRC - 1); // 断言：参数数量不得超过最大源张量数量减一（因为第一个槽位预留给 a）
	                                                                    // 断言：确保参数数量在允许范围内，留出原位张量的位置
	    struct ggml_tensor * result = ggml_view_tensor(ctx, a); // 创建一个 a 的视图张量作为结果（原位操作）
	                                                                    // 使用视图张量实现原位操作，不分配新内存
	    struct ggml_custom_op_params params = { // 初始化自定义操作参数结构体
	        /*.fun      =*/ fun,               // 设置自定义操作的函数指针
	        /*.n_tasks  =*/ n_tasks,            // 设置任务数量
	        /*.userdata =*/ userdata            // 设置用户数据指针
	    }; // 参数结构体初始化结束
	    ggml_set_op_params(result, &params, sizeof(params)); // 将参数写入结果张量的操作参数字段
	                                                                    // 将自定义操作参数复制到结果张量中
	    result->op = GGML_OP_CUSTOM; // 设置结果张量的操作类型为自定义操作
	    result->src[0] = a; // 将第一个源张量设为 a（原位操作的目标）
	    for (int i = 0; i < n_args; i++) { // 遍历所有参数张量
	        result->src[i + 1] = args[i]; // 将参数张量依次存入源张量数组（从索引1开始）
	    } // 参数遍历结束
	    return result; // 返回结果张量
} // ggml_custom_inplace 函数结束
// ggml_cross_entropy_loss // 交叉熵损失函数的注释标记
	                                                                    // 空行
struct ggml_tensor * ggml_cross_entropy_loss( // 定义交叉熵损失函数，返回张量指针
	        struct ggml_context * ctx, // 上下文指针
	        struct ggml_tensor  * a,   // 第一个输入张量（预测值）
	        struct ggml_tensor  * b) { // 第二个输入张量（目标值/标签）
	    GGML_ASSERT(ggml_are_same_shape(a, b)); // 断言：a 和 b 必须具有相同的形状
	                                                                    // 确保预测值和目标值的形状匹配
	    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, a->type, 1); // 创建一个标量结果张量（1维，大小为1）
	                                                                    // 交叉熵损失的结果是一个标量
	    result->op     = GGML_OP_CROSS_ENTROPY_LOSS; // 设置操作类型为交叉熵损失
	    result->src[0] = a; // 设置第一个源张量为预测值
	    result->src[1] = b; // 设置第二个源张量为目标值
	    return result; // 返回结果张量
} // ggml_cross_entropy_loss 函数结束
	                                                                    // 空行
// ggml_cross_entropy_loss_back // 交叉熵损失反向传播的注释标记
	                                                                    // 空行
struct ggml_tensor * ggml_cross_entropy_loss_back( // 定义交叉熵损失反向传播函数
	        struct ggml_context * ctx, // 上下文指针
	        struct ggml_tensor  * a,   // 第一个输入张量（梯度）
	        struct ggml_tensor  * b,   // 第二个输入张量（预测值）
	        struct ggml_tensor  * c) { // 第三个输入张量（目标值）
	    GGML_ASSERT(ggml_is_scalar(a)); // 断言：a 必须是标量
	    GGML_ASSERT(ggml_are_same_shape(b, c)); // 断言：b 和 c 必须具有相同的形状
	                                                                    // 确保预测值和目标值形状匹配
	    struct ggml_tensor * result = ggml_dup_tensor(ctx, b); // 复制 b 张量作为结果张量
	                                                                    // 结果张量与预测值张量形状相同
	    result->op     = GGML_OP_CROSS_ENTROPY_LOSS_BACK; // 设置操作类型为交叉熵损失反向传播
	    result->src[0] = a; // 设置第一个源张量为梯度
	    result->src[1] = b; // 设置第二个源张量为预测值
	    result->src[2] = c; // 设置第三个源张量为目标值
	    return result; // 返回结果张量
} // ggml_cross_entropy_loss_back 函数结束
	                                                                    // 空行
// opt_step_adamw // AdamW 优化器步骤的注释标记
	                                                                    // 空行
struct ggml_tensor * ggml_opt_step_adamw( // 定义 AdamW 优化器步骤函数
	        struct ggml_context * ctx,        // 上下文指针
	        struct ggml_tensor  * a,          // 参数张量（权重）
	        struct ggml_tensor  * grad,       // 梯度张量
	        struct ggml_tensor  * m,          // 一阶矩估计（动量）
	        struct ggml_tensor  * v,          // 二阶矩估计（速度）
	        struct ggml_tensor  * adamw_params) { // AdamW 超参数张量
	    GGML_ASSERT(a->flags & GGML_TENSOR_FLAG_PARAM); // 断言：a 必须标记为可训练参数
	    GGML_ASSERT(ggml_are_same_shape(a, grad)); // 断言：参数和梯度形状必须相同
	    GGML_ASSERT(ggml_are_same_shape(a, m)); // 断言：参数和一阶矩形状必须相同
	    GGML_ASSERT(ggml_are_same_shape(a, v)); // 断言：参数和二阶矩形状必须相同
	    GGML_ASSERT(adamw_params->type == GGML_TYPE_F32); // 断言：超参数必须是浮点32类型
	    GGML_ASSERT(ggml_nelements(adamw_params) == 7); // 断言：超参数必须包含7个元素（学习率、beta1、beta2、epsilon等）
	                                                                    // AdamW 需要7个超参数：alpha, beta1, beta2, eps, wd, beta1^t, beta2^t
	    struct ggml_tensor * result = ggml_view_tensor(ctx, a); // 创建参数张量的视图作为结果（原位更新）
	                                                                    // AdamW 优化器直接在参数张量上原位更新
	    result->op     = GGML_OP_OPT_STEP_ADAMW; // 设置操作类型为 AdamW 优化步骤
	    result->src[0] = a; // 设置第一个源张量为参数
	    result->src[1] = grad; // 设置第二个源张量为梯度
	    result->src[2] = m; // 设置第三个源张量为一阶矩
	    result->src[3] = v; // 设置第四个源张量为二阶矩
	    result->src[4] = adamw_params; // 设置第五个源张量为超参数
	    return result; // 返回结果张量
} // ggml_opt_step_adamw 函数结束
	                                                                    // 空行
// opt_step_sgd // SGD 优化器步骤的注释标记
	                                                                    // 空行
struct ggml_tensor * ggml_opt_step_sgd( // 定义 SGD 优化器步骤函数
	        struct ggml_context * ctx,   // 上下文指针
	        struct ggml_tensor  * a,     // 参数张量（权重）
	        struct ggml_tensor  * grad,  // 梯度张量
	        struct ggml_tensor  * params) { // SGD 超参数张量
	    GGML_ASSERT(a->flags & GGML_TENSOR_FLAG_PARAM); // 断言：a 必须标记为可训练参数
	    GGML_ASSERT(ggml_are_same_shape(a, grad)); // 断言：参数和梯度形状必须相同
	    GGML_ASSERT(params->type == GGML_TYPE_F32); // 断言：超参数必须是浮点32类型
	    GGML_ASSERT(ggml_nelements(params) == 2); // 断言：超参数必须包含2个元素（学习率、权重衰减等）
	                                                                    // SGD 需要2个超参数
	    struct ggml_tensor * result = ggml_view_tensor(ctx, a); // 创建参数张量的视图作为结果（原位更新）
	                                                                    // SGD 优化器直接在参数张量上原位更新
	    result->op     = GGML_OP_OPT_STEP_SGD; // 设置操作类型为 SGD 优化步骤
	    result->src[0] = a; // 设置第一个源张量为参数
	    result->src[1] = grad; // 设置第二个源张量为梯度
	    result->src[2] = params; // 设置第三个源张量为超参数
	    return result; // 返回结果张量
} // ggml_opt_step_sgd 函数结束
	                                                                    // 空行
// solve_tri // 三角方程组求解的注释标记
	                                                                    // 空行
struct ggml_tensor * ggml_solve_tri( // 定义三角方程组求解函数
	        struct ggml_context * ctx,   // 上下文指针
	        struct ggml_tensor  * a,     // 三角矩阵
	        struct ggml_tensor  * b,     // 右端项矩阵
	        bool                  left,  // 是否左乘（AX=B 或 XA=B）
	        bool                  lower, // 是否下三角
	        bool                  uni) { // 是否单位三角矩阵（对角线为1）
	    GGML_ASSERT(a->type == GGML_TYPE_F32); // 断言：矩阵 a 必须是浮点32类型
	    GGML_ASSERT(b->type == GGML_TYPE_F32); // 断言：矩阵 b 必须是浮点32类型
	    // A must be square and lower diagonal // 英文注释：A 必须是方阵且为下三角矩阵
	    GGML_ASSERT(a->ne[0] == a->ne[1]); // 断言：矩阵 a 必须是方阵（行数等于列数）
	    // B must have same outer dimension as A // 英文注释：B 的外维度必须与 A 相同
	    GGML_ASSERT(a->ne[1] == b->ne[1]); // 断言：A 的列数必须等于 B 的行数（矩阵乘法兼容性）
	    // batch dimensions must be equal // 英文注释：批次维度必须相等
	    GGML_ASSERT(a->ne[2] == b->ne[2]); // 断言：第三维度（批次维度）必须相等
	    GGML_ASSERT(a->ne[3] == b->ne[3]); // 断言：第四维度（批次维度）必须相等
	    GGML_ASSERT(ggml_is_contiguous(a)); // 断言：矩阵 a 必须在内存中连续存储
	    GGML_ASSERT(ggml_is_contiguous(b)); // 断言：矩阵 b 必须在内存中连续存储
	    GGML_ASSERT(lower && left && !uni); // TODO: support other variants // 断言：当前仅支持下三角、左乘、非单位三角矩阵
	                                                                    // 限制条件：暂时只支持下三角左乘非单位矩阵的变体
	    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, GGML_TYPE_F32, b->ne[0], b->ne[1], b->ne[2], b->ne[3]); // 创建与 b 相同形状的结果张量
	                                                                    // 求解结果 X 与右端项 B 形状相同
	    result->op     = GGML_OP_SOLVE_TRI; // 设置操作类型为三角方程组求解
	    result->src[0] = a; // 设置第一个源张量为三角矩阵
	    result->src[1] = b; // 设置第二个源张量为右端项
	    return result; // 返回结果张量
} // ggml_solve_tri 函数结束
	                                                                    // 空行
// ggml_gated_delta_net // 门控增量网络的注释标记
	                                                                    // 空行
struct ggml_tensor * ggml_gated_delta_net( // 定义门控增量网络函数
	        struct ggml_context * ctx,   // 上下文指针
	        struct ggml_tensor  * q,     // 查询张量
	        struct ggml_tensor  * k,     // 键张量
	        struct ggml_tensor  * v,     // 值张量
	        struct ggml_tensor  * g,     // 门控张量
	        struct ggml_tensor  * beta,  // beta 参数张量
	        struct ggml_tensor  * state) { // 状态张量
	    GGML_ASSERT(ggml_is_contiguous_rows(q)); // 断言：q 的行必须是连续的
	    GGML_ASSERT(ggml_is_contiguous_rows(k)); // 断言：k 的行必须是连续的
	    GGML_ASSERT(ggml_is_contiguous_rows(v)); // 断言：v 的行必须是连续的
	    GGML_ASSERT(ggml_is_contiguous(g)); // 断言：g 必须在内存中完全连续
	    GGML_ASSERT(ggml_is_contiguous(beta)); // 断言：beta 必须在内存中完全连续
	    GGML_ASSERT(ggml_is_contiguous(state)); // 断言：state 必须在内存中完全连续
	    GGML_ASSERT(q->type == GGML_TYPE_F32); // 断言：q 必须是浮点32类型
	    GGML_ASSERT(k->type == GGML_TYPE_F32); // 断言：k 必须是浮点32类型
	    GGML_ASSERT(v->type == GGML_TYPE_F32); // 断言：v 必须是浮点32类型
	    GGML_ASSERT(g->type == GGML_TYPE_F32); // 断言：g 必须是浮点32类型
	    GGML_ASSERT(beta->type == GGML_TYPE_F32); // 断言：beta 必须是浮点32类型
	    GGML_ASSERT(state->type == GGML_TYPE_F32); // 断言：state 必须是浮点32类型
	    const int64_t S_v      = v->ne[0]; // 获取值张量的第一个维度（值维度大小）
	    const int64_t H        = v->ne[1]; // 获取值张量的第二个维度（注意力头数）
	    const int64_t n_tokens = v->ne[2]; // 获取值张量的第三个维度（token 数量）
	    const int64_t n_seqs   = v->ne[3]; // 获取值张量的第四个维度（序列数量）
	    // gate: scalar [1, H, T, B] or vector [S_v, H, T, B] (KDA) // 英文注释：门控可以是标量或向量形式
	    GGML_ASSERT(g->ne[0] == 1 || g->ne[0] == S_v); // 断言：门控的第一维度为1（标量）或等于值维度（向量）
	    GGML_ASSERT(beta->ne[0] == 1); // 断言：beta 的第一维度必须为1（标量）
	    GGML_ASSERT(ggml_nelements(state) == S_v * S_v * H * n_seqs); // 断言：状态张量的元素数必须等于 S_v^2 * H * n_seqs
	                                                                    // 状态矩阵的形状为 [S_v, S_v, H, n_seqs]
	    // concat output and new_state into a single tensor // 英文注释：将输出和新状态拼接为一个张量
	    // output: S_v * H * n_tokens * n_seqs, state: S_v * S_v * H * n_seqs // 英文注释：输出和新状态的尺寸说明
	    const int64_t ne[4] = { S_v * H, n_tokens * n_seqs + S_v * n_seqs, 1, 1 }; // 定义拼接后的张量形状
	    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建拼接后的结果张量
	                                                                    // 结果包含输出和更新后的状态
	    result->op     = GGML_OP_GATED_DELTA_NET; // 设置操作类型为门控增量网络
	    result->src[0] = q; // 设置第一个源张量为查询
	    result->src[1] = k; // 设置第二个源张量为键
	    result->src[2] = v; // 设置第三个源张量为值
	    result->src[3] = g; // 设置第四个源张量为门控
	    result->src[4] = beta; // 设置第五个源张量为 beta
	    result->src[5] = state; // 设置第六个源张量为状态
	    return result; // 返回结果张量
} // ggml_gated_delta_net 函数结束
	                                                                    // 空行
//////////////////////////////////////////////////////////////////////////////// // 分隔线
	                                                                    // 空行
struct ggml_hash_set ggml_hash_set_new(size_t size) { // 创建新的哈希集合，指定初始大小
	    size = ggml_hash_size(size); // 将大小调整为合适的素数大小
	    struct ggml_hash_set result; // 声明哈希集合结果变量
	    result.size = size; // 设置哈希集合的大小
	    result.keys = GGML_MALLOC(sizeof(struct ggml_tensor *) * size); // 分配键（张量指针）数组的内存
	    result.used = GGML_CALLOC(ggml_bitset_size(size), sizeof(ggml_bitset_t)); // 分配并初始化使用位集合的内存
	    return result; // 返回创建的哈希集合
} // ggml_hash_set_new 函数结束
	                                                                    // 空行
void ggml_hash_set_reset(struct ggml_hash_set * hash_set) { // 重置哈希集合（清空所有条目）
	    memset(hash_set->used, 0, sizeof(ggml_bitset_t) * ggml_bitset_size(hash_set->size)); // 将使用位集合全部清零
} // ggml_hash_set_reset 函数结束
	                                                                    // 空行
void ggml_hash_set_free(struct ggml_hash_set * hash_set) { // 释放哈希集合占用的内存
	    GGML_FREE(hash_set->used); // 释放使用位集合的内存
	    GGML_FREE(hash_set->keys); // 释放键数组的内存
} // ggml_hash_set_free 函数结束
	                                                                    // 空行
size_t ggml_hash_size(size_t min_sz) { // 根据最小需求大小计算合适的哈希表大小
	    // next primes after powers of two // 英文注释：2的幂之后的下一个素数
	    static const size_t primes[] = { // 预定义的素数表，用于哈希表大小
	        2, 3, 5, 11, 17, 37, 67, 131, 257, 521, 1031, // 素数序列（小值）
	        2053, 4099, 8209, 16411, 32771, 65537, 131101, // 素数序列（中值）
	        262147, 524309, 1048583, 2097169, 4194319, 8388617, // 素数序列（大值）
	        16777259, 33554467, 67108879, 134217757, 268435459, // 素数序列（更大值）
	        536870923, 1073741827, 2147483659 // 素数序列（最大值）
	    }; // 素数表结束
	    static const size_t n_primes = sizeof(primes)/sizeof(primes[0]); // 计算素数表中的元素个数
	    // find the smallest prime that is larger or equal than min_sz // 英文注释：找到大于等于 min_sz 的最小素数
	    size_t l = 0; // 二分搜索的左边界，初始化为0
	    size_t r = n_primes; // 二分搜索的右边界，初始化为素数表长度
	    while (l < r) { // 二分搜索循环
	        size_t m = (l + r)/2; // 计算中间位置
	        if (primes[m] < min_sz) { // 如果中间素数小于最小需求大小
	            l = m + 1; // 将左边界移到中间位置右侧
	        } else { // 否则
	            r = m; // 将右边界移到中间位置
	        } // 条件判断结束
	    } // 二分搜索循环结束
	    size_t sz = l < n_primes ? primes[l] : min_sz | 1; // 如果找到素数则使用素数，否则使用奇数化的 min_sz
	    return sz; // 返回合适的哈希表大小
} // ggml_hash_size 函数结束
	                                                                    // 空行
struct hash_map { // 哈希映射结构体定义
	    struct ggml_hash_set set; // 哈希集合（存储键）
	    struct ggml_tensor ** vals; // 值数组（张量指针的指针）
}; // hash_map 结构体结束
	                                                                    // 空行
static struct hash_map * ggml_new_hash_map(size_t size) { // 创建新的哈希映射
	    struct hash_map * result = GGML_MALLOC(sizeof(struct hash_map)); // 分配哈希映射结构体内存
	    result->set = ggml_hash_set_new(size); // 初始化内部的哈希集合
	    result->vals = GGML_CALLOC(result->set.size, sizeof(struct ggml_tensor *)); // 分配并初始化值数组内存
	    return result; // 返回创建的哈希映射
} // ggml_new_hash_map 函数结束
	                                                                    // 空行
static void ggml_hash_map_free(struct hash_map * map) { // 释放哈希映射占用的内存
	    ggml_hash_set_free(&map->set); // 释放内部哈希集合
	    GGML_FREE(map->vals); // 释放值数组
	    GGML_FREE(map); // 释放哈希映射结构体本身
} // ggml_hash_map_free 函数结束
	                                                                    // 空行
// utility functions to change gradients // 英文注释：修改梯度的工具函数
// isrc is the index of tensor in cgraph->visited_has_set.keys // 英文注释：isrc 是张量在哈希集合键数组中的索引
// the corresponding gradient (accumulators) are also at position isrc // 英文注释：对应的梯度（累加器）也在 isrc 位置
// if tensor has a gradient accumulator, modify that accumulator in-place // 英文注释：如果张量有梯度累加器，则原位修改
// else if there is no gradient for tensor, set the corresponding value // 英文注释：如果张量没有梯度，则设置对应的值
// else, just add/subtract/etc. the gradients // 英文注释：否则直接进行加/减等梯度操作
	                                                                    // 空行
static void ggml_add_or_set( // 定义"加或设置"梯度工具函数
	        struct ggml_context * ctx,     // 上下文指针
	        struct ggml_cgraph  * cgraph,  // 计算图指针
	        size_t                isrc,    // 源张量在哈希集合中的索引
	        struct ggml_tensor  * tensor) { // 要添加/设置的梯度张量
	    struct ggml_tensor * src = cgraph->visited_hash_set.keys[isrc]; // 获取源张量
	    GGML_ASSERT(src); // 断言：源张量必须存在
	    if (cgraph->grads[isrc]) { // 如果该位置已有梯度
	        cgraph->grads[isrc] = ggml_add_impl(ctx, cgraph->grads[isrc], tensor, /*inplace =*/ cgraph->grad_accs[isrc]); // 原位或非原位地将新梯度加到现有梯度上
	    } else { // 否则（没有现有梯度）
	        cgraph->grads[isrc] = tensor; // 直接设置梯度为传入的张量
	    } // 条件判断结束
	    ggml_format_name(cgraph->grads[isrc], "grad for %s", src->name); // 格式化梯度张量的名称
	    ggml_build_forward_expand(cgraph, cgraph->grads[isrc]); // 将梯度张量添加到计算图中
} // ggml_add_or_set 函数结束
	                                                                    // 空行
static void ggml_acc_or_set( // 定义"累加或设置"梯度工具函数（支持偏移和步长）
	        struct ggml_context * ctx,     // 上下文指针
	        struct ggml_cgraph  * cgraph,  // 计算图指针
	        size_t                isrc,    // 源张量在哈希集合中的索引
	        struct ggml_tensor  * tensor,  // 要累加/设置的梯度张量
	        const  size_t         nb1,     // 第一维度的步长
	        const  size_t         nb2,     // 第二维度的步长
	        const  size_t         nb3,     // 第三维度的步长
	        const  size_t         offset) { // 偏移量
	    struct ggml_tensor * src = cgraph->visited_hash_set.keys[isrc]; // 获取源张量
	    GGML_ASSERT(src); // 断言：源张量必须存在
	    if (cgraph->grads[isrc]) { // 如果该位置已有梯度
	        cgraph->grads[isrc] = ggml_acc_impl(ctx, cgraph->grads[isrc], tensor, nb1, nb2, nb3, offset, cgraph->grad_accs[isrc]); // 原位或非原位地将梯度累加到指定位置
	    } else { // 否则（没有现有梯度）
	        struct ggml_tensor * a_zero = ggml_scale(ctx, src, 0.0f); // FIXME this is going to produce NaN if a contains inf/NaN // 创建一个全零张量（通过缩放实现）
	                                                                    // 注意：如果源张量包含 inf/NaN，这里会产生 NaN
	        cgraph->grads[isrc] = ggml_acc_impl(ctx, a_zero, tensor, nb1, nb2, nb3, offset, false); // 将梯度累加到全零张量上
	    } // 条件判断结束
	    ggml_format_name(cgraph->grads[isrc], "grad for %s", cgraph->visited_hash_set.keys[isrc]->name); // 格式化梯度张量的名称
	    ggml_build_forward_expand(cgraph, cgraph->grads[isrc]); // 将梯度张量添加到计算图中
} // ggml_acc_or_set 函数结束
	                                                                    // 空行
static void ggml_add1_or_set( // 定义"add1或设置"梯度工具函数（广播加法）
	        struct ggml_context * ctx,     // 上下文指针
	        struct ggml_cgraph  * cgraph,  // 计算图指针
	        size_t                isrc,    // 源张量在哈希集合中的索引
	        struct ggml_tensor  * tensor) { // 要添加/设置的梯度张量
	    struct ggml_tensor * src = cgraph->visited_hash_set.keys[isrc]; // 获取源张量
	    GGML_ASSERT(src); // 断言：源张量必须存在
	    if (cgraph->grads[isrc]) { // 如果该位置已有梯度
	        cgraph->grads[isrc] = ggml_add1_impl(ctx, cgraph->grads[isrc], tensor, cgraph->grad_accs[isrc]); // 将标量梯度广播加到现有梯度上
	    } else { // 否则（没有现有梯度）
	        cgraph->grads[isrc] = ggml_repeat(ctx, tensor, src); // 将梯度张量广播重复到与源张量相同形状
	    } // 条件判断结束
	    ggml_format_name(cgraph->grads[isrc], "grad for %s", src->name); // 格式化梯度张量的名称
	    ggml_build_forward_expand(cgraph, cgraph->grads[isrc]); // 将梯度张量添加到计算图中
} // ggml_add1_or_set 函数结束
	                                                                    // 空行
static void ggml_sub_or_set( // 定义"减或设置"梯度工具函数
	        struct ggml_context * ctx,     // 上下文指针
	        struct ggml_cgraph  * cgraph,  // 计算图指针
	        size_t                isrc,    // 源张量在哈希集合中的索引
	        struct ggml_tensor  * tensor) { // 要减去/设置的梯度张量
	    struct ggml_tensor * src = cgraph->visited_hash_set.keys[isrc]; // 获取源张量
	    GGML_ASSERT(src); // 断言：源张量必须存在
	    if (cgraph->grads[isrc]) { // 如果该位置已有梯度
	        cgraph->grads[isrc] = ggml_sub_impl(ctx, cgraph->grads[isrc], tensor, cgraph->grad_accs[isrc]); // 从现有梯度中减去新梯度
	    } else { // 否则（没有现有梯度）
	        cgraph->grads[isrc] = ggml_neg(ctx, tensor); // 取反梯度张量作为初始值
	    } // 条件判断结束
	    ggml_format_name(cgraph->grads[isrc], "grad for %s", src->name); // 格式化梯度张量的名称
	    ggml_build_forward_expand(cgraph, cgraph->grads[isrc]); // 将梯度张量添加到计算图中
} // ggml_sub_or_set 函数结束
	                                                                    // 空行
static void ggml_compute_backward( // 定义计算反向传播的核心函数
	        struct ggml_context * ctx, struct ggml_cgraph * cgraph, int i, const bool * grads_needed) { // 参数：上下文、计算图、节点索引、梯度需求标志数组
	    struct ggml_tensor * tensor = cgraph->nodes[i]; // 获取当前节点张量
	    struct ggml_tensor * grad   = ggml_graph_get_grad(cgraph, tensor); // 获取当前节点的梯度
	    if (!grad) { // 如果没有梯度
	        return; // 直接返回，无需计算反向传播
	    } // 条件判断结束
	    struct ggml_tensor * src0 = tensor->src[0]; // 获取第一个源张量
	    struct ggml_tensor * src1 = tensor->src[1]; // 获取第二个源张量
	    struct ggml_tensor * src2 = tensor->src[2]; // 获取第三个源张量
	    struct ggml_hash_set * hash_set = &cgraph->visited_hash_set; // 获取哈希集合指针
	    const size_t isrc0 = src0 ? ggml_hash_find(hash_set, src0) : (size_t) -1; // 查找 src0 在哈希集合中的索引，不存在则为 -1
	    const size_t isrc1 = src1 ? ggml_hash_find(hash_set, src1) : (size_t) -1; // 查找 src1 在哈希集合中的索引，不存在则为 -1
	    const size_t isrc2 = src2 ? ggml_hash_find(hash_set, src2) : (size_t) -1; // 查找 src2 在哈希集合中的索引，不存在则为 -1
	    const bool src0_needs_grads = src0 && isrc0 != GGML_HASHSET_FULL && ggml_bitset_get(hash_set->used, isrc0) && grads_needed[isrc0]; // 判断 src0 是否需要梯度
	    const bool src1_needs_grads = src1 && isrc1 != GGML_HASHSET_FULL && ggml_bitset_get(hash_set->used, isrc1) && grads_needed[isrc1]; // 判断 src1 是否需要梯度
	    const bool src2_needs_grads = src2 && isrc2 != GGML_HASHSET_FULL && ggml_bitset_get(hash_set->used, isrc2) && grads_needed[isrc2]; // 判断 src2 是否需要梯度
	    switch (tensor->op) { // 根据操作类型进行分支处理
	        case GGML_OP_DUP: { // 复制操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, grad); // 梯度直接传递给 src0
	            } // 条件判断结束
	        } break; // DUP 操作处理结束
	        case GGML_OP_ADD: { // 加法操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, grad); // 加法的梯度直接传递给 src0
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                struct ggml_tensor * tmp = grad; // 临时变量初始化为当前梯度
	                if (!ggml_are_same_shape(src0, src1)) { // 如果 src0 和 src1 形状不同
	                    tmp = ggml_repeat_back(ctx, tmp, src1); // 对梯度进行反向广播，使其匹配 src1 的形状
	                } // 形状检查结束
	                ggml_add_or_set(ctx, cgraph, isrc1, tmp); // 将处理后的梯度传递给 src1
	            } // src1 梯度处理结束
	        } break; // ADD 操作处理结束
	        case GGML_OP_ADD1: { // 广播加法操作的反向传播（加一个标量）
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, grad); // 梯度直接传递给 src0
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc1, ggml_mean(ctx, grad)); // TODO: should probably be sum instead of mean // src1 的梯度是梯度的均值
	                                                                    // 注意：可能应该用求和而非均值
	            } // src1 梯度处理结束
	        } break; // ADD1 操作处理结束
	        case GGML_OP_ACC: { // 累加操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, grad); // 梯度直接传递给 src0
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                const size_t nb1    = ((int32_t *) tensor->op_params)[0]; // 从操作参数中提取第一维度步长
	                const size_t nb2    = ((int32_t *) tensor->op_params)[1]; // 从操作参数中提取第二维度步长
	                const size_t nb3    = ((int32_t *) tensor->op_params)[2]; // 从操作参数中提取第三维度步长
	                const size_t offset = ((int32_t *) tensor->op_params)[3]; // 从操作参数中提取偏移量
	                struct ggml_tensor * tensor_grad_view = ggml_view_4d(ctx, // 创建梯度的四维视图
	                    grad, src1->ne[0], src1->ne[1], src1->ne[2], src1->ne[3], // 使用 src1 的形状
	                    nb1, nb2, nb3, offset); // 使用对应的步长和偏移
	                ggml_add_or_set(ctx, cgraph, isrc1, ggml_reshape(ctx, ggml_cont(ctx, tensor_grad_view), src1)); // 将视图重塑后传递给 src1
	            } // src1 梯度处理结束
	        } break; // ACC 操作处理结束
	        case GGML_OP_SUB: { // 减法操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, grad); // src0 的梯度为正的当前梯度
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                ggml_sub_or_set(ctx, cgraph, isrc1, grad); // src1 的梯度为负的当前梯度
	            } // src1 梯度处理结束
	        } break; // SUB 操作处理结束
	        case GGML_OP_MUL: { // 乘法操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, grad, src1)); // src0 的梯度 = grad * src1
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                struct ggml_tensor * tmp = ggml_mul(ctx, src0, grad); // 计算 src0 * grad
	                if (!ggml_are_same_shape(src0, src1)) { // 如果 src0 和 src1 形状不同
	                    tmp = ggml_repeat_back(ctx, tmp, src1); // 对梯度进行反向广播
	                } // 形状检查结束
	                ggml_add_or_set(ctx, cgraph, isrc1, tmp); // src1 的梯度 = src0 * grad
	            } // src1 梯度处理结束
	        } break; // MUL 操作处理结束
	        case GGML_OP_DIV: { // 除法操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_div(ctx, grad, src1)); // src0 的梯度 = grad / src1
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                ggml_sub_or_set(ctx, cgraph, isrc1, ggml_mul(ctx, grad, ggml_div(ctx, tensor, src1))); // src1 的梯度 = -grad * (tensor / src1)
	            } // src1 梯度处理结束
	        } break; // DIV 操作处理结束
	        case GGML_OP_SQR: { // 平方操作的反向传播 (f(x) = x^2)
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_scale(ctx, ggml_mul(ctx, src0, grad), 2.0f)); // src0 的梯度 = 2 * src0 * grad
	            } // 条件判断结束
	        } break; // SQR 操作处理结束
	        case GGML_OP_SQRT: { // 平方根操作的反向传播 (f(x) = sqrt(x))
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_scale(ctx, ggml_div(ctx, grad, tensor), 0.5f)); // src0 的梯度 = grad / (2 * sqrt(src0))
	            } // 条件判断结束
	        } break; // SQRT 操作处理结束
	        case GGML_OP_LOG: { // 对数操作的反向传播 (f(x) = log(x))
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_div(ctx, grad, src0)); // src0 的梯度 = grad / src0
	            } // 条件判断结束
	        } break; // LOG 操作处理结束
	        case GGML_OP_SIN: { // 正弦操作的反向传播 (f(x) = sin(x))
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, grad, ggml_cos(ctx, src0))); // src0 的梯度 = grad * cos(src0)
	            } // 条件判断结束
	        } break; // SIN 操作处理结束
	        case GGML_OP_COS: { // 余弦操作的反向传播 (f(x) = cos(x))
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_sub_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, grad, ggml_sin(ctx, src0))); // src0 的梯度 = -grad * sin(src0)
	            } // 条件判断结束
	        } break; // COS 操作处理结束
	        case GGML_OP_SUM: { // 求和操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add1_or_set(ctx, cgraph, isrc0, grad); // src0 的梯度广播自标量梯度
	            } // 条件判断结束
	        } break; // SUM 操作处理结束
	        case GGML_OP_SUM_ROWS: { // 按行求和操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_repeat(ctx, grad, src0)); // src0 的梯度通过重复梯度行获得
	            } // 条件判断结束
	        } break; // SUM_ROWS 操作处理结束
	        case GGML_OP_MEAN: { // 均值操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add1_or_set(ctx, cgraph, isrc0, ggml_scale_impl(ctx, grad, 1.0f/src0->ne[0], 0.0, false)); // src0 的梯度 = grad / n（除以元素数量）
	            } // 条件判断结束
	        } break; // MEAN 操作处理结束
	        case GGML_OP_REPEAT: { // 重复操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_repeat_back(ctx, grad, src0)); // src0 的梯度通过反向重复（归约）获得
	            } // 条件判断结束
	        } break; // REPEAT 操作处理结束
	        case GGML_OP_REPEAT_BACK: { // 反向重复操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_repeat(ctx, grad, src0)); // src0 的梯度通过重复获得
	            } // 条件判断结束
	        } break; // REPEAT_BACK 操作处理结束
	        case GGML_OP_RMS_NORM: { // RMS 归一化操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                float eps; // 声明 epsilon 变量
	                memcpy(&eps, tensor->op_params, sizeof(float)); // 从操作参数中提取 epsilon 值
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_rms_norm_back(ctx, grad, src0, eps)); // 调用 RMS 归一化反向传播函数
	            } // 条件判断结束
	        } break; // RMS_NORM 操作处理结束
	        case GGML_OP_MUL_MAT: { // 矩阵乘法操作的反向传播
	            // https://cs231n.github.io/optimization-2/#staged // 英文注释：参考 CS231n 课程关于反向传播的说明
	            // # forward pass // 英文注释：前向传播示例
	            // s0 = np.random.randn(5, 10) // 英文注释：示例代码
	            // s1 = np.random.randn(10, 3) // 英文注释：示例代码
	            // t = s0.dot(s1) // 英文注释：矩阵乘法
	            // # now suppose we had the gradient on t from above in the circuit // 英文注释：假设我们有输出 t 的梯度
	            // dt = np.random.randn(*t.shape) # same shape as t // 英文注释：梯度与 t 同形状
	            // ds0 = dt.dot(s1.T) #.T gives the transpose of the matrix // 英文注释：src0 的梯度 = dt * s1^T
	            // ds1 = t.T.dot(dt) // 英文注释：src1 的梯度 = t^T * dt
	            // tensor.shape [m,p,qq,rr] // 英文注释：结果张量的形状
	            // src0.shape   [n,m,q1,r1] // 英文注释：src0 的形状
	            // src1.shape   [n,p,qq,rr] // 英文注释：src1 的形状
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                GGML_ASSERT(grad->ne[2] == src1->ne[2]); // 断言：梯度的第三维度必须等于 src1 的第三维度
	                GGML_ASSERT(grad->ne[3] == src1->ne[3]); // 断言：梯度的第四维度必须等于 src1 的第四维度
	                struct ggml_tensor * tmp = // 计算外积作为 src0 的梯度
	                    ggml_out_prod(ctx, // [n,m,qq,rr] // 外积操作：计算 src1 和 grad 的外积
	                        src1,          // [n,p,qq,rr] // 第一个输入：src1
	                        grad);         // [m,p,qq,rr] // 第二个输入：梯度
	                if (!ggml_are_same_shape(tmp, src0)) { // 如果外积结果与 src0 形状不同
	                    GGML_ASSERT(tmp->ne[0] == src0->ne[0]); // 断言：第一维度必须匹配
	                    GGML_ASSERT(tmp->ne[1] == src0->ne[1]); // 断言：第二维度必须匹配
	                    GGML_ASSERT(tmp->ne[3] == 1); // 断言：第四维度必须为1
	                    const int64_t nr2 = tmp->ne[2] / src0->ne[2]; // 计算第三维度的重复因子
	                    const size_t nb2 = tmp->nb[2] * nr2; // 计算调整后的第二维度步长
	                    const size_t nb3 = tmp->nb[2]; // 计算第三维度步长
	                    tmp = ggml_view_4d(ctx, tmp, src0->ne[0], src0->ne[1], src0->ne[2], nr2, tmp->nb[1], nb2, nb3, 0); // 创建四维视图进行重塑
	                    tmp = ggml_repeat_back(ctx, tmp, src0); // 对梯度进行反向广播以匹配 src0 形状
	                } // 形状调整结束
	                ggml_add_or_set(ctx, cgraph, isrc0, tmp); // 将计算得到的梯度设置给 src0
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc1, // 设置 src1 的梯度
	                        // ggml_mul_mat(ctx,                   // [n,p,qq,rr] // 注释掉的替代方案：使用矩阵乘法
	                        //     ggml_cont(ctx,                  // [m,n,q1,r1] // 对转置后的 src0 做连续化
	                        //         ggml_transpose(ctx, src0)), // [m,n,q1,r1] // src0 转置
	                        //     grad),                          // [m,p,qq,rr] // 乘以梯度
	                        // when src0 is bigger than tensor->grad (this is mostly the case in llama), // 英文注释：当 src0 比梯度大时（llama 中的常见情况）
	                        // avoid transpose of src0, rather transpose smaller tensor->grad // 英文注释：避免对 src0 转置，而是转置较小的梯度
	                        // and then use ggml_out_prod // 英文注释：然后使用外积
	                        ggml_out_prod(ctx,      // [n,p,qq,rr] // 使用外积方式计算
	                            src0,               // [n,m,q1,r1] // 第一个输入：src0
	                            ggml_transpose(ctx, // [p,m,qq,rr] // 转置梯度
	                                grad)));        // [m,p,qq,rr] // 梯度
	            } // src1 梯度处理结束
	        } break; // MUL_MAT 操作处理结束
	        case GGML_OP_SCALE: { // 缩放操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                float s; // 声明缩放因子变量
	                memcpy(&s, tensor->op_params, sizeof(float)); // 从操作参数中提取缩放因子
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_scale_impl(ctx, grad, s, 0.0, false)); // src0 的梯度 = grad * s
	            } // 条件判断结束
	        } break; // SCALE 操作处理结束
	        case GGML_OP_SET: { // 设置操作的反向传播（在指定位置写入子张量）
	            const size_t nb1    = ((const int32_t *) tensor->op_params)[0]; // 提取第一维度步长
	            const size_t nb2    = ((const int32_t *) tensor->op_params)[1]; // 提取第二维度步长
	            const size_t nb3    = ((const int32_t *) tensor->op_params)[2]; // 提取第三维度步长
	            const size_t offset = ((const int32_t *) tensor->op_params)[3]; // 提取偏移量
	            struct ggml_tensor * tensor_grad_view = NULL; // 声明梯度视图指针，初始化为 NULL
	            if (src0_needs_grads || src1_needs_grads) { // 如果任一源张量需要梯度
	                GGML_ASSERT(src0->type == tensor->type); // 断言：src0 类型必须与结果类型相同
	                GGML_ASSERT(!cgraph->grads[isrc0] ||                      cgraph->grads[isrc0]->type == grad->type); // 断言：已有梯度类型必须匹配
	                GGML_ASSERT(!cgraph->grads[isrc1] || !src1_needs_grads || cgraph->grads[isrc1]->type == grad->type); // 断言：已有梯度类型必须匹配
	                tensor_grad_view = ggml_view_4d(ctx, // 创建梯度的四维视图
	                    grad, src1->ne[0], src1->ne[1], src1->ne[2], src1->ne[3], // 使用 src1 的形状
	                    nb1, nb2, nb3, offset); // 使用对应的步长和偏移
	            } // 视图创建结束
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                struct ggml_tensor * tmp = ggml_neg(ctx, tensor_grad_view); // 取反视图区域的梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_acc_impl(ctx, grad, tmp, nb1, nb2, nb3, offset, false)); // 将取反值累加到 src0 梯度中
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc1, ggml_reshape(ctx, ggml_cont(ctx, tensor_grad_view), src1)); // 将视图区域重塑为 src1 形状
	            } // src1 梯度处理结束
	        } break; // SET 操作处理结束
	        case GGML_OP_CPY: { // 复制操作的反向传播
	            // cpy overwrites value of src1 by src0 and returns view(src1) // 英文注释：cpy 用 src0 覆盖 src1 并返回 src1 的视图
	            // the overwriting is mathematically equivalent to: // 英文注释：数学上等价于
	            // tensor = src0 * 1 + src1 * 0 // 英文注释：tensor = src0 * 1 + src1 * 0
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                // dsrc0 = dtensor * 1 // 英文注释：src0 的梯度 = dtensor * 1
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_reshape(ctx, grad, src0)); // 梯度直接传递给 src0（重塑形状）
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                // dsrc1 = dtensor * 0 -> noop // 英文注释：src1 的梯度 = 0，无需操作
	            } // src1 梯度处理结束（无操作）
	        } break; // CPY 操作处理结束
	        case GGML_OP_CONT: { // 连续化操作的反向传播
	            // same as cpy // 英文注释：与 cpy 相同
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                GGML_ASSERT(!cgraph->grads[isrc0] || ggml_is_contiguous(cgraph->grads[isrc0])); // 断言：已有梯度必须是连续的
	                GGML_ASSERT(ggml_is_contiguous(grad)); // 断言：梯度必须是连续的
	                GGML_ASSERT(ggml_nelements(tensor) == ggml_nelements(src0)); // 断言：元素数必须相同
	                ggml_add_or_set(ctx, cgraph, isrc0, // 设置 src0 的梯度
	                    ggml_are_same_shape(tensor, src0) ? grad : ggml_reshape(ctx, grad, src0)); // 形状相同则直接使用，否则重塑
	            } // src0 梯度处理结束
	        } break; // CONT 操作处理结束
	        case GGML_OP_RESHAPE: { // 重塑操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                struct ggml_tensor * grad_cont = ggml_is_contiguous(grad) ? grad : ggml_cont(ctx, grad); // 确保梯度是连续的
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_reshape(ctx, grad_cont, src0)); // 将梯度重塑回 src0 的形状
	            } // 条件判断结束
	        } break; // RESHAPE 操作处理结束
	        case GGML_OP_VIEW: { // 视图操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                size_t offset; // 声明偏移量变量
	                memcpy(&offset, tensor->op_params, sizeof(offset)); // 从操作参数中提取偏移量
	                size_t nb1 = tensor->nb[1]; // 获取第一维度步长
	                size_t nb2 = tensor->nb[2]; // 获取第二维度步长
	                size_t nb3 = tensor->nb[3]; // 获取第三维度步长
	                if (cgraph->grads[isrc0] && src0->type != cgraph->grads[isrc0]->type) { // 如果已有梯度类型与源张量类型不同
	                    // gradient is typically F32, but src0 could be other type // 英文注释：梯度通常是 F32，但 src0 可能是其他类型
	                    size_t ng = ggml_element_size(cgraph->grads[isrc0]); // 获取梯度元素大小
	                    size_t n0 = ggml_element_size(src0); // 获取源张量元素大小
	                    GGML_ASSERT(offset % n0 == 0); // 断言：偏移量必须整除源元素大小
	                    GGML_ASSERT(nb1 % n0 == 0); // 断言：步长1必须整除源元素大小
	                    GGML_ASSERT(nb2 % n0 == 0); // 断言：步长2必须整除源元素大小
	                    GGML_ASSERT(nb3 % n0 == 0); // 断言：步长3必须整除源元素大小
	                    offset = (offset / n0) * ng; // 按比例转换偏移量
	                    nb1 = (nb1 / n0) * ng; // 按比例转换步长1
	                    nb2 = (nb2 / n0) * ng; // 按比例转换步长2
	                    nb3 = (nb3 / n0) * ng; // 按比例转换步长3
	                } // 类型转换结束
	                ggml_acc_or_set(ctx, cgraph, isrc0, grad, nb1, nb2, nb3, offset); // 将梯度累加到 src0 的对应位置
	            } // src0 梯度处理结束
	        } break; // VIEW 操作处理结束
	        case GGML_OP_PERMUTE: { // 排列操作的反向传播（维度重排）
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                const int32_t * axes = (const int32_t *) tensor->op_params; // 获取排列轴参数
	                const int axis0 = axes[0] & 0x3; // 提取第一个轴（低2位）
	                const int axis1 = axes[1] & 0x3; // 提取第二个轴（低2位）
	                const int axis2 = axes[2] & 0x3; // 提取第三个轴（低2位）
	                const int axis3 = axes[3] & 0x3; // 提取第四个轴（低2位）
	                int axb[4] = {0,0,0,0}; // axes backward // 初始化反向排列轴数组
	                axb[axis0] = 0; // 设置反向映射：轴0对应位置
	                axb[axis1] = 1; // 设置反向映射：轴1对应位置
	                axb[axis2] = 2; // 设置反向映射：轴2对应位置
	                axb[axis3] = 3; // 设置反向映射：轴3对应位置
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_permute(ctx, grad, axb[0], axb[1], axb[2], axb[3])); // 用反向排列恢复梯度维度顺序
	            } // 条件判断结束
	        } break; // PERMUTE 操作处理结束
	        case GGML_OP_TRANSPOSE: { // 转置操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_transpose(ctx, grad)); // 再次转置梯度恢复原始维度
	            } // 条件判断结束
	        } break; // TRANSPOSE 操作处理结束
	        case GGML_OP_GET_ROWS: { // 取行操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_get_rows_back(ctx, grad, src1, src0)); // 调用反向取行函数
	            } // src0 梯度处理结束
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                // noop // 英文注释：无操作（索引张量不需要梯度）
	            } // src1 梯度处理结束
	        } break; // GET_ROWS 操作处理结束
	        case GGML_OP_DIAG_MASK_INF: { // 对角掩码（无穷大）操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                /* ggml_diag_mask_inf_impl() shouldn't be here */ // 英文注释：不应使用 inf 版本
	                /* ref:  https://github.com/ggml-org/llama.cpp/pull/4203#discussion_r1412377992 */ // 英文注释：参考链接
	                const int n_past = ((const int32_t *) tensor->op_params)[0]; // 提取 n_past 参数
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_diag_mask_zero_impl(ctx, grad, n_past, false)); // 使用零掩码版本的实现
	            } // 条件判断结束
	        } break; // DIAG_MASK_INF 操作处理结束
	        case GGML_OP_DIAG_MASK_ZERO: { // 对角掩码（零）操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                const int n_past = ((const int32_t *) tensor->op_params)[0]; // 提取 n_past 参数
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_diag_mask_zero_impl(ctx, grad, n_past, false)); // 使用零掩码版本的实现
	            } // 条件判断结束
	        } break; // DIAG_MASK_ZERO 操作处理结束
	        case GGML_OP_SOFT_MAX: { // Softmax 操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                float scale    = 1.0f; // 初始化缩放因子为1.0
	                float max_bias = 0.0f; // 初始化最大偏置为0.0
	                memcpy(&scale,    (const float *) tensor->op_params + 0, sizeof(float)); // 从操作参数提取缩放因子
	                memcpy(&max_bias, (const float *) tensor->op_params + 1, sizeof(float)); // 从操作参数提取最大偏置
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_soft_max_ext_back(ctx, grad, tensor, scale, max_bias)); // 调用 softmax 反向传播
	            } // src0 梯度处理结束
	            GGML_ASSERT((!src1 || !src1_needs_grads) && "backward pass for softmax mask not implemented"); // 断言：暂不支持掩码的 softmax 反向传播
	        } break; // SOFT_MAX 操作处理结束
	        case GGML_OP_ROPE: { // RoPE（旋转位置编码）操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                //const int n_past = ((int32_t *) tensor->op_params)[0]; // 注释掉：n_past 参数
	                const int n_dims     = ((const int32_t *) tensor->op_params)[1]; // 提取旋转维度数
	                const int mode       = ((const int32_t *) tensor->op_params)[2]; // 提取 RoPE 模式
	                //const int n_ctx      = ((int32_t *) tensor->op_params)[3]; // 注释掉：上下文长度
	                const int n_ctx_orig = ((const int32_t *) tensor->op_params)[4]; // 提取原始上下文长度
	                float freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow; // 声明 RoPE 相关参数
	                int sections[4] = {0, 0, 0, 0}; // 初始化分段参数数组
	                memcpy(&freq_base,   (const float *) tensor->op_params +  5, sizeof(float)); // 提取频率基数
	                memcpy(&freq_scale,  (const float *) tensor->op_params +  6, sizeof(float)); // 提取频率缩放
	                memcpy(&ext_factor,  (const float *) tensor->op_params +  7, sizeof(float)); // 提取扩展因子
	                memcpy(&attn_factor, (const float *) tensor->op_params +  8, sizeof(float)); // 提取注意力因子
	                memcpy(&beta_fast,   (const float *) tensor->op_params +  9, sizeof(float)); // 提取快速 beta
	                memcpy(&beta_slow,   (const float *) tensor->op_params + 10, sizeof(float)); // 提取慢速 beta
	                memcpy(&sections,                    tensor->op_params + 11, sizeof(sections)); // 提取分段参数
	                struct ggml_tensor * rope_back = grad->ne[2] == src1->ne[0] ? // 根据维度选择使用哪种 RoPE 反向传播
	                    ggml_rope_ext_back(ctx, grad, src1, src2, n_dims, // 扩展版 RoPE 反向传播
	                        mode, n_ctx_orig, freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow) : // 传入所有参数
	                    ggml_rope_multi_back(ctx, grad, src1, src2, n_dims, sections, // 多段 RoPE 反向传播
	                        mode, n_ctx_orig, freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow); // 传入所有参数
	                ggml_add_or_set(ctx, cgraph, isrc0, rope_back); // 将 RoPE 反向传播结果设置给 src0
	            } // src0 梯度处理结束
	            GGML_ASSERT((!src2 || !src2_needs_grads) && "gradients for freq factors not implemented"); // 断言：暂不支持频率因子的梯度
	        } break; // ROPE 操作处理结束
	        case GGML_OP_IM2COL: { // im2col（图像转列）操作的反向传播
	            if (src1_needs_grads) { // 如果 src1 需要梯度
	                const int32_t s0    = ggml_get_op_params_i32(tensor, 0); // 提取步幅 s0
	                const int32_t s1    = ggml_get_op_params_i32(tensor, 1); // 提取步幅 s1
	                const int32_t p0    = ggml_get_op_params_i32(tensor, 2); // 提取填充 p0
	                const int32_t p1    = ggml_get_op_params_i32(tensor, 3); // 提取填充 p1
	                const int32_t d0    = ggml_get_op_params_i32(tensor, 4); // 提取膨胀 d0
	                const int32_t d1    = ggml_get_op_params_i32(tensor, 5); // 提取膨胀 d1
	                const bool    is_2D = ggml_get_op_params_i32(tensor, 6) == 1; // 判断是否为二维操作
	                ggml_add_or_set(ctx, cgraph, isrc1, ggml_im2col_back(ctx, grad, src0, src1->ne, s0, s1, p0, p1, d0, d1, is_2D)); // 调用 im2col 反向传播
	            } // 条件判断结束
	        } break; // IM2COL 操作处理结束
	        case GGML_OP_POOL_2D: { // 二维池化操作的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                const enum ggml_op_pool op = ggml_get_op_params_i32(tensor, 0); // 提取池化操作类型
	                const      int32_t      k0 = ggml_get_op_params_i32(tensor, 1); // 提取核大小 k0
	                const      int32_t      k1 = ggml_get_op_params_i32(tensor, 2); // 提取核大小 k1
	                const      int32_t      s0 = ggml_get_op_params_i32(tensor, 3); // 提取步幅 s0
	                const      int32_t      s1 = ggml_get_op_params_i32(tensor, 4); // 提取步幅 s1
	                const      int32_t      p0 = ggml_get_op_params_i32(tensor, 5); // 提取填充 p0
	                const      int32_t      p1 = ggml_get_op_params_i32(tensor, 6); // 提取填充 p1
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_pool_2d_back(ctx, grad, src0, op, k0, k1, s0, s1, p0, p1)); // 调用池化反向传播
	            } // 条件判断结束
	        } break; // POOL_2D 操作处理结束
	        case GGML_OP_WIN_PART: // 窗口分区操作（无反向传播实现）
	        case GGML_OP_WIN_UNPART: // 窗口反分区操作（无反向传播实现）
	        case GGML_OP_UNARY: { // 一元操作的反向传播
	            switch (ggml_get_unary_op(tensor)) { // 根据具体的一元操作类型分支
	                case GGML_UNARY_OP_ABS: { // 绝对值操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, ggml_sgn(ctx, src0), grad)); // 梯度 = sign(src0) * grad
	                    } // 条件判断结束
	                } break; // ABS 处理结束
	                case GGML_UNARY_OP_SGN: { // 符号函数操作的反向传播
	                    // noop // 英文注释：无操作（符号函数几乎处处导数为0）
	                } break; // SGN 处理结束
	                case GGML_UNARY_OP_NEG: { // 取反操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_sub_or_set(ctx, cgraph, isrc0, grad); // 梯度 = -grad
	                    } // 条件判断结束
	                } break; // NEG 处理结束
	                case GGML_UNARY_OP_STEP: { // 阶跃函数操作的反向传播
	                    // noop // 英文注释：无操作（阶跃函数几乎处处导数为0）
	                } break; // STEP 处理结束
	                case GGML_UNARY_OP_RELU: { // ReLU 操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, ggml_step(ctx, src0), grad)); // 梯度 = step(src0) * grad
	                    } // 条件判断结束
	                } break; // RELU 处理结束
	                case GGML_UNARY_OP_SILU: { // SiLU 操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_silu_back(ctx, grad, src0)); // 调用 SiLU 反向传播函数
	                    } // 条件判断结束
	                } break; // SILU 处理结束
	                case GGML_UNARY_OP_EXP: { // 指数操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, tensor, grad)); // 梯度 = exp(src0) * grad = tensor * grad
	                    } // 条件判断结束
	                } break; // EXP 处理结束
	                case GGML_UNARY_OP_EXPM1: { // exp(x)-1 操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, grad, ggml_exp(ctx, src0))); // 梯度 = exp(src0) * grad
	                    } // 条件判断结束
	                } break; // EXPM1 处理结束
	                case GGML_UNARY_OP_SOFTPLUS: { // softplus 操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_mul(ctx, grad, ggml_sigmoid(ctx, src0))); // 梯度 = sigmoid(src0) * grad
	                    } // 条件判断结束
	                } break; // SOFTPLUS 处理结束
	                default: { // 未支持的一元操作
	                    fprintf(stderr, "%s: unsupported unary op for backward pass: %s\n", // 打印错误信息
	                        __func__, ggml_unary_op_name(ggml_get_unary_op(tensor))); // 输出函数名和操作名
	                    GGML_ABORT("fatal error"); // 终止程序
	                } //break; // 默认处理结束
	            } // 一元操作 switch 结束
	        } break; // UNARY 操作处理结束
	        case GGML_OP_CROSS_ENTROPY_LOSS: { // 交叉熵损失的反向传播
	            if (src0_needs_grads) { // 如果 src0 需要梯度
	                ggml_add_or_set(ctx, cgraph, isrc0, ggml_cross_entropy_loss_back(ctx, grad, src0, src1)); // 调用交叉熵损失反向函数
	            } // src0 梯度处理结束
	            GGML_ASSERT(!src1_needs_grads && "backward pass for labels not implemented"); // 断言：暂不支持标签的反向传播
	        } break; // CROSS_ENTROPY_LOSS 操作处理结束
	        case GGML_OP_GLU: { // 门控线性单元的反向传播
	            switch (ggml_get_glu_op(tensor)) { // 根据具体的 GLU 操作类型分支
	                case GGML_GLU_OP_SWIGLU: { // SwiGLU 操作的反向传播
	                    if (src0_needs_grads) { // 如果 src0 需要梯度
	                        GGML_ASSERT(src1 && "backward pass only implemented for split swiglu"); // 断言：仅支持分离式 swiglu
	                        ggml_add_or_set(ctx, cgraph, isrc0, ggml_silu_back(ctx, ggml_mul(ctx, grad, src1), src0)); // src0 梯度 = silu_back(grad * src1, src0)
	                    } // src0 梯度处理结束
	                    if (src1_needs_grads) { // 如果 src1 需要梯度
	                        ggml_add_or_set(ctx, cgraph, isrc1, ggml_mul(ctx, ggml_silu(ctx, src0), grad)); // src1 梯度 = silu(src0) * grad
	                    } // src1 梯度处理结束
	                } break; // SWIGLU 处理结束
	                default: { // 未支持的 GLU 操作
	                    GGML_ABORT("unsupported glu op for backward pass: %s", ggml_glu_op_name(ggml_get_glu_op(tensor))); // 终止程序并输出错误信息
	                } //break; // 默认处理结束
	            } // GLU 操作 switch 结束
	        } break; // GLU 操作处理结束
	        case GGML_OP_NONE: { // 无操作
	            // noop // 英文注释：无操作
	        } break; // NONE 处理结束
	        case GGML_OP_COUNT: // 操作计数（不应到达此处）
	        default: { // 未支持的操作
	            GGML_ABORT("%s: unsupported ggml op for backward pass: %s\n", __func__, ggml_op_name(tensor->op)); // 终止程序并输出错误
	        } //break; // 默认处理结束
	    } // 操作类型 switch 结束
	    GGML_ASSERT(!src0_needs_grads || ggml_are_same_shape(src0, cgraph->grads[isrc0])); // 断言：src0 与其梯度形状必须相同
	    GGML_ASSERT(!src1_needs_grads || ggml_are_same_shape(src1, cgraph->grads[isrc1])); // 断言：src1 与其梯度形状必须相同
	    GGML_ASSERT(!src2_needs_grads || ggml_are_same_shape(src2, cgraph->grads[isrc2])); // 断言：src2 与其梯度形状必须相同
} // ggml_compute_backward 函数结束
	                                                                    // 空行
static size_t ggml_visit_parents_graph(struct ggml_cgraph * cgraph, struct ggml_tensor * node, bool compute) { // 递归访问计算图中节点的父节点
	    if (node->op != GGML_OP_NONE && compute) { // 如果节点有操作且需要计算
	        node->flags |= GGML_TENSOR_FLAG_COMPUTE; // 标记该节点需要计算
	    } // 计算标记结束
	    const size_t node_hash_pos = ggml_hash_find(&cgraph->visited_hash_set, node); // 在哈希集合中查找节点的位置
	    GGML_ASSERT(node_hash_pos != GGML_HASHSET_FULL); // 断言：哈希集合不能已满
	    if (ggml_bitset_get(cgraph->visited_hash_set.used, node_hash_pos)) { // 如果节点已经被访问过
	        // already visited // 英文注释：已经访问过
	        if (compute) { // 如果需要计算
	            // update the compute flag regardless // 英文注释：无论如何更新计算标志
	            for (int i = 0; i < GGML_MAX_SRC; ++i) { // 遍历所有源张量
	                struct ggml_tensor * src = node->src[i]; // 获取源张量
	                if (src && ((src->flags & GGML_TENSOR_FLAG_COMPUTE) == 0)) { // 如果源张量存在但未被标记为需要计算
	                    ggml_visit_parents_graph(cgraph, src, true); // 递归访问并标记需要计算
	                } // 条件判断结束
	            } // 源张量遍历结束
	        } // compute 条件结束
	        return node_hash_pos; // 返回节点的哈希位置（已访问过）
	    } // 已访问节点处理结束
	    // This is the first time we see this node in the current graph. // 英文注释：这是在当前图中第一次看到该节点
	    cgraph->visited_hash_set.keys[node_hash_pos] = node; // 将节点存入哈希集合
	    ggml_bitset_set(cgraph->visited_hash_set.used, node_hash_pos); // 标记该位置为已使用
	    cgraph->use_counts[node_hash_pos] = 0; // 初始化使用计数为0
	    for (int i = 0; i < GGML_MAX_SRC; ++i) { // 遍历所有源张量
	        const int k = // 根据计算图的评估顺序确定遍历索引
	            (cgraph->order == GGML_CGRAPH_EVAL_ORDER_LEFT_TO_RIGHT) ? i : // 从左到右：正常顺序
	            (cgraph->order == GGML_CGRAPH_EVAL_ORDER_RIGHT_TO_LEFT) ? (GGML_MAX_SRC-1-i) : // 从右到左：逆序
	            /* unknown order, just fall back to using i */ i; // 未知顺序：使用默认顺序
	        struct ggml_tensor * src = node->src[k]; // 获取对应索引的源张量
	        if (src) { // 如果源张量存在
	            const size_t src_hash_pos = ggml_visit_parents_graph(cgraph, src, compute); // 递归访问源张量的父节点
	            // Update the use count for this operand. // 英文注释：更新该操作数的使用计数
	            cgraph->use_counts[src_hash_pos]++; // 增加源张量的使用计数
	        } // 源张量处理结束
	    } // 源张量遍历结束
	    if (node->op == GGML_OP_NONE && !(node->flags & GGML_TENSOR_FLAG_PARAM)) { // 如果是无操作节点且不是参数
	        // reached a leaf node, not part of the gradient graph (e.g. a constant) // 英文注释：到达叶子节点，不属于梯度图（如常量）
	        GGML_ASSERT(cgraph->n_leafs < cgraph->size); // 断言：叶子节点数不超过图大小
	        if (strlen(node->name) == 0) { // 如果节点没有名称
	            ggml_format_name(node, "leaf_%d", cgraph->n_leafs); // 自动生成名称 "leaf_N"
	        } // 名称检查结束
	        cgraph->leafs[cgraph->n_leafs] = node; // 将节点添加到叶子数组中
	        cgraph->n_leafs++; // 增加叶子节点计数
	    } else { // 否则（是有操作的节点或参数）
	        GGML_ASSERT(cgraph->n_nodes < cgraph->size); // 断言：节点数不超过图大小
	        if (strlen(node->name) == 0) { // 如果节点没有名称
	            ggml_format_name(node, "node_%d", cgraph->n_nodes); // 自动生成名称 "node_N"
	        } // 名称检查结束
	        cgraph->nodes[cgraph->n_nodes] = node; // 将节点添加到节点数组中
	        cgraph->n_nodes++; // 增加节点计数
	    } // 叶子/非叶子节点分支结束
	    return node_hash_pos; // 返回节点的哈希位置
} // ggml_visit_parents_graph 函数结束
	                                                                    // 空行
static void ggml_build_forward_impl(struct ggml_cgraph * cgraph, struct ggml_tensor * tensor, bool expand, bool compute) { // 构建前向计算图的内部实现
	    if (!expand) { // 如果不是扩展模式（即重新构建模式）
	        // TODO: this branch isn't accessible anymore, maybe move this to ggml_build_forward_expand // 英文注释：此分支已不再可访问，可能应移到 ggml_build_forward_expand
	        ggml_graph_clear(cgraph); // 清空计算图
	    } // 扩展模式检查结束
	    const int n_old = cgraph->n_nodes; // 记录添加前的节点数
	    ggml_visit_parents_graph(cgraph, tensor, compute); // 递归访问并添加节点到图中
	    const int n_new = cgraph->n_nodes - n_old; // 计算新增的节点数
	    GGML_PRINT_DEBUG("%s: visited %d new nodes\n", __func__, n_new); // 调试输出：访问了多少新节点
	    if (n_new > 0) { // 如果添加了新节点
	        // the last added node should always be starting point // 英文注释：最后添加的节点应该总是起点
	        GGML_ASSERT(cgraph->nodes[cgraph->n_nodes - 1] == tensor); // 断言：最后一个节点就是传入的张量
	    } // 新节点检查结束
} // ggml_build_forward_impl 函数结束
	                                                                    // 空行
struct ggml_tensor * ggml_build_forward_select( // 构建选择性前向计算图（只计算指定输出）
	        struct ggml_cgraph  * cgraph,       // 计算图指针
	        struct ggml_tensor ** tensors,       // 输出张量数组
	        int                   n_tensors,    // 输出张量数量
	        int                   idx) {        // 选择计算的输出索引
	    GGML_ASSERT(idx >= 0 && idx < n_tensors); // 断言：索引必须在有效范围内
	    for (int i = 0; i < n_tensors; i++) { // 遍历所有输出张量
	        ggml_build_forward_impl(cgraph, tensors[i], true, i == idx ? true : false); // 扩展图，仅索引对应的张量标记为需要计算
	    } // 遍历结束
	    return tensors[idx]; // 返回选中的输出张量
} // ggml_build_forward_select 函数结束
	                                                                    // 空行
void ggml_build_forward_expand(struct ggml_cgraph * cgraph, struct ggml_tensor * tensor) { // 扩展前向计算图（添加新节点）
	    ggml_build_forward_impl(cgraph, tensor, true, true); // 调用内部实现，扩展模式，标记需要计算
} // ggml_build_forward_expand 函数结束
	                                                                    // 空行
void ggml_build_backward_expand( // 扩展反向计算图
	        struct ggml_context *  ctx,     // 上下文指针
	        struct ggml_cgraph  *  cgraph,  // 计算图指针
	        struct ggml_tensor  ** grad_accs) { // 梯度累加器数组
	    GGML_ASSERT(cgraph->n_nodes > 0); // 断言：计算图中必须有节点
	    GGML_ASSERT(cgraph->grads); // 断言：梯度数组必须存在
	    GGML_ASSERT(cgraph->grad_accs); // 断言：梯度累加器数组必须存在
	    const int n_nodes_f = cgraph->n_nodes; // 记录前向传播的节点数
	    memset(cgraph->grads,     0, cgraph->visited_hash_set.size*sizeof(struct ggml_tensor *)); // 清零梯度数组
	    memset(cgraph->grad_accs, 0, cgraph->visited_hash_set.size*sizeof(struct ggml_tensor *)); // 清零梯度累加器数组
	    bool * grads_needed = calloc(cgraph->visited_hash_set.size, sizeof(bool)); // 分配并初始化梯度需求标志数组
	    { // 检查是否存在可训练参数和损失
	        bool any_params = false; // 标记是否存在参数
	        bool any_loss   = false; // 标记是否存在损失
	        for (int i = 0; i < n_nodes_f; ++i) { // 遍历所有前向节点
	            struct ggml_tensor * node = cgraph->nodes[i]; // 获取节点
	            any_params = any_params || (node->flags & GGML_TENSOR_FLAG_PARAM); // 检查是否有参数标志
	            any_loss   = any_loss   || (node->flags & GGML_TENSOR_FLAG_LOSS); // 检查是否有损失标志
	        } // 遍历结束
	        GGML_ASSERT(any_params && "no trainable parameters found, did you forget to call ggml_set_param?"); // 断言：必须存在可训练参数
	        GGML_ASSERT(any_loss && "no training loss found, did you forget to call ggml_set_loss?"); // 断言：必须存在损失
	    } // 参数和损失检查结束
	    for (int i = 0; i < n_nodes_f; ++i) { // 遍历所有前向节点，确定哪些节点需要梯度
	        struct ggml_tensor * node = cgraph->nodes[i]; // 获取当前节点
	        if (node->type == GGML_TYPE_I32) { // 如果节点是整数32类型
	            continue; // 跳过（整数类型不需要梯度）
	        } // 类型检查结束
	        bool node_needs_grad = (node->flags & GGML_TENSOR_FLAG_PARAM) || (node->flags & GGML_TENSOR_FLAG_LOSS); // 判断节点是否需要梯度（是参数或损失）
	        bool ignore_src[GGML_MAX_SRC] = {false}; // 初始化忽略源张量标志数组
	        switch (node->op) { // 根据操作类型处理特殊忽略情况
	            // gradients in node->src[0] for one reason or another have no effect on output gradients // 英文注释：某些操作的 src0 梯度对输出梯度无影响
	            case GGML_OP_IM2COL:      // only used for its shape // IM2COL 操作仅用于其形状
	            case GGML_OP_IM2COL_BACK: // same as IM2COL // IM2COL_BACK 同理
	                ignore_src[0] = true; // 忽略第一个源张量的梯度
	                break; // 跳出
	            case GGML_OP_UNARY: { // 一元操作的特殊处理
	                const enum ggml_unary_op uop = ggml_get_unary_op(node); // 获取具体的一元操作类型
	                // SGN and STEP unary ops are piecewise constant // 英文注释：SGN 和 STEP 是分段常量函数
	                if (uop == GGML_UNARY_OP_SGN || uop == GGML_UNARY_OP_STEP) { // 如果是符号函数或阶跃函数
	                    ignore_src[0] = true; // 忽略第一个源张量的梯度
	                } // 条件判断结束
	            } break; // UNARY 处理结束
	                                                                    // 空行（第6999行）
	            // gradients in node->src[1] for one reason or another have no effect on output gradients // 英文注释：某些操作的 src1 梯度对输出梯度无影响（第7000行）
// 文件: ggml.c 第7000-7765行 中文注释版本
// 本部分包含: 计算图梯度传播、计算图构建/管理、图可视化(DOT格式)、张量标志设置、量化初始化与分块量化、日志系统、线程池参数等核心功能

            // gradients in node->src[1] for one reason or another have no effect on output gradients // node->src[1]中的梯度由于某些原因对输出梯度没有影响
            case GGML_OP_CPY:           // gradients in CPY target are irrelevant // CPY目标张量的梯度不相关
            case GGML_OP_GET_ROWS:      // row indices not differentiable // 行索引不可微分
            case GGML_OP_GET_ROWS_BACK: // same as for GET_ROWS // 与GET_ROWS相同，行索引不可微
            case GGML_OP_ROPE:          // positions not differentiable // 位置信息不可微分
                ignore_src[1] = true; // 标记忽略src[1]的梯度 // mark to ignore src[1] gradient
                break; // 跳出switch // exit switch

            default: // 默认情况 // default case
                break; // 不做额外处理 // no extra handling
        } // 结束switch // end switch
        for (int j = 0; j < GGML_MAX_SRC; ++j) { // 遍历所有可能的源张量 // iterate over all possible source tensors
            if (!node->src[j] || ignore_src[j] || !grads_needed[ggml_hash_find(&cgraph->visited_hash_set, node->src[j])]) { // 如果源为空、被忽略或不需要梯度 // if src is null, ignored, or grad not needed
                continue; // 跳过此源 // skip this source
            } // 结束if // end if
            GGML_ASSERT(node->src[j]->type == GGML_TYPE_F32 || node->src[j]->type == GGML_TYPE_F16); // 断言源张量类型为F32或F16 // assert source tensor type is F32 or F16
            node_needs_grad = true; // 标记此节点需要梯度 // mark this node needs gradient
            break; // 找到一个需要梯度的源即可退出循环 // found one source needing grad, exit loop
        } // 结束for // end for
        if (!node_needs_grad) { // 如果节点不需要梯度 // if node does not need gradient
            continue; // 跳过此节点 // skip this node
        } // 结束if // end if

        // inplace operations are currently not supported // 当前不支持原地操作
        GGML_ASSERT(!node->view_src || node->op == GGML_OP_CPY || node->op == GGML_OP_VIEW || // 断言非view操作或为特定操作 // assert not a view or specific ops
            node->op == GGML_OP_RESHAPE || node->op == GGML_OP_PERMUTE || node->op == GGML_OP_TRANSPOSE); // RESHAPE/PERMUTE/TRANSPOSE除外 // except RESHAPE/PERMUTE/TRANSPOSE

        const size_t ihash = ggml_hash_find(&cgraph->visited_hash_set, node); // 在哈希集合中查找节点的哈希索引 // find hash index of node in hash set
        GGML_ASSERT(ihash != GGML_HASHSET_FULL); // 断言哈希表未满 // assert hash table is not full
        GGML_ASSERT(ggml_bitset_get(cgraph->visited_hash_set.used, ihash)); // 断言该位置已被使用 // assert this slot is in use
        if (grad_accs && grad_accs[i]) { // 如果提供了梯度累加器数组且当前有值 // if grad accumulator array provided and current entry has value
            cgraph->grad_accs[ihash] = grad_accs[i]; // 设置梯度累加器 // set gradient accumulator
            cgraph->grads[ihash]     = cgraph->grad_accs[ihash]; // 梯度指针指向累加器 // grad pointer points to accumulator
        } else if (node->flags & GGML_TENSOR_FLAG_LOSS) { // 否则如果是损失张量 // else if it's a loss tensor
            // loss tensors always need a gradient accumulator // 损失张量始终需要梯度累加器
            cgraph->grad_accs[ihash] = ggml_new_tensor(ctx, GGML_TYPE_F32, GGML_MAX_DIMS, node->ne); // 为损失张量创建新的F32梯度累加器 // create new F32 grad accumulator for loss tensor
            cgraph->grads[ihash]     = cgraph->grad_accs[ihash]; // 梯度指向累加器 // grad points to accumulator
        } // 结束if // end if
        grads_needed[ihash] = true; // 标记该节点需要梯度 // mark this node needs gradient
    } // 结束for（前向遍历节点）// end for (forward node iteration)

    for (int i = n_nodes_f - 1; i >= 0; --i) { // 反向遍历计算图节点 // reverse iterate through computation graph nodes
        // inplace operations to add gradients are not created by ggml_compute_backward except for gradient accumulation // 添加梯度的原地操作不会由ggml_compute_backward创建（梯度累加除外）
        // use allocator to automatically make inplace operations // 使用分配器自动执行原地操作
        ggml_compute_backward(ctx, cgraph, i, grads_needed); // 计算第i个节点的反向传播梯度 // compute backward gradient for node i
    } // 结束for（反向遍历）// end for (reverse iteration)

    free(grads_needed); // 释放梯度需求标记数组 // free gradient needs flag array
} // 结束ggml_build_backward_impl函数 // end ggml_build_backward_impl function

static void * incr_ptr_aligned(void ** p, size_t size, size_t align) { // 按对齐要求递增指针，用于内存布局计算 // increment pointer with alignment, for memory layout calculation
    void * ptr = *p; // 获取当前指针 // get current pointer
    ptr = (void *) GGML_PAD((uintptr_t) ptr, align); // 将指针对齐到指定边界 // align pointer to specified boundary
    *p = (void *) ((char *) ptr + size); // 更新指针位置，前进size字节 // update pointer position, advance by size bytes
    return ptr; // 返回对齐后的原始指针 // return aligned original pointer
} // 结束incr_ptr_aligned函数 // end incr_ptr_aligned function

static size_t ggml_graph_nbytes(size_t size, bool grads) { // 计算计算图所需的字节数 // calculate bytes needed for computation graph
    size_t hash_size = ggml_hash_size(size * 2); // 哈希表大小为图容量的两倍 // hash table size is twice graph capacity
    void * p = 0; // 初始化指针为0 // initialize pointer to 0
    incr_ptr_aligned(&p, sizeof(struct ggml_cgraph), 1); // 预留cgraph结构体空间 // reserve space for cgraph struct
    incr_ptr_aligned(&p, size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // nodes // 预留节点指针数组空间 // reserve space for node pointer array
    incr_ptr_aligned(&p, size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // leafs // 预留叶子指针数组空间 // reserve space for leaf pointer array
    incr_ptr_aligned(&p, hash_size * sizeof(int32_t), sizeof(int32_t)); // use_counts // 预留使用计数数组空间 // reserve space for use count array
    incr_ptr_aligned(&p, hash_size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // hash keys // 预留哈希键数组空间 // reserve space for hash key array
    if (grads) { // 如果需要梯度 // if gradients are needed
        incr_ptr_aligned(&p, hash_size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // grads // 预留梯度指针数组空间 // reserve space for grad pointer array
        incr_ptr_aligned(&p, hash_size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // grad_accs // 预留梯度累加器数组空间 // reserve space for grad accumulator array
    } // 结束if // end if
    incr_ptr_aligned(&p, ggml_bitset_size(hash_size) * sizeof(ggml_bitset_t), sizeof(ggml_bitset_t)); // 预留哈希集合位集空间 // reserve space for hash set bitset

    size_t nbytes = (size_t) p; // 指针值即为总字节数 // pointer value equals total bytes
    return nbytes; // 返回所需总字节数 // return total bytes needed
} // 结束ggml_graph_nbytes函数 // end ggml_graph_nbytes function

size_t ggml_graph_overhead_custom(size_t size, bool grads) { // 计算自定义大小计算图的总开销（含对象头） // calculate total overhead for custom-sized graph (including object header)
    return GGML_OBJECT_SIZE + GGML_PAD(ggml_graph_nbytes(size, grads), GGML_MEM_ALIGN); // 对象头大小 + 对齐后的图数据大小 // object header size + aligned graph data size
} // 结束ggml_graph_overhead_custom函数 // end ggml_graph_overhead_custom function

size_t ggml_graph_overhead(void) { // 计算默认大小计算图的总开销 // calculate total overhead for default-sized graph
    return ggml_graph_overhead_custom(GGML_DEFAULT_GRAPH_SIZE, false); // 使用默认图大小，不包含梯度 // use default graph size, without gradients
} // 结束ggml_graph_overhead函数 // end ggml_graph_overhead function

struct ggml_cgraph * ggml_new_graph_custom(struct ggml_context * ctx, size_t size, bool grads) { // 创建自定义大小的计算图 // create computation graph with custom size
    const size_t obj_size = ggml_graph_nbytes(size, grads); // 计算图数据所需字节数 // calculate bytes needed for graph data
    struct ggml_object * obj = ggml_new_object(ctx, GGML_OBJECT_TYPE_GRAPH, obj_size); // 在上下文中分配图对象 // allocate graph object in context
    struct ggml_cgraph * cgraph = (struct ggml_cgraph *) ((char *) ctx->mem_buffer + obj->offs); // 获取图结构体指针 // get graph struct pointer

    // the size of the hash table is doubled since it needs to hold both nodes and leafs // 哈希表大小翻倍，因为需要容纳节点和叶子
    size_t hash_size = ggml_hash_size(size * 2); // 哈希表容量 // hash table capacity

    void * p = cgraph + 1; // 指针跳过cgraph结构体，指向数据区起始 // pointer skips cgraph struct, points to data area start

    struct ggml_tensor ** nodes_ptr      =         incr_ptr_aligned(&p, size      * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // 节点指针数组 // node pointer array
    struct ggml_tensor ** leafs_ptr      =         incr_ptr_aligned(&p, size      * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // 叶子指针数组 // leaf pointer array
    int32_t             * use_counts_ptr =         incr_ptr_aligned(&p, hash_size * sizeof(int32_t), sizeof(int32_t)); // 使用计数数组 // use count array
    struct ggml_tensor ** hash_keys_ptr  =         incr_ptr_aligned(&p, hash_size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)); // 哈希键数组 // hash key array
    struct ggml_tensor ** grads_ptr      = grads ? incr_ptr_aligned(&p, hash_size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)) : NULL; // 梯度数组（条件分配）// grad array (conditional allocation)
    struct ggml_tensor ** grad_accs_ptr  = grads ? incr_ptr_aligned(&p, hash_size * sizeof(struct ggml_tensor *), sizeof(struct ggml_tensor *)) : NULL; // 梯度累加器数组（条件分配）// grad accumulator array (conditional allocation)

    ggml_bitset_t * hash_used = incr_ptr_aligned(&p, ggml_bitset_size(hash_size) * sizeof(ggml_bitset_t), sizeof(ggml_bitset_t)); // 哈希集合位集 // hash set bitset

    // check that we allocated the correct amount of memory // 检查分配了正确数量的内存
    assert(obj_size == (size_t)((char *)p - (char *)cgraph)); // 断言实际使用量等于预计算量 // assert actual usage equals precomputed amount

    *cgraph = (struct ggml_cgraph) { // 初始化计算图结构体 // initialize computation graph struct
        /*.size         =*/ size, // 图容量 // graph capacity
        /*.n_nodes      =*/ 0, // 当前节点数为0 // current node count is 0
        /*.n_leafs      =*/ 0, // 当前叶子数为0 // current leaf count is 0
        /*.nodes        =*/ nodes_ptr, // 节点数组指针 // node array pointer
        /*.grads        =*/ grads_ptr, // 梯度数组指针 // grad array pointer
        /*.grad_accs    =*/ grad_accs_ptr, // 梯度累加器数组指针 // grad accumulator array pointer
        /*.leafs        =*/ leafs_ptr, // 叶子数组指针 // leaf array pointer
        /*.use_counts   =*/ use_counts_ptr, // 使用计数数组指针 // use count array pointer
        /*.hash_table   =*/ { hash_size, hash_used, hash_keys_ptr }, // 哈希表：大小、位集、键数组 // hash table: size, bitset, key array
        /*.order        =*/ GGML_CGRAPH_EVAL_ORDER_LEFT_TO_RIGHT, // 默认从左到右求值顺序 // default left-to-right evaluation order
        /*.uid          =*/ 0, // 唯一标识符初始化为0 // unique identifier initialized to 0
    }; // 结束结构体初始化 // end struct initialization

    ggml_hash_set_reset(&cgraph->visited_hash_set); // 重置哈希集合 // reset hash set
    if (grads) { // 如果启用了梯度 // if gradients are enabled
        memset(cgraph->grads,     0, hash_size*sizeof(struct ggml_tensor *)); // 清零梯度数组 // zero out grad array
        memset(cgraph->grad_accs, 0, hash_size*sizeof(struct ggml_tensor *)); // 清零梯度累加器数组 // zero out grad accumulator array
    } // 结束if // end if

    return cgraph; // 返回新创建的计算图 // return newly created computation graph
} // 结束ggml_new_graph_custom函数 // end ggml_new_graph_custom function

struct ggml_cgraph * ggml_new_graph(struct ggml_context * ctx) { // 使用默认参数创建计算图 // create computation graph with default parameters
    return ggml_new_graph_custom(ctx, GGML_DEFAULT_GRAPH_SIZE, false); // 默认大小，不启用梯度 // default size, gradients disabled
} // 结束ggml_new_graph函数 // end ggml_new_graph function

struct ggml_cgraph ggml_graph_view(struct ggml_cgraph * cgraph0, int i0, int i1) { // 创建计算图的视图（切片），包含节点i0到i1-1 // create a view (slice) of the graph, containing nodes i0 to i1-1
    struct ggml_cgraph cgraph = { // 构造视图结构体 // construct view struct
        /*.size             =*/ 0, // 视图大小设为0（只读视图）// view size set to 0 (read-only view)
        /*.n_nodes          =*/ i1 - i0, // 节点数为i1-i0 // node count is i1-i0
        /*.n_leafs          =*/ 0, // 叶子数设为0 // leaf count set to 0
        /*.nodes            =*/ cgraph0->nodes + i0, // 节点指针指向原图的子集 // node pointer points to subset of original graph
        /*.grads            =*/ NULL, // gradients would need visited_hash_set // 梯度为NULL，需要visited_hash_set才能使用 // gradients NULL, would need visited_hash_set
        /*.grad_accs        =*/ NULL, // 梯度累加器为NULL // grad accumulators NULL
        /*.leafs            =*/ NULL, // 叶子为NULL // leafs NULL
        /*.use_counts       =*/ cgraph0->use_counts, // 共享原图的使用计数 // share use counts with original graph
        /*.visited_hash_set =*/ cgraph0->visited_hash_set, // 共享原图的哈希集合 // share hash set with original graph
        /*.order            =*/ cgraph0->order, // 继承原图的求值顺序 // inherit evaluation order from original graph
        /*.uid              =*/ 0 // 唯一标识符设为0 // unique identifier set to 0
    }; // 结束结构体初始化 // end struct initialization

    return cgraph; // 返回视图（按值返回）// return view (by value)
} // 结束ggml_graph_view函数 // end ggml_graph_view function

void ggml_graph_cpy(struct ggml_cgraph * src, struct ggml_cgraph * dst) { // 将源计算图复制到目标计算图 // copy source graph to destination graph
    GGML_ASSERT(dst->size >= src->n_leafs); // 断言目标图容量足够存放叶子 // assert destination capacity sufficient for leafs
    GGML_ASSERT(dst->size >= src->n_nodes); // 断言目标图容量足够存放节点 // assert destination capacity sufficient for nodes
    GGML_ASSERT(dst->visited_hash_set.size >= src->visited_hash_set.size); // 断言目标哈希表足够大 // assert destination hash table large enough

    dst->n_leafs = src->n_leafs; // 复制叶子数 // copy leaf count
    dst->n_nodes = src->n_nodes; // 复制节点数 // copy node count
    dst->order   = src->order; // 复制求值顺序 // copy evaluation order

    for (int i = 0; i < src->n_leafs; ++i) { // 遍历源图的所有叶子 // iterate all leafs in source graph
        dst->leafs[i] = src->leafs[i]; // 复制叶子张量指针 // copy leaf tensor pointer
    } // 结束for // end for

    for (int i = 0; i < src->n_nodes; ++i) { // 遍历源图的所有节点 // iterate all nodes in source graph
        dst->nodes[i] = src->nodes[i]; // 复制节点张量指针 // copy node tensor pointer
    } // 结束for // end for

    for (size_t i = 0; i < src->visited_hash_set.size; ++i) { // 遍历源哈希表 // iterate source hash table
        // copy all hashset keys (tensors) that are in use // 复制所有正在使用的哈希集键（张量）
        if (ggml_bitset_get(src->visited_hash_set.used, i)) { // 如果该位置在使用中 // if this slot is in use
            size_t new_hash_pos = ggml_hash_insert(&dst->visited_hash_set, src->visited_hash_set.keys[i]); // 插入到目标哈希表 // insert into destination hash table
            dst->use_counts[new_hash_pos] = src->use_counts[i]; // 复制使用计数 // copy use count
        } // 结束if // end if
    } // 结束for // end for

    if (dst->grads) { // 如果目标图支持梯度 // if destination graph supports gradients
        memset(dst->grads,     0, dst->visited_hash_set.size*sizeof(struct ggml_tensor *)); // 清零目标梯度数组 // zero out destination grad array
        memset(dst->grad_accs, 0, dst->visited_hash_set.size*sizeof(struct ggml_tensor *)); // 清零目标梯度累加器数组 // zero out destination grad accumulator array
    } // 结束if // end if
    if (src->grads) { // 如果源图有梯度 // if source graph has gradients
        GGML_ASSERT(dst->grads     != NULL); // 断言目标梯度数组存在 // assert destination grad array exists
        GGML_ASSERT(dst->grad_accs != NULL); // 断言目标梯度累加器存在 // assert destination grad accumulator exists
        for (int i = 0; i < src->n_nodes; ++i) { // 遍历源图所有节点 // iterate all nodes in source graph
            const size_t igrad_src = ggml_hash_find(&src->visited_hash_set, src->nodes[i]); // 在源哈希表中查找节点 // find node in source hash table
            const size_t igrad_dst = ggml_hash_find(&dst->visited_hash_set, dst->nodes[i]); // 在目标哈希表中查找节点 // find node in destination hash table

            GGML_ASSERT(igrad_src != GGML_HASHSET_FULL); // 断言源哈希表未满 // assert source hash table not full
            GGML_ASSERT(ggml_bitset_get(src->visited_hash_set.used, igrad_src)); // 断言源位置已使用 // assert source slot is used
            GGML_ASSERT(igrad_dst != GGML_HASHSET_FULL); // 断言目标哈希表未满 // assert destination hash table not full
            GGML_ASSERT(ggml_bitset_get(dst->visited_hash_set.used, igrad_dst)); // 断言目标位置已使用 // assert destination slot is used

            dst->grads[igrad_dst]     = src->grads[igrad_src]; // 复制梯度指针 // copy grad pointer
            dst->grad_accs[igrad_dst] = src->grad_accs[igrad_src]; // 复制梯度累加器指针 // copy grad accumulator pointer
        } // 结束for // end for
    } // 结束if // end if
} // 结束ggml_graph_cpy函数 // end ggml_graph_cpy function

struct ggml_cgraph * ggml_graph_dup(struct ggml_context * ctx, struct ggml_cgraph * cgraph, bool force_grads) { // 复制计算图到新的内存区域 // duplicate computation graph to new memory region
    struct ggml_cgraph * result = ggml_new_graph_custom(ctx, cgraph->size, cgraph->grads || force_grads); // 创建新图，可选强制启用梯度 // create new graph, optionally force-enable gradients
    ggml_graph_cpy(cgraph, result); // 将原图内容复制到新图 // copy original graph contents to new graph
    return result; // 返回新图的指针 // return pointer to new graph
} // 结束ggml_graph_dup函数 // end ggml_graph_dup function

struct ggml_tensor * ggml_set_zero(struct ggml_tensor * tensor) { // 将张量的所有数据清零 // zero out all data in a tensor
    if (ggml_is_empty(tensor)) { // 如果张量为空 // if tensor is empty
        return tensor; // 直接返回 // return directly
    } // 结束if // end if
    if (tensor->buffer) { // 如果张量有后端缓冲区 // if tensor has a backend buffer
        ggml_backend_tensor_memset(tensor, 0, 0, ggml_nbytes(tensor)); // 通过后端API清零 // zero via backend API
    } else { // 否则 // otherwise
        GGML_ASSERT(tensor->data); // 断言张量有数据指针 // assert tensor has data pointer
        memset(tensor->data, 0, ggml_nbytes(tensor)); // 直接用memset清零 // zero directly with memset
    } // 结束if // end if
    return tensor; // 返回张量 // return tensor
} // 结束ggml_set_zero函数 // end ggml_set_zero function

void ggml_graph_reset(struct ggml_cgraph * cgraph) { // 重置计算图的梯度状态 // reset computation graph's gradient state
    if (!cgraph) { // 如果图为空指针 // if graph is null pointer
        return; // 直接返回 // return directly
    } // 结束if // end if
    GGML_ASSERT(cgraph->grads != NULL); // 断言梯度数组存在 // assert grad array exists

    for (int i = 0; i < cgraph->n_nodes; i++) { // 遍历所有节点 // iterate all nodes
        struct ggml_tensor * node     = cgraph->nodes[i]; // 获取当前节点 // get current node
        struct ggml_tensor * grad_acc = ggml_graph_get_grad_acc(cgraph, node); // 获取该节点的梯度累加器 // get grad accumulator for this node

        if (node->op == GGML_OP_OPT_STEP_ADAMW) { // 如果是AdamW优化步骤操作 // if it's AdamW optimizer step operation
            // clear momenta // 清零动量
            ggml_set_zero(node->src[2]); // 清零第一动量 // zero first momentum
            ggml_set_zero(node->src[3]); // 清零第二动量 // zero second momentum
        } // 结束if // end if

        // initial gradients of loss should be 1, 0 otherwise // 损失张量的初始梯度为1，其余为0
        if (grad_acc) { // 如果存在梯度累加器 // if grad accumulator exists
            if (node->flags & GGML_TENSOR_FLAG_LOSS) { // 如果是损失张量 // if it's a loss tensor
                GGML_ASSERT(grad_acc->type == GGML_TYPE_F32); // 断言梯度类型为F32 // assert grad type is F32
                GGML_ASSERT(ggml_is_scalar(grad_acc)); // 断言梯度为标量 // assert grad is scalar

                const float onef = 1.0f; // 初始梯度值1.0 // initial gradient value 1.0
                if (grad_acc->buffer) { // 如果梯度有后端缓冲区 // if grad has backend buffer
                    ggml_backend_tensor_set(grad_acc, &onef, 0, sizeof(float)); // 通过后端API设置值 // set value via backend API
                } else { // 否则 // otherwise
                    GGML_ASSERT(grad_acc->data); // 断言梯度有数据指针 // assert grad has data pointer
                    *((float *) grad_acc->data) = onef; // 直接写入1.0 // write 1.0 directly
                } // 结束if // end if
            } else { // 否则（非损失张量）// otherwise (non-loss tensor)
                ggml_set_zero(grad_acc); // 清零梯度累加器 // zero out grad accumulator
            } // 结束if // end if
        } // 结束if // end if
    } // 结束for // end for
} // 结束ggml_graph_reset函数 // end ggml_graph_reset function

void ggml_graph_clear(struct ggml_cgraph * cgraph) { // 清空计算图（重置节点和叶子计数）// clear computation graph (reset node and leaf counts)
    cgraph->n_leafs = 0; // 叶子数归零 // reset leaf count to zero
    cgraph->n_nodes = 0; // 节点数归零 // reset node count to zero
    ggml_hash_set_reset(&cgraph->visited_hash_set); // 重置哈希集合 // reset hash set
} // 结束ggml_graph_clear函数 // end ggml_graph_clear function

int ggml_graph_size(struct ggml_cgraph * cgraph) { // 获取计算图容量 // get computation graph capacity
    return cgraph->size; // 返回容量值 // return capacity value
} // 结束ggml_graph_size函数 // end ggml_graph_size function

struct ggml_tensor * ggml_graph_node(struct ggml_cgraph * cgraph, int i) { // 获取计算图中第i个节点（支持负索引）// get i-th node in graph (supports negative index)
    if (i < 0) { // 如果索引为负 // if index is negative
        GGML_ASSERT(cgraph->n_nodes + i >= 0); // 断言转换后的索引有效 // assert converted index is valid
        return cgraph->nodes[cgraph->n_nodes + i]; // 返回倒数第|i|个节点 // return |i|-th node from end
    } // 结束if // end if

    GGML_ASSERT(i < cgraph->n_nodes); // 断言索引在范围内 // assert index is in range
    return cgraph->nodes[i]; // 返回第i个节点 // return i-th node
} // 结束ggml_graph_node函数 // end ggml_graph_node function

struct ggml_tensor ** ggml_graph_nodes(struct ggml_cgraph * cgraph) { // 获取节点数组指针 // get node array pointer
    return cgraph->nodes; // 返回节点数组首地址 // return address of node array
} // 结束ggml_graph_nodes函数 // end ggml_graph_nodes function

int ggml_graph_n_nodes(struct ggml_cgraph * cgraph) { // 获取计算图中的节点数量 // get number of nodes in computation graph
    return cgraph->n_nodes; // 返回节点数 // return node count
} // 结束ggml_graph_n_nodes函数 // end ggml_graph_n_nodes function

void ggml_graph_add_node(struct ggml_cgraph * cgraph, struct ggml_tensor * tensor) { // 向计算图添加一个节点 // add a node to computation graph
    GGML_ASSERT(cgraph->size > cgraph->n_nodes); // 断言图还有剩余容量 // assert graph has remaining capacity
    cgraph->nodes[cgraph->n_nodes] = tensor; // 在当前末尾位置存放张量 // store tensor at current end position
    cgraph->n_nodes++; // 节点计数加1 // increment node count
} // 结束ggml_graph_add_node函数 // end ggml_graph_add_node function

struct ggml_tensor * ggml_graph_get_tensor(const struct ggml_cgraph * cgraph, const char * name) { // 按名称查找张量（先搜叶子再搜节点）// find tensor by name (search leafs first, then nodes)
    for (int i = 0; i < cgraph->n_leafs; i++) { // 遍历所有叶子 // iterate all leafs
        struct ggml_tensor * leaf = cgraph->leafs[i]; // 获取当前叶子 // get current leaf

        if (strcmp(leaf->name, name) == 0) { // 比较名称 // compare names
            return leaf; // 找到匹配，返回叶子 // found match, return leaf
        } // 结束if // end if
    } // 结束for // end for

    for (int i = 0; i < cgraph->n_nodes; i++) { // 遍历所有节点 // iterate all nodes
        struct ggml_tensor * node = cgraph->nodes[i]; // 获取当前节点 // get current node

        if (strcmp(node->name, name) == 0) { // 比较名称 // compare names
            return node; // 找到匹配，返回节点 // found match, return node
        } // 结束if // end if
    } // 结束for // end for

    return NULL; // 未找到，返回NULL // not found, return NULL
} // 结束ggml_graph_get_tensor函数 // end ggml_graph_get_tensor function

struct ggml_tensor * ggml_graph_get_grad(const struct ggml_cgraph * cgraph, const struct ggml_tensor * node) { // 获取节点对应的梯度张量 // get gradient tensor for a node
    const size_t igrad = ggml_hash_find(&cgraph->visited_hash_set, node); // 在哈希表中查找节点 // find node in hash table
    return igrad != GGML_HASHSET_FULL && ggml_bitset_get(cgraph->visited_hash_set.used, igrad) && cgraph->grads ? cgraph->grads[igrad] : NULL; // 如果找到且梯度存在则返回，否则返回NULL // return grad if found and exists, else NULL
} // 结束ggml_graph_get_grad函数 // end ggml_graph_get_grad function

struct ggml_tensor * ggml_graph_get_grad_acc(const struct ggml_cgraph * cgraph, const struct ggml_tensor * node) { // 获取节点对应的梯度累加器 // get gradient accumulator for a node
    const size_t igrad = ggml_hash_find(&cgraph->visited_hash_set, node); // 在哈希表中查找节点 // find node in hash table
    return igrad != GGML_HASHSET_FULL && ggml_bitset_get(cgraph->visited_hash_set.used, igrad) && cgraph->grad_accs ? cgraph->grad_accs[igrad] : NULL; // 如果找到且累加器存在则返回，否则返回NULL // return accumulator if found and exists, else NULL
} // 结束ggml_graph_get_grad_acc函数 // end ggml_graph_get_grad_acc function

void ggml_graph_print(const struct ggml_cgraph * cgraph) { // 打印计算图信息到日志 // print computation graph info to log
    GGML_LOG_INFO("=== GRAPH ===\n"); // 打印图标题 // print graph title

    GGML_LOG_INFO("n_nodes = %d\n", cgraph->n_nodes); // 打印节点数量 // print node count
    for (int i = 0; i < cgraph->n_nodes; i++) { // 遍历所有节点 // iterate all nodes
        struct ggml_tensor * node = cgraph->nodes[i]; // 获取当前节点 // get current node

        GGML_LOG_INFO(" - %3d: [ %5" PRId64 ", %5" PRId64 ", %5" PRId64 "] %16s %s\n", // 打印节点维度和操作信息 // print node dimensions and op info
                i, // 节点索引 // node index
                node->ne[0], node->ne[1], node->ne[2], // 前三个维度 // first three dimensions
                ggml_op_name(node->op), (node->flags & GGML_TENSOR_FLAG_PARAM) ? "x" : // 参数张量标记"x" // parameter tensor mark "x"
                      ggml_graph_get_grad(cgraph, node) ? "g" : " "); // 有梯度标记"g"，否则空格 // has gradient mark "g", else space
    } // 结束for // end for

    GGML_LOG_INFO("n_leafs = %d\n", cgraph->n_leafs); // 打印叶子数量 // print leaf count
    for (int i = 0; i < cgraph->n_leafs; i++) { // 遍历所有叶子 // iterate all leafs
        struct ggml_tensor * node = cgraph->leafs[i]; // 获取当前叶子 // get current leaf

        GGML_LOG_INFO(" - %3d: [ %5" PRId64 ", %5" PRId64 "] %8s %16s\n", // 打印叶子信息 // print leaf info
                i, // 叶子索引 // leaf index
                node->ne[0], node->ne[1], // 前两个维度 // first two dimensions
                ggml_op_name(node->op), // 操作名 // operation name
                ggml_get_name(node)); // 张量名称 // tensor name
    } // 结束for // end for

    GGML_LOG_INFO("========================================\n"); // 打印分隔线 // print separator line
} // 结束ggml_graph_print函数 // end ggml_graph_print function

static int ggml_node_list_find_tensor(const struct ggml_cgraph * cgraph, // 在节点索引列表中查找张量 // find tensor in node index list
                                      const int *                idxs, // 节点索引数组 // node index array
                                      int                        count, // 索引数量 // index count
                                      const struct ggml_tensor * tensor) { // 要查找的张量 // tensor to find
    GGML_ASSERT(cgraph && idxs); // 断言参数非空 // assert parameters are non-null
    for (int i = 0; i < count; ++i) { // 遍历索引列表 // iterate index list
        const int node_idx = idxs[i]; // 获取当前索引 // get current index

        if (node_idx >= cgraph->n_nodes) { // 如果索引超出范围 // if index is out of range
            return -1; // 返回-1表示未找到 // return -1 meaning not found
        } // 结束if // end if
        if (cgraph->nodes[node_idx] == tensor) { // 如果找到匹配的张量 // if matching tensor found
            return i; // 返回在列表中的位置 // return position in list
        } // 结束if // end if
    } // 结束for // end for
    return -1; // 未找到，返回-1 // not found, return -1
} // 结束ggml_node_list_find_tensor函数 // end ggml_node_list_find_tensor function

bool ggml_can_fuse_subgraph_ext(const struct ggml_cgraph * cgraph, // 检查子图是否可以被融合（扩展版本）// check if subgraph can be fused (extended version)
                                const int *                node_idxs, // 节点索引数组 // node index array
                                int                        count, // 节点数量 // node count
                                const enum ggml_op *       ops, // 期望的操作类型数组 // expected operation type array
                                const int *                outputs, // 输出节点索引数组 // output node index array
                                int                        num_outputs) { // 输出节点数量 // output node count
    GGML_ASSERT(outputs && num_outputs > 0); // 断言输出参数有效 // assert output parameters are valid

    for (int i = 0; i < count; ++i) { // 遍历子图中的所有节点 // iterate all nodes in subgraph
        if (node_idxs[i] >= cgraph->n_nodes) { // 如果索引超出范围 // if index is out of range
            return false; // 不可融合 // cannot fuse
        } // 结束if // end if

        const struct ggml_tensor * node = cgraph->nodes[node_idxs[i]]; // 获取当前节点 // get current node

        if (node->op != ops[i]) { // 如果操作类型不匹配 // if operation type doesn't match
            return false; // 不可融合 // cannot fuse
        } // 结束if // end if

        if ((node->flags & GGML_TENSOR_FLAG_COMPUTE) == 0) { // 如果节点没有计算标志 // if node has no compute flag
            return false; // 不可融合 // cannot fuse
        } // 结束if // end if

        if (ggml_node_list_find_tensor(cgraph, outputs, num_outputs, node) != -1) { // 如果节点是输出之一 // if node is one of the outputs
            continue; // 跳过后续检查 // skip subsequent checks
        } // 结束if // end if

        if (node->flags & GGML_TENSOR_FLAG_OUTPUT) { // 如果节点被标记为输出 // if node is marked as output
            return false; // 不可融合 // cannot fuse
        } // 结束if // end if

        int subgraph_uses = 0; // 子图内部使用次数计数 // count of uses within subgraph
        for (int j = i + 1; j < count; ++j) { // 遍历子图中后续节点 // iterate subsequent nodes in subgraph
            const struct ggml_tensor * other_node = cgraph->nodes[node_idxs[j]]; // 获取后续节点 // get subsequent node
            for (int src_idx = 0; src_idx < GGML_MAX_SRC; src_idx++) { // 遍历后续节点的所有源 // iterate all sources of subsequent node
                if (other_node->src[src_idx] == node) { // 如果后续节点引用了当前节点 // if subsequent node references current node
                    subgraph_uses++; // 增加子图内部使用计数 // increment subgraph internal use count
                } // 结束if // end if
            } // 结束for（遍历源）// end for (iterate sources)
        } // 结束for（遍历后续节点）// end for (iterate subsequent nodes)

        if (subgraph_uses != ggml_node_get_use_count(cgraph, node_idxs[i])) { // 如果子图内部使用次数不等于总使用次数 // if subgraph use count doesn't equal total use count
            return false; // 说明节点被子图外部使用，不可融合 // node is used outside subgraph, cannot fuse
        } // 结束if // end if

        // if node is a view, check if the view_src and all it's parent view_srcs are within the subgraph // 如果节点是视图，检查view_src及其所有父视图是否都在子图内
        struct ggml_tensor * view_src = node->view_src; // 获取视图源张量 // get view source tensor
        while (view_src) { // 沿视图链向上遍历 // traverse up the view chain
            if (ggml_node_list_find_tensor(cgraph, node_idxs, count, view_src) == -1) { // 如果视图源不在子图中 // if view source is not in subgraph
                return false; // 不可融合 // cannot fuse
            } // 结束if // end if
            view_src = view_src->view_src; // 继续向上查找 // continue searching upward
        } // 结束while // end while
    } // 结束for（遍历子图节点）// end for (iterate subgraph nodes)

    return true; // 所有检查通过，可以融合 // all checks passed, can fuse
} // 结束ggml_can_fuse_subgraph_ext函数 // end ggml_can_fuse_subgraph_ext function

// check if node is part of the graph // 检查节点是否属于计算图
static bool ggml_graph_find(const struct ggml_cgraph * cgraph, const struct ggml_tensor * node) { // 在计算图中查找指定节点 // find specified node in computation graph
    if (cgraph == NULL) { // 如果图为空 // if graph is NULL
        return true; // 视为找到 // consider found
    } // 结束if // end if

    for (int i = 0; i < cgraph->n_nodes; i++) { // 遍历所有节点 // iterate all nodes
        if (cgraph->nodes[i] == node) { // 比较指针 // compare pointers
            return true; // 找到 // found
        } // 结束if // end if
    } // 结束for // end for

    return false; // 未找到 // not found
} // 结束ggml_graph_find函数 // end ggml_graph_find function

static struct ggml_tensor * ggml_graph_get_parent(const struct ggml_cgraph * cgraph, const struct ggml_tensor * node) { // 获取节点的父节点（即梯度指向该节点的节点）// get parent of node (node whose gradient points to this node)
    for (int i = 0; i < cgraph->n_nodes; i++) { // 遍历所有节点 // iterate all nodes
        struct ggml_tensor * parent = cgraph->nodes[i]; // 获取当前节点作为候选父节点 // get current node as candidate parent
        struct ggml_tensor * grad = ggml_graph_get_grad(cgraph, parent); // 获取候选父节点的梯度 // get gradient of candidate parent

        if (grad == node) { // 如果梯度就是目标节点 // if gradient is the target node
            return parent; // 返回父节点 // return parent
        } // 结束if // end if
    } // 结束for // end for

    return NULL; // 没有父节点，返回NULL // no parent, return NULL
} // 结束ggml_graph_get_parent函数 // end ggml_graph_get_parent function

static void ggml_graph_dump_dot_node_edge(FILE * fp, const struct ggml_cgraph * gb, struct ggml_tensor * node, struct ggml_tensor * parent, const char * label)  { // 输出DOT格式的节点边 // output DOT format node edge
    struct ggml_tensor * gparent = ggml_graph_get_parent(gb, node); // 获取节点的梯度父节点 // get gradient parent of node
    struct ggml_tensor * gparent0 = ggml_graph_get_parent(gb, parent); // 获取父节点的梯度父节点 // get gradient parent of parent
    fprintf(fp, "  \"%p\" -> \"%p\" [ arrowhead = %s; style = %s; label = \"%s\"; ]\n", // 写入DOT边定义 // write DOT edge definition
            gparent0 ? (void *) gparent0 : (void *) parent, // 起始节点 // start node
            gparent ? (void *) gparent : (void *) node, // 终止节点 // end node
            gparent ? "empty" : "vee", // 箭头样式 // arrow style
            gparent ? "dashed" : "solid", // 线条样式 // line style
            label); // 边标签 // edge label
} // 结束ggml_graph_dump_dot_node_edge函数 // end ggml_graph_dump_dot_node_edge function

static void ggml_graph_dump_dot_leaf_edge(FILE * fp, struct ggml_tensor * node, struct ggml_tensor * parent, const char * label)  { // 输出DOT格式的叶子边 // output DOT format leaf edge
    fprintf(fp, "  \"%p\" -> \"%p\" [ label = \"%s\"; ]\n", // 写入DOT边定义 // write DOT edge definition
            (void *) parent, // 起始节点（父）// start node (parent)
            (void *) node, // 终止节点（子）// end node (child)
            label); // 边标签 // edge label
} // 结束ggml_graph_dump_dot_leaf_edge函数 // end ggml_graph_dump_dot_leaf_edge function

void ggml_graph_dump_dot(const struct ggml_cgraph * gb, const struct ggml_cgraph * cgraph, const char * filename) { // 将计算图导出为DOT格式文件（可用于Graphviz可视化）// export computation graph as DOT format file (for Graphviz visualization)
    char color[16]; // 颜色缓冲区 // color buffer

    FILE * fp = ggml_fopen(filename, "w"); // 打开输出文件 // open output file
    GGML_ASSERT(fp); // 断言文件打开成功 // assert file opened successfully

    fprintf(fp, "digraph G {\n"); // DOT文件头：有向图G // DOT file header: directed graph G
    fprintf(fp, "  newrank = true;\n"); // 启用新排名算法 // enable new ranking algorithm
    fprintf(fp, "  rankdir = TB;\n"); // 从上到下布局 // top-to-bottom layout

    for (int i = 0; i < gb->n_nodes; i++) { // 遍历所有节点 // iterate all nodes
        struct ggml_tensor * node = gb->nodes[i]; // 获取当前节点 // get current node
        struct ggml_tensor * grad = ggml_graph_get_grad(gb, node); // 获取节点的梯度 // get node's gradient

        if (ggml_graph_get_parent(gb, node) != NULL) { // 如果节点本身是某个节点的梯度 // if node itself is a gradient of some node
            continue; // 跳过（避免重复绘制）// skip (avoid duplicate drawing)
        } // 结束if // end if

        if (node->flags & GGML_TENSOR_FLAG_PARAM) { // 如果是参数张量 // if it's a parameter tensor
            snprintf(color, sizeof(color), "yellow"); // 黄色 // yellow
        } else if (grad) { // 如果有梯度 // if has gradient
            if (ggml_graph_find(cgraph, node)) { // 如果节点在cgraph中 // if node is in cgraph
                snprintf(color, sizeof(color), "green"); // 绿色 // green
            } else { // 否则 // otherwise
                snprintf(color, sizeof(color), "lightblue"); // 浅蓝色 // light blue
            } // 结束if // end if
        } else { // 没有梯度 // no gradient
            snprintf(color, sizeof(color), "white"); // 白色 // white
        } // 结束if // end if

        fprintf(fp, "  \"%p\" [ " // 写入DOT节点定义 // write DOT node definition
                    "style = filled; fillcolor = %s; shape = record; " // 填充样式、颜色、record形状 // fill style, color, record shape
                    "label=\"", // 标签开始 // label start
                (void *) node, color); // 节点地址和颜色 // node address and color

        if (strlen(node->name) > 0) { // 如果节点有名称 // if node has a name
            fprintf(fp, "%s (%s)|", node->name, ggml_type_name(node->type)); // 打印名称和类型 // print name and type
        } else { // 否则 // otherwise
            fprintf(fp, "(%s)|", ggml_type_name(node->type)); // 只打印类型 // print type only
        } // 结束if // end if

        if (ggml_is_matrix(node)) { // 如果是矩阵（二维）// if it's a matrix (2D)
            fprintf(fp, "%d [%" PRId64 ", %" PRId64 "] | <x>%s", i, node->ne[0], node->ne[1], ggml_op_symbol(node->op)); // 打印索引、维度和操作符号 // print index, dimensions and op symbol
        } else { // 否则（三维或以上）// otherwise (3D or more)
            fprintf(fp, "%d [%" PRId64 ", %" PRId64 ", %" PRId64 "] | <x>%s", i, node->ne[0], node->ne[1], node->ne[2], ggml_op_symbol(node->op)); // 打印索引和三个维度 // print index and three dimensions
        } // 结束if // end if

        if (grad) { // 如果有梯度 // if has gradient
            fprintf(fp, " | <g>%s\"; ]\n", ggml_op_symbol(grad->op)); // 打印梯度操作符号 // print gradient op symbol
        } else { // 否则 // otherwise
            fprintf(fp, "\"; ]\n"); // 结束节点定义 // end node definition
        } // 结束if // end if
    } // 结束for（遍历节点）// end for (iterate nodes)

    for (int i = 0; i < gb->n_leafs; i++) { // 遍历所有叶子节点 // iterate all leaf nodes
        struct ggml_tensor * node = gb->leafs[i]; // 获取当前叶子 // get current leaf

        snprintf(color, sizeof(color), "pink"); // 叶子节点用粉色 // leaf nodes use pink

        fprintf(fp, "  \"%p\" [ " // 写入DOT叶子节点定义 // write DOT leaf node definition
                    "style = filled; fillcolor = %s; shape = record; " // 填充样式 // fill style
                    "label=\"<x>", // 标签开始 // label start
                (void *) node, color); // 叶子地址和颜色 // leaf address and color

        if (strlen(node->name) > 0) { // 如果叶子有名称 // if leaf has a name
            fprintf(fp, "%s (%s)|", node->name, ggml_type_name(node->type)); // 打印名称和类型 // print name and type
        } else { // 否则 // otherwise
            fprintf(fp, "(%s)|", ggml_type_name(node->type)); // 只打印类型 // print type only
        } // 结束if // end if

        fprintf(fp, "CONST %d [%" PRId64 ", %" PRId64 "]", i, node->ne[0], node->ne[1]); // 打印CONST标记和维度 // print CONST mark and dimensions
        if (ggml_nelements(node) < 5 && node->data != NULL) { // 如果元素少于5个且有数据 // if fewer than 5 elements and has data
            fprintf(fp, " | ("); // 打印数据值开始 // print data values start
            for (int j = 0; j < ggml_nelements(node); j++) { // 遍历每个元素 // iterate each element
                // FIXME: use ggml-backend to obtain the tensor data // 待修复：使用ggml-backend获取张量数据
                //if (node->type == GGML_TYPE_I8 || node->type == GGML_TYPE_I16 || node->type == GGML_TYPE_I32) { // 如果是整数类型 // if integer type
                //    fprintf(fp, "%d", ggml_get_i32_1d(node, j)); // 打印整数值 // print integer value
                //} // 结束if // end if
                //else if (node->type == GGML_TYPE_F32 || // 如果是浮点类型 // if float type
                //         node->type == GGML_TYPE_F16 || // F16类型 // F16 type
                //         node->type == GGML_TYPE_BF16) { // BF16类型 // BF16 type
                //    fprintf(fp, "%.1e", (double)ggml_get_f32_1d(node, j)); // 打印浮点值 // print float value
                //} // 结束if // end if
                //else // 其他类型 // other types
                { // 当前临时实现 // current temporary implementation
                    fprintf(fp, "#"); // 打印占位符 // print placeholder
                } // 结束代码块 // end code block
                if (j < ggml_nelements(node) - 1) { // 如果不是最后一个元素 // if not last element
                    fprintf(fp, ", "); // 打印分隔符 // print separator
                } // 结束if // end if
            } // 结束for（遍历元素）// end for (iterate elements)
            fprintf(fp, ")"); // 打印数据值结束 // print data values end
        } // 结束if // end if
        fprintf(fp, "\"; ]\n"); // 结束叶子节点定义 // end leaf node definition
    } // 结束for（遍历叶子）// end for (iterate leafs)

    for (int i = 0; i < gb->n_nodes; i++) { // 遍历所有节点绘制边 // iterate all nodes to draw edges
        struct ggml_tensor * node = gb->nodes[i]; // 获取当前节点 // get current node

        for (int j = 0; j < GGML_MAX_SRC; j++) { // 遍历所有源 // iterate all sources
            if (node->src[j]) { // 如果源存在 // if source exists
                char label[16]; // 标签缓冲区 // label buffer
                snprintf(label, sizeof(label), "src %d", j); // 生成标签 "src N" // generate label "src N"
                ggml_graph_dump_dot_node_edge(fp, gb, node, node->src[j], label); // 绘制节点间的边 // draw edge between nodes
            } // 结束if // end if
        } // 结束for（遍历源）// end for (iterate sources)
    } // 结束for（遍历节点）// end for (iterate nodes)

    for (int i = 0; i < gb->n_leafs; i++) { // 遍历所有叶子绘制边 // iterate all leafs to draw edges
        struct ggml_tensor * node = gb->leafs[i]; // 获取当前叶子 // get current leaf

        for (int j = 0; j < GGML_MAX_SRC; j++) { // 遍历所有源 // iterate all sources
            if (node->src[j]) { // 如果源存在 // if source exists
                char label[16]; // 标签缓冲区 // label buffer
                snprintf(label, sizeof(label), "src %d", j); // 生成标签 "src N" // generate label "src N"
                ggml_graph_dump_dot_leaf_edge(fp, node, node->src[j], label); // 绘制叶子到源的边 // draw leaf-to-source edge
            } // 结束if // end if
        } // 结束for（遍历源）// end for (iterate sources)
    } // 结束for（遍历叶子）// end for (iterate leafs)

    fprintf(fp, "}\n"); // DOT文件尾 // DOT file footer

    fclose(fp); // 关闭文件 // close file

    GGML_LOG_INFO("%s: dot -Tpng %s -o %s.png && open %s.png\n", __func__, filename, filename, filename); // 打印可视化命令提示 // print visualization command hint
} // 结束ggml_graph_dump_dot函数 // end ggml_graph_dump_dot function

//////////////////////////////////////////////////////////////////////////////// // 分隔线 // separator line

void ggml_set_input(struct ggml_tensor * tensor) { // 将张量标记为输入张量 // mark tensor as input tensor
    tensor->flags |= GGML_TENSOR_FLAG_INPUT; // 设置INPUT标志 // set INPUT flag
} // 结束ggml_set_input函数 // end ggml_set_input function

void ggml_set_output(struct ggml_tensor * tensor) { // 将张量标记为输出张量 // mark tensor as output tensor
    tensor->flags |= GGML_TENSOR_FLAG_OUTPUT; // 设置OUTPUT标志 // set OUTPUT flag
} // 结束ggml_set_output函数 // end ggml_set_output function

void ggml_set_param(struct ggml_tensor * tensor) { // 将张量标记为可训练参数 // mark tensor as trainable parameter
    GGML_ASSERT(tensor->op == GGML_OP_NONE); // 断言张量没有操作（是叶子节点）// assert tensor has no operation (is a leaf node)
    tensor->flags |= GGML_TENSOR_FLAG_PARAM; // 设置PARAM标志 // set PARAM flag
} // 结束ggml_set_param函数 // end ggml_set_param function

void ggml_set_loss(struct ggml_tensor * tensor) { // 将张量标记为损失张量 // mark tensor as loss tensor
    GGML_ASSERT(ggml_is_scalar(tensor)); // 断言张量是标量 // assert tensor is scalar
    GGML_ASSERT(tensor->type == GGML_TYPE_F32); // 断言类型为F32 // assert type is F32
    tensor->flags |= GGML_TENSOR_FLAG_LOSS; // 设置LOSS标志 // set LOSS flag
} // 结束ggml_set_loss函数 // end ggml_set_loss function

//////////////////////////////////////////////////////////////////////////////// // 分隔线 // separator line

void ggml_quantize_init(enum ggml_type type) { // 初始化量化所需的查找表等资源 // initialize lookup tables etc. needed for quantization
    ggml_critical_section_start(); // 进入临界区 // enter critical section

    switch (type) { // 根据量化类型分发 // dispatch by quantization type
        case GGML_TYPE_IQ2_XXS: // IQ2超超小量化 // IQ2 extra-extra-small quantization
        case GGML_TYPE_IQ2_XS: // IQ2超小量化 // IQ2 extra-small quantization
        case GGML_TYPE_IQ2_S: // IQ2小量化 // IQ2 small quantization
        case GGML_TYPE_IQ1_S: // IQ1小量化 // IQ1 small quantization
        case GGML_TYPE_IQ1_M:   iq2xs_init_impl(type); break; // IQ1中等量化，初始化IQ2XS实现 // IQ1 medium quantization, init IQ2XS impl
        case GGML_TYPE_IQ3_XXS: iq3xs_init_impl(256); break; // IQ3超超小量化，使用256级 // IQ3 extra-extra-small, use 256 levels
        case GGML_TYPE_IQ3_S:   iq3xs_init_impl(512); break; // IQ3小量化，使用512级 // IQ3 small, use 512 levels
        default: // nothing // 其他类型无需初始化 // other types need no initialization
            break; // 跳出 // break
    } // 结束switch // end switch

    ggml_critical_section_end(); // 离开临界区 // leave critical section
} // 结束ggml_quantize_init函数 // end ggml_quantize_init function

void ggml_quantize_free(void) { // 释放量化使用的资源 // free resources used by quantization
    ggml_critical_section_start(); // 进入临界区 // enter critical section

    iq2xs_free_impl(GGML_TYPE_IQ2_XXS); // 释放IQ2_XXS查找表 // free IQ2_XXS lookup table
    iq2xs_free_impl(GGML_TYPE_IQ2_XS); // 释放IQ2_XS查找表 // free IQ2_XS lookup table
    iq2xs_free_impl(GGML_TYPE_IQ2_S); // 释放IQ2_S查找表 // free IQ2_S lookup table
    iq2xs_free_impl(GGML_TYPE_IQ1_S); // 释放IQ1_S查找表 // free IQ1_S lookup table
    iq2xs_free_impl(GGML_TYPE_IQ1_M); // 释放IQ1_M查找表 // free IQ1_M lookup table
    iq3xs_free_impl(256); // 释放IQ3_XXS（256级）查找表 // free IQ3_XXS (256 levels) lookup table
    iq3xs_free_impl(512); // 释放IQ3_S（512级）查找表 // free IQ3_S (512 levels) lookup table

    ggml_critical_section_end(); // 离开临界区 // leave critical section
} // 结束ggml_quantize_free函数 // end ggml_quantize_free function

bool ggml_quantize_requires_imatrix(enum ggml_type type) { // 检查量化类型是否需要重要性矩阵 // check if quantization type requires importance matrix
    return // 返回以下条件 // return following condition
        type == GGML_TYPE_IQ2_XXS || // IQ2超超小需要 // IQ2 extra-extra-small needs
        type == GGML_TYPE_IQ2_XS  || // IQ2超小需要 // IQ2 extra-small needs
        type == GGML_TYPE_IQ1_S;//   || // IQ1小需要（注释掉了IQ1_M）// IQ1 small needs (IQ1_M commented out)
        //type == GGML_TYPE_IQ1_M; // IQ1中等（已注释掉）// IQ1 medium (commented out)
} // 结束ggml_quantize_requires_imatrix函数 // end ggml_quantize_requires_imatrix function

size_t ggml_quantize_chunk( // 量化一个数据块 // quantize a chunk of data
        enum ggml_type   type, // 目标量化类型 // target quantization type
           const float * src, // 源浮点数据 // source float data
                  void * dst, // 目标量化数据缓冲区 // destination quantized data buffer
               int64_t   start, // 起始元素位置 // starting element position
               int64_t   nrows, // 要量化的行数 // number of rows to quantize
               int64_t   n_per_row, // 每行元素数 // elements per row
           const float * imatrix) { // 重要性矩阵（可选）// importance matrix (optional)
    const int64_t n = nrows * n_per_row; // 总元素数 // total element count

    if (ggml_quantize_requires_imatrix(type)) { // 如果该类型需要重要性矩阵 // if this type requires importance matrix
        GGML_ASSERT(imatrix != NULL); // 断言提供了重要性矩阵 // assert importance matrix is provided
    } // 结束if // end if

    GGML_ASSERT(start % type_traits[type].blck_size == 0); // 断言起始位置按块大小对齐 // assert start is aligned to block size
    GGML_ASSERT(start % n_per_row == 0); // 断言起始位置按行大小对齐 // assert start is aligned to row size

    ggml_quantize_init(type); // this is noop if already initialized // 初始化量化（如果已初始化则无操作）// init quantization (noop if already initialized)

    const size_t start_row = start / n_per_row; // 计算起始行号 // calculate starting row number
    const size_t row_size  = ggml_row_size(type, n_per_row); // 计算每行量化后的字节大小 // calculate byte size per quantized row

    size_t result = 0; // 结果：量化后的字节大小 // result: byte size after quantization

    switch (type) { // 根据量化类型分发 // dispatch by quantization type
        case GGML_TYPE_Q1_0:    result = quantize_q1_0   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q1_0量化 // Q1_0 quantization
        case GGML_TYPE_Q4_0:    result = quantize_q4_0   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q4_0量化 // Q4_0 quantization
        case GGML_TYPE_Q4_1:    result = quantize_q4_1   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q4_1量化 // Q4_1 quantization
        case GGML_TYPE_Q5_0:    result = quantize_q5_0   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q5_0量化 // Q5_0 quantization
        case GGML_TYPE_Q5_1:    result = quantize_q5_1   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q5_1量化 // Q5_1 quantization
        case GGML_TYPE_Q8_0:    result = quantize_q8_0   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q8_0量化 // Q8_0 quantization
        case GGML_TYPE_MXFP4:   result = quantize_mxfp4  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // MXFP4量化 // MXFP4 quantization
        case GGML_TYPE_NVFP4:   result = quantize_nvfp4  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // NVFP4量化 // NVFP4 quantization
        case GGML_TYPE_Q2_K:    result = quantize_q2_K   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q2_K量化 // Q2_K quantization
        case GGML_TYPE_Q3_K:    result = quantize_q3_K   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q3_K量化 // Q3_K quantization
        case GGML_TYPE_Q4_K:    result = quantize_q4_K   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q4_K量化 // Q4_K quantization
        case GGML_TYPE_Q5_K:    result = quantize_q5_K   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q5_K量化 // Q5_K quantization
        case GGML_TYPE_Q6_K:    result = quantize_q6_K   (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // Q6_K量化 // Q6_K quantization
        case GGML_TYPE_TQ1_0:   result = quantize_tq1_0  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // TQ1_0量化 // TQ1_0 quantization
        case GGML_TYPE_TQ2_0:   result = quantize_tq2_0  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // TQ2_0量化 // TQ2_0 quantization
        case GGML_TYPE_IQ2_XXS: result = quantize_iq2_xxs(src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ2_XXS量化 // IQ2_XXS quantization
        case GGML_TYPE_IQ2_XS:  result = quantize_iq2_xs (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ2_XS量化 // IQ2_XS quantization
        case GGML_TYPE_IQ3_XXS: result = quantize_iq3_xxs(src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ3_XXS量化 // IQ3_XXS quantization
        case GGML_TYPE_IQ3_S:   result = quantize_iq3_s  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ3_S量化 // IQ3_S quantization
        case GGML_TYPE_IQ2_S:   result = quantize_iq2_s  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ2_S量化 // IQ2_S quantization
        case GGML_TYPE_IQ1_S:   result = quantize_iq1_s  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ1_S量化 // IQ1_S quantization
        case GGML_TYPE_IQ1_M:   result = quantize_iq1_m  (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ1_M量化 // IQ1_M quantization
        case GGML_TYPE_IQ4_NL:  result = quantize_iq4_nl (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ4_NL量化 // IQ4_NL quantization
        case GGML_TYPE_IQ4_XS:  result = quantize_iq4_xs (src + start, (char *) dst + start_row * row_size, nrows, n_per_row, imatrix); break; // IQ4_XS量化 // IQ4_XS quantization
        case GGML_TYPE_F16: // F16半精度浮点 // F16 half-precision float
            { // 开始代码块 // begin code block
                size_t elemsize = sizeof(ggml_fp16_t); // F16元素大小 // F16 element size
                ggml_fp32_to_fp16_row(src + start, (ggml_fp16_t *)dst + start, n); // 将F32转换为F16 // convert F32 to F16
                result = n * elemsize; // 计算总字节数 // calculate total bytes
            } break; // 结束F16处理 // end F16 handling
        case GGML_TYPE_BF16: // BF16脑浮点 // BF16 brain float
            { // 开始代码块 // begin code block
                size_t elemsize = sizeof(ggml_bf16_t); // BF16元素大小 // BF16 element size
                ggml_fp32_to_bf16_row_ref(src + start, (ggml_bf16_t *)dst + start, n); // 将F32转换为BF16 // convert F32 to BF16
                result = n * elemsize; // 计算总字节数 // calculate total bytes
            } break; // 结束BF16处理 // end BF16 handling
        case GGML_TYPE_F32: // F32单精度浮点（直接复制）// F32 single-precision float (direct copy)
            { // 开始代码块 // begin code block
                size_t elemsize = sizeof(float); // F32元素大小 // F32 element size
                result = n * elemsize; // 计算总字节数 // calculate total bytes
                memcpy((uint8_t *)dst + start * elemsize, src + start, result); // 直接内存复制 // direct memory copy
            } break; // 结束F32处理 // end F32 handling
        default: // 不支持的类型 // unsupported type
            assert(false); // 触发断言失败 // trigger assertion failure
    } // 结束switch // end switch

    GGML_ASSERT(result == nrows * row_size); // 断言结果大小正确 // assert result size is correct

    return result; // 返回量化后的字节大小 // return quantized byte size
} // 结束ggml_quantize_chunk函数 // end ggml_quantize_chunk function

//////////////////////////////////////////////////////////////////////////////// // 分隔线 // separator line

void ggml_log_get(ggml_log_callback * log_callback, void ** user_data) { // 获取当前日志回调和用户数据 // get current log callback and user data
    *log_callback = g_logger_state.log_callback; // 输出日志回调函数指针 // output log callback function pointer
    *user_data    = g_logger_state.log_callback_user_data; // 输出用户数据指针 // output user data pointer
} // 结束ggml_log_get函数 // end ggml_log_get function

void ggml_log_set(ggml_log_callback log_callback, void * user_data) { // 设置日志回调和用户数据 // set log callback and user data
    g_logger_state.log_callback = log_callback ? log_callback : ggml_log_callback_default; // 设置回调，NULL则使用默认 // set callback, NULL uses default
    g_logger_state.log_callback_user_data = user_data; // 设置用户数据 // set user data
} // 结束ggml_log_set函数 // end ggml_log_set function

void ggml_threadpool_params_init(struct ggml_threadpool_params * p, int n_threads) { // 初始化线程池参数 // initialize thread pool parameters
    p->n_threads  = n_threads; // 线程数量 // number of threads
    p->prio       = 0;     // default priority (usually means normal or inherited) // 默认优先级（通常表示普通或继承的优先级）
    p->poll       = 50;    // hybrid-polling enabled // 启用混合轮询，间隔50 // enable hybrid polling, interval 50
    p->strict_cpu = false; // no strict placement (all threads share same cpumask) // 无严格CPU绑定（所有线程共享相同CPU掩码）// no strict CPU binding (all threads share same CPU mask)
    p->paused     = false; // threads are ready to go // 线程已就绪 // threads are ready
    memset(p->cpumask, 0, GGML_MAX_N_THREADS); // all-zero means use the default affinity (usually inherited) // 全零表示使用默认亲和性（通常是继承的）// all-zero means use default affinity (usually inherited)
} // 结束ggml_threadpool_params_init函数 // end ggml_threadpool_params_init function

struct ggml_threadpool_params ggml_threadpool_params_default(int n_threads) { // 获取默认线程池参数 // get default thread pool parameters
    struct ggml_threadpool_params p; // 声明参数结构体 // declare parameter struct
    ggml_threadpool_params_init(&p, n_threads); // 初始化参数 // initialize parameters
    return p; // 返回参数结构体（按值）// return parameter struct (by value)
} // 结束ggml_threadpool_params_default函数 // end ggml_threadpool_params_default function

bool ggml_threadpool_params_match(const struct ggml_threadpool_params * p0, const struct ggml_threadpool_params * p1) { // 检查两组线程池参数是否匹配 // check if two sets of thread pool parameters match
    if (p0->n_threads  != p1->n_threads  ) return false; // 线程数不匹配 // thread count mismatch
    if (p0->prio       != p1->prio       ) return false; // 优先级不匹配 // priority mismatch
    if (p0->poll       != p1->poll       ) return false; // 轮询间隔不匹配 // poll interval mismatch
    if (p0->strict_cpu != p1->strict_cpu ) return false; // CPU绑定策略不匹配 // CPU binding strategy mismatch
    return memcmp(p0->cpumask, p1->cpumask, GGML_MAX_N_THREADS) == 0; // 比较CPU掩码是否相同 // compare CPU masks for equality
} // 结束ggml_threadpool_params_match函数 // end ggml_threadpool_params_match function
