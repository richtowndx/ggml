}

// ggml_glu // GLU（门控线性单元）标记注释

static struct ggml_tensor * ggml_glu_impl( // GLU 操作的内部实现函数
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 输入张量（第0维会被分为两半）
        struct ggml_tensor  * b, // 可选的第二个输入张量（分割模式使用），可为 NULL
        enum ggml_glu_op      op, // GLU 操作的具体类型
        bool                  swapped) { // 是否交换门控和线性部分
    GGML_ASSERT(ggml_is_contiguous_1(a)); // 断言：a 在第1维及以上必须是连续的

    if (b) { // 如果提供了第二个输入张量 b
        GGML_ASSERT(ggml_is_contiguous_1(b)); // 断言：b 在第1维及以上必须是连续的
        GGML_ASSERT(ggml_are_same_shape(a, b)); // 断言：a 和 b 的形状必须相同
        GGML_ASSERT(a->type == b->type); // 断言：a 和 b 的数据类型必须相同
    }

    int64_t ne[GGML_MAX_DIMS] = { a->ne[0] / 2 }; for (int i = 1; i < GGML_MAX_DIMS; i++) ne[i] = a->ne[i]; // 计算输出维度：第0维减半，其余不变
    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, GGML_MAX_DIMS, b ? a->ne : ne, NULL, 0); // 创建结果张量，有 b 时用完整维度，否则用减半维度

    ggml_set_op_params_i32(result, 0, (int32_t) op); // 将 GLU 操作类型保存为参数
    ggml_set_op_params_i32(result, 1, (int32_t) swapped); // 将交换标志保存为参数

    result->op     = GGML_OP_GLU; // 设置操作类型为 GLU
    result->src[0] = a; // 设置第一个源张量
    result->src[1] = b; // 设置第二个源张量（可能为 NULL）

    return result; // 返回结果张量
}

