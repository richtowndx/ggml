struct ggml_tensor * ggml_gelu_quick_inplace( // Quick GELU 的原地版本
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量，也用于存储结果
    return ggml_unary_inplace(ctx, a, GGML_UNARY_OP_GELU_QUICK); // 调用通用一元原地操作接口
}

