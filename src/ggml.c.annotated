        float                 beta_slow) {        // YaRN慢速参数 / YaRN slow parameter
    return ggml_rope_impl(                        // 调用内部实现 / call internal implementation
        ctx, a, b, NULL, n_dims, NULL, mode, n_ctx_orig, freq_base, freq_scale,
        ext_factor, attn_factor, beta_fast, beta_slow, true // 原地操作 / inplace
    );                                            // 返回结果 / return result
}                                                 // 结束 ggml_rope_custom_inplace 函数 / end function

// Apparently solving `n_rot = 2pi * x * base^((2 * max_pos_emb) / n_dims)` for x, we get // 求解YaRN修正维度公式 / solving YaRN correction dimension formula
// `corr_dim(n_rot) = n_dims * log(max_pos_emb / (n_rot * 2pi)) / (2 * log(base))` // 修正维度计算公式 / correction dimension calculation formula
static float ggml_rope_yarn_corr_dim(int n_dims, int n_ctx_orig, float n_rot, float base) { // YaRN修正维度计算 / YaRN correction dimension calculation
    return n_dims * logf(n_ctx_orig / (n_rot * 2 * (float)M_PI)) / (2 * logf(base)); // 计算修正维度 / compute correction dimension
}                                                 // 结束 ggml_rope_yarn_corr_dim 函数 / end function

void ggml_rope_yarn_corr_dims(                    // 计算YaRN修正维度范围 / compute YaRN correction dimension range
    int n_dims, int n_ctx_orig, float freq_base, float beta_fast, float beta_slow, float dims[2] // 参数列表 / parameter list
) {
    // start and end correction dims                // 起始和结束修正维度 / start and end correction dimensions
    float start = floorf(ggml_rope_yarn_corr_dim(n_dims, n_ctx_orig, beta_fast, freq_base)); // 计算起始修正维度（向下取整）/ compute start correction dim (floor)
    float end   =  ceilf(ggml_rope_yarn_corr_dim(n_dims, n_ctx_orig, beta_slow, freq_base)); // 计算结束修正维度（向上取整）/ compute end correction dim (ceil)
    dims[0] = MAX(0, start);                      // 起始维度不小于0 / start dim not less than 0
    dims[1] = MIN(n_dims - 1, end);               // 结束维度不超过n_dims-1 / end dim not exceeding n_dims-1
}                                                 // 结束 ggml_rope_yarn_corr_dims 函数 / end function

// ggml_rope_back                                 // RoPE反向传播 / RoPE backward pass

struct ggml_tensor * ggml_rope_ext_back(          // 扩展RoPE反向传播 / extended RoPE backward
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        struct ggml_tensor  * c,                  // 频率因子张量 / freq factors tensor
        int                   n_dims,             // RoPE维度数 / RoPE dimensions
        int                   mode,               // RoPE模式 / RoPE mode
        int                   n_ctx_orig,         // 原始上下文长度 / original context length
        float                 freq_base,          // 频率基准 / frequency base
        float                 freq_scale,         // 频率缩放 / frequency scale
        float                 ext_factor,         // 外推因子 / extrapolation factor
        float                 attn_factor,        // 注意力因子 / attention factor
        float                 beta_fast,          // YaRN快速参数 / YaRN fast parameter
        float                 beta_slow) {        // YaRN慢速参数 / YaRN slow parameter
    struct ggml_tensor * result = ggml_rope_ext(  // 先创建前向RoPE张量 / first create forward RoPE tensor
        ctx, a, b, c, n_dims, mode, n_ctx_orig, freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow);
    result->op = GGML_OP_ROPE_BACK;               // 修改操作类型为ROPE_BACK / change op type to ROPE_BACK
    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_rope_ext_back 函数 / end function

struct ggml_tensor * ggml_rope_multi_back(        // 多模态RoPE反向传播 / multimodal RoPE backward
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        struct ggml_tensor  * c,                  // 频率因子张量 / freq factors tensor
        int                   n_dims,             // RoPE维度数 / RoPE dimensions
        int                   sections[4],        // 多模态分段 / multimodal sections
        int                   mode,               // RoPE模式 / RoPE mode
        int                   n_ctx_orig,         // 原始上下文长度 / original context length
        float                 freq_base,          // 频率基准 / frequency base
        float                 freq_scale,         // 频率缩放 / frequency scale
        float                 ext_factor,         // 外推因子 / extrapolation factor
        float                 attn_factor,        // 注意力因子 / attention factor
        float                 beta_fast,          // YaRN快速参数 / YaRN fast parameter
        float                 beta_slow) {        // YaRN慢速参数 / YaRN slow parameter
    struct ggml_tensor * result = ggml_rope_multi( // 先创建前向多模态RoPE / first create forward multi-RoPE
        ctx, a, b, c, n_dims, sections, mode, n_ctx_orig, freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow);
    result->op = GGML_OP_ROPE_BACK;               // 修改操作类型为ROPE_BACK / change op type to ROPE_BACK
    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_rope_multi_back 函数 / end function
// ggml_clamp                                     // 钳位操作（将值限制在范围内）/ clamp operation (limit values to range)

struct ggml_tensor * ggml_clamp(                  // 钳位操作函数 / clamp operation function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        float                 min,                // 最小值 / minimum value
        float                 max) {              // 最大值 / maximum value
    // TODO: when implement backward, fix this:   // 待办：实现反向传播时需修复 / TODO: fix when implementing backward
    struct ggml_tensor * result = ggml_view_tensor(ctx, a); // 创建输入张量的视图 / create view of input tensor

    float params[] = { min, max };                // 参数数组：最小值和最大值 / parameter array: min and max
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_CLAMP;               // 设置操作类型为CLAMP / set op type to CLAMP
    result->src[0] = a;                           // 设置源张量 / set source tensor

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_clamp 函数 / end ggml_clamp function

static int64_t ggml_calc_conv_output_size(int64_t ins, int64_t ks, int s, int p, int d) { // 计算卷积输出尺寸 / compute convolution output size
    return (ins + 2 * p - d * (ks - 1) - 1) / s + 1; // 输出尺寸公式 / output size formula
}                                                 // 结束 ggml_calc_conv_output_size 函数 / end function

// im2col: [N, IC, IH, IW] => [N, OH, OW, IC*KH*KW] // im2col操作：将图像转为列矩阵 / im2col: convert image to column matrix
// a: [OC，IC, KH, KW]                            // a: 卷积核 [输出通道, 输入通道, 核高, 核宽] / a: kernel [OC, IC, KH, KW]
// b: [N, IC, IH, IW]                              // b: 输入数据 [批次, 输入通道, 输入高, 输入宽] / b: input [N, IC, IH, IW]
// result: [N, OH, OW, IC*KH*KW]                   // 结果: [批次, 输出高, 输出宽, 输入通道*核高*核宽] / result: [N, OH, OW, IC*KH*KW]
struct ggml_tensor * ggml_im2col(                 // im2col操作函数（图像转列矩阵）/ im2col function (image to column)
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核张量 / kernel tensor
        struct ggml_tensor  * b,                  // 输入数据张量 / input data tensor
        int                   s0,                 // 宽度方向步长 / stride in width direction
        int                   s1,                 // 高度方向步长 / stride in height direction
        int                   p0,                 // 宽度方向填充 / padding in width direction
        int                   p1,                 // 高度方向填充 / padding in height direction
        int                   d0,                 // 宽度方向膨胀 / dilation in width direction
        int                   d1,                 // 高度方向膨胀 / dilation in height direction
        bool                  is_2D,              // 是否为2D模式 / whether 2D mode
        enum ggml_type        dst_type) {         // 目标数据类型 / destination data type
    if (is_2D) {                                  // 如果是2D卷积 / if 2D convolution
        GGML_ASSERT(a->ne[2] == b->ne[2]);        // 断言：核的输入通道数等于输入的输入通道数 / assert: kernel IC equals input IC
    } else {                                      // 否则是1D卷积 / otherwise 1D convolution
        //GGML_ASSERT(b->ne[1] % a->ne[1] == 0); // 注释掉的断言 / commented out assertion
        GGML_ASSERT(b->ne[1] == a->ne[1]);        // 断言：输入第1维等于核第1维 / assert: input dim1 equals kernel dim1
        GGML_ASSERT(b->ne[3] == 1);               // 断言：1D模式下批次维度为1 / assert: batch dim is 1 for 1D
    }                                             // 结束维度检查 / end dimension check

    const int64_t OH = is_2D ? ggml_calc_conv_output_size(b->ne[1], a->ne[1], s1, p1, d1) : 0; // 计算输出高度（仅2D）/ compute output height (2D only)
    const int64_t OW =         ggml_calc_conv_output_size(b->ne[0], a->ne[0], s0, p0, d0); // 计算输出宽度 / compute output width

    GGML_ASSERT((!is_2D || OH > 0) && "b too small compared to a"); // 断言：输出高度大于0 / assert: output height > 0
    GGML_ASSERT((OW > 0)           && "b too small compared to a"); // 断言：输出宽度大于0 / assert: output width > 0

    const int64_t ne[4] = {                       // 结果张量各维度 / result tensor dimensions
        is_2D ? (a->ne[2] * a->ne[1] * a->ne[0]) : a->ne[1] * a->ne[0], // 第0维：2D时为IC*KH*KW，1D时为IC*K / dim0: IC*KH*KW for 2D, IC*K for 1D
        OW,                                        // 第1维：输出宽度 / dim1: output width
        is_2D ? OH : b->ne[2],                     // 第2维：2D时为OH，1D时为输入第2维 / dim2: OH for 2D, input dim2 for 1D
        is_2D ?      b->ne[3] : 1,                 // 第3维：2D时为批次，1D时为1 / dim3: batch for 2D, 1 for 1D
    };                                             // 结束维度定义 / end dimension definition

    struct ggml_tensor * result = ggml_new_tensor(ctx, dst_type, 4, ne); // 创建新的4维张量 / create new 4D tensor
    int32_t params[] = { s0, s1, p0, p1, d0, d1, (is_2D ? 1 : 0) }; // 参数数组：步长、填充、膨胀、维度标志 / params: strides, padding, dilation, dim flag
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_IM2COL;              // 设置操作类型为IM2COL / set op type to IM2COL
    result->src[0] = a;                           // 设置源张量0为卷积核 / set source 0 to kernel
    result->src[1] = b;                           // 设置源张量1为输入数据 / set source 1 to input

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_im2col 函数 / end ggml_im2col function

struct ggml_tensor * ggml_im2col_back(            // im2col反向传播 / im2col backward
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核张量 / kernel tensor
        struct ggml_tensor  * b,                  // 梯度张量 / gradient tensor
        int64_t             * ne,                 // 输出维度数组 / output dimensions array
        int                   s0,                 // 宽度方向步长 / stride width
        int                   s1,                 // 高度方向步长 / stride height
        int                   p0,                 // 宽度方向填充 / padding width
        int                   p1,                 // 高度方向填充 / padding height
        int                   d0,                 // 宽度方向膨胀 / dilation width
        int                   d1,                 // 高度方向膨胀 / dilation height
        bool                  is_2D) {            // 是否2D模式 / whether 2D mode
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建F32类型的4维结果张量 / create F32 4D result tensor
    int32_t params[] = { s0, s1, p0, p1, d0, d1, (is_2D ? 1 : 0) }; // 参数数组 / parameter array
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_IM2COL_BACK;         // 设置操作类型为IM2COL_BACK / set op type to IM2COL_BACK
    result->src[0] = a;                           // 设置源张量0 / set source 0
    result->src[1] = b;                           // 设置源张量1 / set source 1

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_im2col_back 函数 / end function

// ggml_conv_1d                                   // 1D卷积操作 / 1D convolution operation

struct ggml_tensor * ggml_conv_1d(                // 1D卷积函数 / 1D convolution function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 [OC, IC, K] / kernel [OC, IC, K]
        struct ggml_tensor  * b,                  // 输入数据 [IC, IL, N] / input [IC, IL, N]
        int                   s0,                 // 步长 / stride
        int                   p0,                 // 填充 / padding
        int                   d0) {               // 膨胀 / dilation
    struct ggml_tensor * im2col = ggml_im2col(ctx, a, b, s0, 0, p0, 0, d0, 0, false, GGML_TYPE_F16); // [N, OL, IC * K] // 执行im2col变换 / perform im2col transform

    struct ggml_tensor * result =                 // 卷积结果 = 矩阵乘法 / convolution result = matrix multiplication
        ggml_mul_mat(ctx,                          // 矩阵乘法操作 / matrix multiplication op
                ggml_reshape_2d(ctx, im2col, im2col->ne[0], (im2col->ne[2] * im2col->ne[1])), // [N, OL, IC * K] => [N*OL, IC * K] // 重塑为2D / reshape to 2D
                ggml_reshape_2d(ctx, a, (a->ne[0] * a->ne[1]), a->ne[2]));                    // [OC，IC, K] => [OC, IC * K] // 重塑核为2D / reshape kernel to 2D

    result = ggml_reshape_3d(ctx, result, im2col->ne[1], a->ne[2], im2col->ne[2]); // [N, OC, OL] // 重塑结果为3D / reshape result to 3D

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_1d 函数 / end ggml_conv_1d function

// ggml_conv_1d_ph                                // 1D卷积（半填充模式）/ 1D convolution (half padding mode)

struct ggml_tensor* ggml_conv_1d_ph(              // 1D卷积半填充函数 / 1D convolution half padding function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   s,                  // 步长 / stride
        int                   d) {                // 膨胀 / dilation
    return ggml_conv_1d(ctx, a, b, s, a->ne[0] / 2, d); // 填充为核大小的一半 / padding is half of kernel size
}                                                 // 结束 ggml_conv_1d_ph 函数 / end ggml_conv_1d_ph function

// ggml_conv_1d_dw                                // 1D深度可分离卷积 / 1D depthwise separable convolution

struct ggml_tensor * ggml_conv_1d_dw(             // 1D深度卷积函数 / 1D depthwise convolution function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   s0,                 // 步长 / stride
        int                   p0,                 // 填充 / padding
        int                   d0) {               // 膨胀 / dilation
    struct ggml_tensor * new_b = ggml_reshape_4d(ctx, b, b->ne[0], 1, b->ne[1], b->ne[2]); // 将输入重塑为4D / reshape input to 4D

    struct ggml_tensor * im2col = ggml_im2col(ctx, a, new_b, s0, 0, p0, 0, d0, 0, false, GGML_TYPE_F16); // 执行im2col / perform im2col

    struct ggml_tensor * result = ggml_mul_mat(ctx, im2col, a); // 矩阵乘法得到卷积结果 / matrix multiplication for convolution result

    result = ggml_reshape_3d(ctx, result, result->ne[0], result->ne[2], 1); // 重塑为3D / reshape to 3D

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_1d_dw 函数 / end ggml_conv_1d_dw function

// ggml_conv_1d_dw_ph                             // 1D深度卷积（半填充）/ 1D depthwise convolution (half padding)

struct ggml_tensor * ggml_conv_1d_dw_ph(          // 1D深度卷积半填充函数 / 1D depthwise conv half padding
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   s0,                 // 步长 / stride
        int                   d0) {               // 膨胀 / dilation
    return ggml_conv_1d_dw(ctx, a, b, s0, a->ne[0] / 2, d0); // 填充为核大小一半 / padding is half kernel size
}                                                 // 结束 ggml_conv_1d_dw_ph 函数 / end function

// ggml_conv_transpose_1d                          // 1D转置卷积（反卷积）/ 1D transposed convolution (deconvolution)

static int64_t ggml_calc_conv_transpose_1d_output_size(int64_t ins, int64_t ks, int s, int p, int d) { // 计算1D转置卷积输出尺寸 / compute 1D transposed conv output size
    return (ins - 1) * s - 2 * p + d * (ks - 1) + 1; // 转置卷积输出公式 / transposed conv output formula
}                                                 // 结束计算函数 / end calculation function

GGML_API struct ggml_tensor * ggml_conv_transpose_1d( // 1D转置卷积函数 / 1D transposed convolution function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   s0,                 // 步长 / stride
        int                   p0,                 // 填充 / padding
        int                   d0) {               // 膨胀 / dilation
    GGML_ASSERT(ggml_is_matrix(b));               // 断言：b必须是矩阵 / assert: b must be a matrix
    GGML_ASSERT(a->ne[2] == b->ne[1]);            // 断言：核通道数等于输入通道数 / assert: kernel channels equal input channels
    GGML_ASSERT(a->ne[3] == 1);                   // 断言：核的第3维为1 / assert: kernel dim3 is 1

    GGML_ASSERT(p0 == 0);                         // 断言：填充必须为0 / assert: padding must be 0
    GGML_ASSERT(d0 == 1);                         // 断言：膨胀必须为1 / assert: dilation must be 1

    const int64_t ne[4] = {                       // 输出维度数组 / output dimensions array
        ggml_calc_conv_transpose_1d_output_size(b->ne[0], a->ne[0], s0, 0 /*p0*/, 1 /*d0*/), // 计算输出长度 / compute output length
        a->ne[1], b->ne[2], 1,                    // 输出通道, 批次, 1 / output channels, batch, 1
    };                                             // 结束维度定义 / end dimension definition
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建F32类型4维张量 / create F32 4D tensor

    int32_t params[] = { s0, p0, d0 };            // 参数数组：步长、填充、膨胀 / params: stride, padding, dilation
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_CONV_TRANSPOSE_1D;   // 设置操作类型为CONV_TRANSPOSE_1D / set op to CONV_TRANSPOSE_1D
    result->src[0] = a;                           // 设置源张量0为卷积核 / set source 0 to kernel
    result->src[1] = b;                           // 设置源张量1为输入 / set source 1 to input

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_transpose_1d 函数 / end function

// ggml_conv_2d                                   // 2D卷积操作 / 2D convolution operation

// a: [OC，IC, KH, KW]                            // a: 卷积核 [输出通道, 输入通道, 核高, 核宽] / a: kernel [OC, IC, KH, KW]
// b: [N, IC, IH, IW]                              // b: 输入 [批次, 输入通道, 输入高, 输入宽] / b: input [N, IC, IH, IW]
// result: [N, OC, OH, OW]                         // 结果: [批次, 输出通道, 输出高, 输出宽] / result: [N, OC, OH, OW]
struct ggml_tensor * ggml_conv_2d(                // 2D卷积函数 / 2D convolution function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核张量 / kernel tensor
        struct ggml_tensor  * b,                  // 输入数据张量 / input data tensor
        int                   s0,                 // 宽度步长 / width stride
        int                   s1,                 // 高度步长 / height stride
        int                   p0,                 // 宽度填充 / width padding
        int                   p1,                 // 高度填充 / height padding
        int                   d0,                 // 宽度膨胀 / width dilation
        int                   d1) {               // 高度膨胀 / height dilation
    struct ggml_tensor * im2col = ggml_im2col(ctx, a, b, s0, s1, p0, p1, d0, d1, true, a->type); // [N, OH, OW, IC * KH * KW] // 执行2D im2col / perform 2D im2col

    struct ggml_tensor * result =                 // 卷积结果 / convolution result
        ggml_mul_mat(ctx,                          // 矩阵乘法 / matrix multiplication
                ggml_reshape_2d(ctx, im2col, im2col->ne[0],  im2col->ne[3] * im2col->ne[2] * im2col->ne[1]), // [N, OH, OW, IC * KH * KW] => [N*OH*OW, IC * KH * KW] // 展平空间维度 / flatten spatial dims
                ggml_reshape_2d(ctx, a, (a->ne[0] * a->ne[1] * a->ne[2]),  a->ne[3]));                       // [OC，IC, KH, KW] => [OC, IC * KH * KW] // 展平核 / flatten kernel

    result = ggml_reshape_4d(ctx, result, im2col->ne[1], im2col->ne[2], im2col->ne[3], a->ne[3]); // [OC, N, OH, OW] // 重塑为4D / reshape to 4D
    result = ggml_cont(ctx, ggml_permute(ctx, result, 0, 1, 3, 2)); // [N, OC, OH, OW] // 排列维度使其变为[N, OC, OH, OW] / permute to [N, OC, OH, OW]


    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_2d 函数 / end ggml_conv_2d function

// a: [OC*IC, KD, KH, KW]                         // a: 卷积核 [输出通道*输入通道, 核深, 核高, 核宽] / a: kernel [OC*IC, KD, KH, KW]
// b: [N*IC, ID, IH, IW]                           // b: 输入 [批次*输入通道, 输入深, 输入高, 输入宽] / b: input [N*IC, ID, IH, IW]
// result: [N*OD, OH, OW, IC * KD * KH * KW]       // 结果张量维度 / result tensor dimensions
struct ggml_tensor * ggml_im2col_3d(              // 3D im2col操作函数 / 3D im2col function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核张量 / kernel tensor
        struct ggml_tensor  * b,                  // 输入数据张量 / input data tensor
        int64_t               IC,                 // 输入通道数 / input channels
        int                   s0, // stride width  // 宽度步长 / width stride
        int                   s1, // stride height // 高度步长 / height stride
        int                   s2, // stride depth  // 深度步长 / depth stride
        int                   p0, // padding width // 宽度填充 / width padding
        int                   p1, // padding height// 高度填充 / height padding
        int                   p2, // padding depth // 深度填充 / depth padding
        int                   d0, // dilation width// 宽度膨胀 / width dilation
        int                   d1, // dilation height// 高度膨胀 / height dilation
        int                   d2, // dilation depth// 深度膨胀 / depth dilation
        enum ggml_type        dst_type) {         // 目标数据类型 / destination data type
    const int64_t N = b->ne[3] / IC;              // 批次数 = 输入第3维 / 输入通道数 / batch size = dim3 / IC
    const int64_t ID = b->ne[2];                  // 输入深度 / input depth
    const int64_t IH = b->ne[1];                  // 输入高度 / input height
    const int64_t IW = b->ne[0];                  // 输入宽度 / input width

    const int64_t OC = a->ne[3] / IC;             // 输出通道数 = 核第3维 / 输入通道数 / output channels = dim3 / IC
    UNUSED(OC);                                    // 标记OC未使用（仅用于验证）/ mark OC as unused (for validation only)
    const int64_t KD = a->ne[2];                  // 核深度 / kernel depth
    const int64_t KH = a->ne[1];                  // 核高度 / kernel height
    const int64_t KW = a->ne[0];                  // 核宽度 / kernel width
    const int64_t OD = ggml_calc_conv_output_size(ID, KD, s2, p2, d2); // 计算输出深度 / compute output depth
    const int64_t OH = ggml_calc_conv_output_size(IH, KH, s1, p1, d1); // 计算输出高度 / compute output height
    const int64_t OW = ggml_calc_conv_output_size(IW, KW, s0, p0, d0); // 计算输出宽度 / compute output width

    GGML_ASSERT((OD > 0)  && "b too small compared to a"); // 断言：输出深度大于0 / assert: output depth > 0
    GGML_ASSERT((OH > 0)  && "b too small compared to a"); // 断言：输出高度大于0 / assert: output height > 0
    GGML_ASSERT((OW > 0)  && "b too small compared to a"); // 断言：输出宽度大于0 / assert: output width > 0


    const int64_t ne[4] = {KW*KH*KD*IC, OW, OH, OD*N}; // 结果维度 / result dimensions

    struct ggml_tensor * result = ggml_new_tensor(ctx, dst_type, 4, ne); // 创建结果张量 / create result tensor
    int32_t params[] = { s0, s1, s2, p0, p1, p2, d0, d1, d2, (int32_t)IC}; // 参数数组 / parameter array
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_IM2COL_3D;           // 设置操作类型为IM2COL_3D / set op to IM2COL_3D
    result->src[0] = a;                           // 设置源张量0 / set source 0
    result->src[1] = b;                           // 设置源张量1 / set source 1

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_im2col_3d 函数 / end function

// a: [OC*IC, KD, KH, KW]                         // a: 卷积核 [输出通道*输入通道, 核深, 核高, 核宽] / a: kernel [OC*IC, KD, KH, KW]
// b: [N*IC, ID, IH, IW]                           // b: 输入数据 [批次*输入通道, 输入深, 输入高, 输入宽] / b: input [N*IC, ID, IH, IW]
// result: [N*OC, OD, OH, OW]                      // 结果: [批次*输出通道, 输出深, 输出高, 输出宽] / result: [N*OC, OD, OH, OW]
struct ggml_tensor * ggml_conv_3d(                // 3D卷积函数 / 3D convolution function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核张量 / kernel tensor
        struct ggml_tensor  * b,                  // 输入数据张量 / input data tensor
        int64_t               IC,                 // 输入通道数 / input channels
        int                   s0, // stride width  // 宽度步长 / width stride
        int                   s1, // stride height // 高度步长 / height stride
        int                   s2, // stride depth  // 深度步长 / depth stride
        int                   p0, // padding width // 宽度填充 / width padding
        int                   p1, // padding height// 高度填充 / height padding
        int                   p2, // padding depth // 深度填充 / depth padding
        int                   d0, // dilation width// 宽度膨胀 / width dilation
        int                   d1, // dilation height// 高度膨胀 / height dilation
        int                   d2  // dilation depth // 深度膨胀 / depth dilation
        ) {
    struct ggml_tensor * im2col = ggml_im2col_3d(ctx, a, b, IC, s0, s1, s2, p0, p1, p2, d0, d1, d2, a->type); // [N*OD, OH, OW, IC * KD * KH * KW] // 执行3D im2col / perform 3D im2col

    int64_t OC = a->ne[3] / IC;                   // 计算输出通道数 / compute output channels
    int64_t N = b->ne[3] / IC;                    // 计算批次数 / compute batch size
    struct ggml_tensor * result =                 // 卷积结果 / convolution result
        ggml_mul_mat(ctx,                          // 矩阵乘法 / matrix multiplication
                ggml_reshape_2d(ctx, im2col, im2col->ne[0], im2col->ne[3] * im2col->ne[2] * im2col->ne[1]), // [N*OD, OH, OW, IC * KD * KH * KW] => [N*OD*OH*OW, IC * KD * KH * KW] // 展平 / flatten
                ggml_reshape_2d(ctx, a, (a->ne[0] * a->ne[1] * a->ne[2] * IC), OC));                          // [OC*IC, KD, KH, KW] => [OC, IC * KD * KH * KW] // 展平核 / flatten kernel

    int64_t OD = im2col->ne[3] / N;               // 计算输出深度 / compute output depth
    result = ggml_reshape_4d(ctx, result, im2col->ne[1]*im2col->ne[2], OD, N, OC); // [OC, N*OD*OH*OW] => [OC, N, OD, OH*OW] // 重塑为4D / reshape to 4D
    result = ggml_cont(ctx, ggml_permute(ctx, result, 0, 1, 3, 2)); // [N, OC, OD, OH*OW] // 排列维度 / permute dimensions
    result = ggml_reshape_4d(ctx, result, im2col->ne[1], im2col->ne[2], OD, OC * N); // [N*OC, OD, OH, OW] // 最终重塑 / final reshape

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_3d 函数 / end ggml_conv_3d function

// ggml_conv_2d_sk_p0                             // 2D卷积（步长=核宽，无填充）/ 2D conv (stride=kernel, no padding)

struct ggml_tensor * ggml_conv_2d_sk_p0(          // 2D卷积：步长等于核尺寸，填充为0 / 2D conv: stride equals kernel size, zero padding
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b) {                // 输入数据 / input data
    return ggml_conv_2d(ctx, a, b, a->ne[0], a->ne[1], 0, 0, 1, 1); // 步长=核宽高，无填充，无膨胀 / stride=kernel dims, no pad, no dilation
}                                                 // 结束 ggml_conv_2d_sk_p0 函数 / end function

// ggml_conv_2d_s1_ph                             // 2D卷积（步长1，半填充）/ 2D conv (stride 1, half padding)

struct ggml_tensor * ggml_conv_2d_s1_ph(          // 2D卷积：步长1，半填充 / 2D conv: stride 1, half padding
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b) {                // 输入数据 / input data
    return ggml_conv_2d(ctx, a, b, 1, 1, a->ne[0] / 2, a->ne[1] / 2, 1, 1); // 步长1，填充为核半宽半高 / stride 1, pad half kernel
}                                                 // 结束 ggml_conv_2d_s1_ph 函数 / end function

// ggml_conv_2d_dw                                // 2D深度可分离卷积 / 2D depthwise separable convolution

struct ggml_tensor * ggml_conv_2d_dw(             // 2D深度卷积函数 / 2D depthwise convolution function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   s0,                 // 宽度步长 / width stride
        int                   s1,                 // 高度步长 / height stride
        int                   p0,                 // 宽度填充 / width padding
        int                   p1,                 // 高度填充 / height padding
        int                   d0,                 // 宽度膨胀 / width dilation
        int                   d1) {               // 高度膨胀 / height dilation
    struct ggml_tensor * new_a = ggml_reshape_4d(ctx, a, a->ne[0], a->ne[1], 1, a->ne[2] * a->ne[3]); // 重塑核为4D / reshape kernel to 4D
    struct ggml_tensor * im2col = ggml_im2col(ctx, new_a, // 执行im2col / perform im2col
                                        ggml_reshape_4d(ctx, b, b->ne[0], b->ne[1], 1, b->ne[2] * b->ne[3]), // 重塑输入为4D / reshape input to 4D
                                        s0, s1, p0, p1, d0, d1, true, GGML_TYPE_F16); // [N * IC, OH, OW, KH * KW] // 步长、填充、膨胀参数 / stride, pad, dilation params
    struct ggml_tensor * new_b = ggml_reshape_4d(ctx, im2col, im2col->ne[0], im2col->ne[2] * im2col->ne[1], b->ne[2], b->ne[3]); // [N * IC, OH, OW, KH * KW] => [N, IC, OH * OW, KH * KW] // 重塑im2col结果 / reshape im2col result

    new_a = ggml_reshape_4d(ctx, new_a, (new_a->ne[0] * new_a->ne[1]), new_a->ne[2],  new_a->ne[3], 1);                       // [OC，1, KH, KW] => [1, OC, 1, KH * KW] // 重塑核 / reshape kernel
    struct ggml_tensor * result = ggml_mul_mat(ctx, new_a, new_b); // 矩阵乘法 / matrix multiplication
    result = ggml_reshape_4d(ctx, result, im2col->ne[1], im2col->ne[2], b->ne[2], b->ne[3]); // [N, OC, OH, OW] // 重塑为最终输出形状 / reshape to final output shape

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_2d_dw 函数 / end ggml_conv_2d_dw function

// ggml_conv_2d_dw_direct                         // 2D深度卷积直接实现 / 2D depthwise convolution direct implementation

struct ggml_tensor * ggml_conv_2d_dw_direct(      // 2D深度卷积直接计算函数 / 2D depthwise conv direct function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   stride0,            // 宽度步长 / width stride
        int                   stride1,            // 高度步长 / height stride
        int                   pad0,               // 宽度填充 / width padding
        int                   pad1,               // 高度填充 / height padding
        int                   dilation0,          // 宽度膨胀 / width dilation
        int                   dilation1) {        // 高度膨胀 / height dilation
    GGML_ASSERT(a->ne[2] == 1);                   // 断言：核第2维为1（深度卷积） / assert: kernel dim2 is 1 (depthwise)
    GGML_ASSERT(a->ne[3] == b->ne[2]);            // 断言：核通道数等于输入通道数 / assert: kernel channels == input channels
    int64_t ne[4];                                // 输出维度数组 / output dimensions array
    ne[0] = ggml_calc_conv_output_size(b->ne[0], a->ne[0], stride0, pad0, dilation0); // 计算输出宽度 / compute output width
    ne[1] = ggml_calc_conv_output_size(b->ne[1], a->ne[1], stride1, pad1, dilation1); // 计算输出高度 / compute output height
    ne[2] = b->ne[2];                             // 输出通道数 = 输入通道数 / output channels = input channels
    ne[3] = b->ne[3];                             // 批次数不变 / batch size unchanged

    struct ggml_tensor * result = ggml_new_tensor(ctx, b->type, 4, ne); // 创建与输入同类型的结果张量 / create result tensor with same type as input

    if (ggml_is_contiguous_channels(b)) {         // 如果输入是通道连续格式(CWHN) / if input is channel-contiguous (CWHN)
        // Result will be permuted the same way as input (CWHN order) // 结果将以相同方式排列（CWHN顺序）/ result will be permuted same way as input
        const int64_t type_size = ggml_type_size(result->type); // 获取类型大小 / get type size
        GGML_ASSERT(ggml_blck_size(result->type) == 1); // 断言：块大小为1 / assert: block size is 1
        result->nb[0] = result->ne[2] * type_size; // 设置步长：第0维步长 = 通道数*类型大小 / set stride: dim0 stride = channels * type_size
        result->nb[1] = result->ne[0] * result->nb[0]; // 设置步长：第1维步长 / set stride: dim1 stride
        result->nb[2] = type_size;                 // 设置步长：第2维步长 = 类型大小 / set stride: dim2 stride = type_size
    }                                              // 结束通道连续处理 / end channel contiguous handling

    int32_t params[] = { stride0, stride1, pad0, pad1, dilation0, dilation1 }; // 参数数组 / parameter array
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_CONV_2D_DW;          // 设置操作类型为CONV_2D_DW / set op to CONV_2D_DW
    result->src[0] = a;                           // 设置源张量0 / set source 0
    result->src[1] = b;                           // 设置源张量1 / set source 1
    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_2d_dw_direct 函数 / end function

// ggml_conv_2d_direct                            // 2D卷积直接实现 / 2D convolution direct implementation

struct ggml_tensor * ggml_conv_2d_direct(          // 2D卷积直接计算函数 / 2D conv direct function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,   // convolution kernel [KW, KH, IC, OC] // 卷积核 [核宽, 核高, 输入通道, 输出通道] / kernel [KW, KH, IC, OC]
        struct ggml_tensor  * b,   // input data [W, H, C, N] // 输入数据 [宽, 高, 通道, 批次] / input [W, H, C, N]
        int                   s0,  // stride dimension 0  // 维度0步长 / stride dim 0
        int                   s1,  // stride dimension 1  // 维度1步长 / stride dim 1
        int                   p0,  // padding dimension 0 // 维度0填充 / padding dim 0
        int                   p1,  // padding dimension 1 // 维度1填充 / padding dim 1
        int                   d0,  // dilation dimension 0 // 维度0膨胀 / dilation dim 0
        int                   d1) {// dilation dimension 1 // 维度1膨胀 / dilation dim 1

    GGML_ASSERT(a->ne[2] == b->ne[2]);            // 断言：核输入通道数等于数据通道数 / assert: kernel IC == data channels
    //GGML_ASSERT(a->type == b->type);             // 注释掉的类型断言 / commented out type assertion

    int64_t ne[4];                                // 输出维度数组 / output dimensions array
    ne[0] = ggml_calc_conv_output_size(b->ne[0], a->ne[0], s0, p0, d0); // 计算输出宽度 / compute output width
    ne[1] = ggml_calc_conv_output_size(b->ne[1], a->ne[1], s1, p1, d1); // 计算输出高度 / compute output height
    ne[2] = a->ne[3];                             // 输出通道数 = 核第3维 / output channels = kernel dim3
    ne[3] = b->ne[3];                             // 批次数 = 输入批次数 / batch = input batch

    struct ggml_tensor * result = ggml_new_tensor(ctx, b->type, 4, ne); // 创建结果张量 / create result tensor

    ggml_set_op_params_i32(result, 0, s0);        // 设置参数：宽度步长 / set param: width stride
    ggml_set_op_params_i32(result, 1, s1);        // 设置参数：高度步长 / set param: height stride
    ggml_set_op_params_i32(result, 2, p0);        // 设置参数：宽度填充 / set param: width padding
    ggml_set_op_params_i32(result, 3, p1);        // 设置参数：高度填充 / set param: height padding
    ggml_set_op_params_i32(result, 4, d0);        // 设置参数：宽度膨胀 / set param: width dilation
    ggml_set_op_params_i32(result, 5, d1);        // 设置参数：高度膨胀 / set param: height dilation

    result->op = GGML_OP_CONV_2D;                 // 设置操作类型为CONV_2D / set op to CONV_2D
    result->src[0] = a;                           // 设置源张量0为卷积核 / set source 0 to kernel
    result->src[1] = b;                           // 设置源张量1为输入数据 / set source 1 to input

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_2d_direct 函数 / end function

// ggml_conv_3d_direct                            // 3D卷积直接实现 / 3D convolution direct implementation

struct ggml_tensor * ggml_conv_3d_direct(          // 3D卷积直接计算函数 / 3D conv direct function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   s0,                 // 宽度步长 / width stride
        int                   s1,                 // 高度步长 / height stride
        int                   s2,                 // 深度步长 / depth stride
        int                   p0,                 // 宽度填充 / width padding
        int                   p1,                 // 高度填充 / height padding
        int                   p2,                 // 深度填充 / depth padding
        int                   d0,                 // 宽度膨胀 / width dilation
        int                   d1,                 // 高度膨胀 / height dilation
        int                   d2,                 // 深度膨胀 / depth dilation
        int                   c,                  // 通道数参数 / channels parameter
        int                   n,                  // 批次参数 / batch parameter
        int                   oc) {               // 输出通道参数 / output channels parameter

    GGML_ASSERT(a->ne[3] == (int64_t) c * oc);    // 断言：核第3维等于通道数*输出通道数 / assert: kernel dim3 == channels * OC
    GGML_ASSERT(b->ne[3] == (int64_t) c * n);     // 断言：输入第3维等于通道数*批次数 / assert: input dim3 == channels * batch

    int64_t ne[4];                                // 输出维度数组 / output dimensions array
    ne[0] = ggml_calc_conv_output_size(b->ne[0], a->ne[0], s0, p0, d0); // 计算输出宽度 / compute output width
    ne[1] = ggml_calc_conv_output_size(b->ne[1], a->ne[1], s1, p1, d1); // 计算输出高度 / compute output height
    ne[2] = ggml_calc_conv_output_size(b->ne[2], a->ne[2], s2, p2, d2); // 计算输出深度 / compute output depth
    ne[3] = (int64_t) oc * n;                     // 第3维 = 输出通道 * 批次 / dim3 = output channels * batch

    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建F32类型4维张量 / create F32 4D tensor

    ggml_set_op_params_i32(result, 0,  s0);       // 设置参数：宽度步长 / set param: width stride
    ggml_set_op_params_i32(result, 1,  s1);       // 设置参数：高度步长 / set param: height stride
    ggml_set_op_params_i32(result, 2,  s2);       // 设置参数：深度步长 / set param: depth stride
    ggml_set_op_params_i32(result, 3,  p0);       // 设置参数：宽度填充 / set param: width padding
    ggml_set_op_params_i32(result, 4,  p1);       // 设置参数：高度填充 / set param: height padding
    ggml_set_op_params_i32(result, 5,  p2);       // 设置参数：深度填充 / set param: depth padding
    ggml_set_op_params_i32(result, 6,  d0);       // 设置参数：宽度膨胀 / set param: width dilation
    ggml_set_op_params_i32(result, 7,  d1);       // 设置参数：高度膨胀 / set param: height dilation
    ggml_set_op_params_i32(result, 8,  d2);       // 设置参数：深度膨胀 / set param: depth dilation
    ggml_set_op_params_i32(result, 9,  c);        // 设置参数：通道数 / set param: channels
    ggml_set_op_params_i32(result, 10, n);        // 设置参数：批次数 / set param: batch
    ggml_set_op_params_i32(result, 11, oc);       // 设置参数：输出通道数 / set param: output channels

    result->op = GGML_OP_CONV_3D;                 // 设置操作类型为CONV_3D / set op to CONV_3D
    result->src[0] = a;                           // 设置源张量0为卷积核 / set source 0 to kernel
    result->src[1] = b;                           // 设置源张量1为输入数据 / set source 1 to input

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_3d_direct 函数 / end function

// ggml_conv_transpose_2d_p0                      // 2D转置卷积（无填充）/ 2D transposed convolution (no padding)

static int64_t ggml_calc_conv_transpose_output_size(int64_t ins, int64_t ks, int s, int p) { // 计算转置卷积输出尺寸 / compute transposed conv output size
    return (ins - 1) * s - 2 * p + ks;            // 转置卷积输出公式 / transposed conv output formula
}                                                 // 结束计算函数 / end calculation function

struct ggml_tensor * ggml_conv_transpose_2d_p0(   // 2D转置卷积（零填充）函数 / 2D transposed conv (zero padding) function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 卷积核 / kernel
        struct ggml_tensor  * b,                  // 输入数据 / input data
        int                   stride) {           // 步长 / stride
    GGML_ASSERT(a->ne[3] == b->ne[2]);            // 断言：核输出通道数等于输入通道数 / assert: kernel OC == input channels

    const int64_t ne[4] = {                       // 输出维度数组 / output dimensions array
        ggml_calc_conv_transpose_output_size(b->ne[0], a->ne[0], stride, 0 /*p0*/), // 计算输出宽度 / compute output width
        ggml_calc_conv_transpose_output_size(b->ne[1], a->ne[1], stride, 0 /*p1*/), // 计算输出高度 / compute output height
        a->ne[2], b->ne[3],                       // 输出通道数, 批次数 / output channels, batch
    };                                             // 结束维度定义 / end dimension definition

    struct ggml_tensor* result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建F32类型4维张量 / create F32 4D tensor

    ggml_set_op_params_i32(result, 0, stride);    // 设置参数：步长 / set param: stride

    result->op     = GGML_OP_CONV_TRANSPOSE_2D;   // 设置操作类型为CONV_TRANSPOSE_2D / set op to CONV_TRANSPOSE_2D
    result->src[0] = a;                           // 设置源张量0 / set source 0
    result->src[1] = b;                           // 设置源张量1 / set source 1

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_conv_transpose_2d_p0 函数 / end function

// ggml_pool_*                                    // 池化操作系列 / pooling operations

static int64_t ggml_calc_pool_output_size(int64_t ins, int ks, int s, float p) { // 计算池化输出尺寸 / compute pooling output size
    return (ins + 2 * p - ks) / s + 1;            // 池化输出公式 / pooling output formula
}                                                 // 结束计算函数 / end calculation function

// ggml_pool_1d                                   // 1D池化操作 / 1D pooling operation

struct ggml_tensor * ggml_pool_1d(                // 1D池化函数 / 1D pooling function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        enum ggml_op_pool     op,                 // 池化类型（最大/平均）/ pool type (max/avg)
        int                   k0,                 // 核大小 / kernel size
        int                   s0,                 // 步长 / stride
        int                   p0) {               // 填充 / padding
    const int64_t ne[4] = {                       // 输出维度数组 / output dimensions array
        ggml_calc_pool_output_size(a->ne[0], k0, s0, p0), // 计算池化后宽度 / compute pooled width
        a->ne[1],                                  // 第1维不变 / dim1 unchanged
        a->ne[2],                                  // 第2维不变 / dim2 unchanged
        a->ne[3],                                  // 第3维不变 / dim3 unchanged
    };                                             // 结束维度定义 / end dimension definition
    GGML_ASSERT(ne[0] > 0);                       // 断言：输出宽度大于0 / assert: output width > 0

    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建F32类型4维张量 / create F32 4D tensor

    int32_t params[] = { op, k0, s0, p0 };        // 参数数组：池化类型、核大小、步长、填充 / params: pool type, kernel, stride, padding
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_POOL_1D;             // 设置操作类型为POOL_1D / set op to POOL_1D
    result->src[0] = a;                           // 设置源张量 / set source tensor

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_pool_1d 函数 / end ggml_pool_1d function

// ggml_pool_2d                                   // 2D池化操作 / 2D pooling operation

struct ggml_tensor * ggml_pool_2d(                // 2D池化函数 / 2D pooling function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        enum ggml_op_pool     op,                 // 池化类型 / pool type
        int                   k0,                 // 宽度核大小 / width kernel size
        int                   k1,                 // 高度核大小 / height kernel size
        int                   s0,                 // 宽度步长 / width stride
        int                   s1,                 // 高度步长 / height stride
        float                 p0,                 // 宽度填充 / width padding
        float                 p1) {               // 高度填充 / height padding
    struct ggml_tensor * result;                  // 结果张量指针 / result tensor pointer
    const int64_t ne[4] = {                       // 输出维度数组 / output dimensions array
        ggml_calc_pool_output_size(a->ne[0], k0, s0, p0), // 计算池化后宽度 / compute pooled width
        ggml_calc_pool_output_size(a->ne[1], k1, s1, p1), // 计算池化后高度 / compute pooled height
        a->ne[2],                                  // 第2维不变 / dim2 unchanged
        a->ne[3],                                  // 第3维不变 / dim3 unchanged
    };                                             // 结束维度定义 / end dimension definition
    GGML_ASSERT(ne[0] > 0);                       // 断言：输出宽度大于0 / assert: output width > 0
    GGML_ASSERT(ne[1] > 0);                       // 断言：输出高度大于0 / assert: output height > 0

    result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建F32类型4维张量 / create F32 4D tensor

    int32_t params[] = { op, k0, k1, s0, s1, p0, p1 }; // 参数数组 / parameter array
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_POOL_2D;             // 设置操作类型为POOL_2D / set op to POOL_2D
    result->src[0] = a;                           // 设置源张量 / set source tensor

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_pool_2d 函数 / end ggml_pool_2d function

struct ggml_tensor * ggml_pool_2d_back(           // 2D池化反向传播 / 2D pooling backward
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 梯度张量 / gradient tensor
        struct ggml_tensor  * af,                 // 前向传播的输入张量 / forward pass input tensor
        enum ggml_op_pool     op,                 // 池化类型 / pool type
        int                   k0,                 // 宽度核大小 / width kernel size
        int                   k1,                 // 高度核大小 / height kernel size
        int                   s0,                 // 宽度步长 / width stride
        int                   s1,                 // 高度步长 / height stride
        float                 p0,                 // 宽度填充 / width padding
        float                 p1) {               // 高度填充 / height padding
    struct ggml_tensor * result;                  // 结果张量指针 / result tensor pointer
    result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, af->ne); // 使用前向输入的维度创建张量 / create tensor with forward input dims

    int32_t params[] = { op, k0, k1, s0, s1, p0, p1 }; // 参数数组 / parameter array
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_POOL_2D_BACK;        // 设置操作类型为POOL_2D_BACK / set op to POOL_2D_BACK
    result->src[0] = a;                           // 设置源张量0为梯度 / set source 0 to gradient
    result->src[1] = af;                          // 设置源张量1为前向输入 / set source 1 to forward input

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_pool_2d_back 函数 / end function

// ggml_upscale / ggml_interpolate                // 上采样/插值操作 / upscale/interpolation operations

static struct ggml_tensor * ggml_interpolate_impl( // 插值内部实现函数 / interpolation internal implementation
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        int64_t               ne0,                // 目标第0维 / target dim0
        int64_t               ne1,                // 目标第1维 / target dim1
        int64_t               ne2,                // 目标第2维 / target dim2
        int64_t               ne3,                // 目标第3维 / target dim3
        uint32_t              mode) {             // 插值模式 / interpolation mode
    GGML_ASSERT((mode & 0xFF) < GGML_SCALE_MODE_COUNT); // 断言：模式有效 / assert: mode is valid
    // TODO: implement antialias for modes other than bilinear // 待办：为非双线性模式实现抗锯齿 / TODO: antialias for non-bilinear modes
    GGML_ASSERT(!(mode & GGML_SCALE_FLAG_ANTIALIAS) || (mode & 0xFF) == GGML_SCALE_MODE_BILINEAR); // 断言：抗锯齿仅支持双线性 / assert: antialias only for bilinear
    GGML_ASSERT(a->type == GGML_TYPE_F32);        // 断言：输入必须是F32 / assert: input must be F32

    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, a->type, ne0, ne1, ne2, ne3); // 创建4维目标张量 / create 4D target tensor

    ggml_set_op_params_i32(result, 0, (int32_t)mode); // 设置插值模式参数 / set interpolation mode param

    result->op     = GGML_OP_UPSCALE;             // 设置操作类型为UPSCALE / set op to UPSCALE
    result->src[0] = a;                           // 设置源张量 / set source tensor

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_interpolate_impl 函数 / end function
// 文件: ggml.c 第5000-6000行 中文注释版本
// 本部分涵盖: 上采样(upscale)、填充(pad)、滚动(roll)、时间步嵌入(timestep_embedding)、
// 三角矩阵(tri)、填充(fill)、排序(argsort)、Top-K、范围生成(arange)、
// Flash Attention、SSM卷积与扫描、窗口分割(partition/unpartition)、
// 相对位置编码、RWKV WKV、门控线性注意力、一元操作、自定义映射操作、损失函数等
																													// 空行
																			// 空行
// ggml_upscale - 张量上采样操作
// 通过指定缩放因子对输入张量进行上采样
struct ggml_tensor * ggml_upscale(                          // 定义上采样函数，返回新张量指针
        struct ggml_context * ctx,                          // 上下文指针，用于内存分配
        struct ggml_tensor  * a,                            // 输入张量
        int                   scale_factor,                 // 缩放因子，必须大于1
        enum ggml_scale_mode  mode) {                       // 缩放模式（最近邻、双线性等）
    GGML_ASSERT(scale_factor > 1);                          // 断言：缩放因子必须大于1
    return ggml_interpolate_impl(ctx, a, a->ne[0] * scale_factor, a->ne[1] * scale_factor, a->ne[2], a->ne[3], mode);  // 调用插值实现函数，各维度乘以缩放因子
}                                                           // 函数结束
																			// 空行
// ggml_upscale_ext - 扩展上采样操作
// 允许显式指定输出张量各维度大小
struct ggml_tensor * ggml_upscale_ext(                      // 定义扩展上采样函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   ne0,                          // 输出维度0（宽度）
        int                   ne1,                          // 输出维度1（高度）
        int                   ne2,                          // 输出维度2（通道数）
        int                   ne3,                          // 输出维度3（批次数）
        enum ggml_scale_mode  mode) {                       // 缩放模式
    return ggml_interpolate_impl(ctx, a, ne0, ne1, ne2, ne3, mode);  // 直接调用插值实现函数
}                                                           // 函数结束
																			// 空行
// ggml_interpolate - 插值操作
// 通用的张量插值函数，支持多种插值模式
struct ggml_tensor * ggml_interpolate(                      // 定义插值函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int64_t               ne0,                          // 目标维度0
        int64_t               ne1,                          // 目标维度1
        int64_t               ne2,                          // 目标维度2
        int64_t               ne3,                          // 目标维度3
        uint32_t              mode) {                       // 插值模式（无符号整数表示）
    return ggml_interpolate_impl(ctx, a, ne0, ne1, ne2, ne3, mode);  // 调用插值实现函数
}                                                           // 函数结束
																			// 空行
// ggml_pad - 张量填充操作
// 在张量各维度两侧添加零填充
																			// 空行
struct ggml_tensor * ggml_pad(                              // 定义填充函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   p0,                           // 维度0的填充大小
        int                   p1,                           // 维度1的填充大小
        int                   p2,                           // 维度2的填充大小
        int                   p3) {                         // 维度3的填充大小
    return ggml_pad_ext(ctx, a, 0, p0, 0, p1, 0, p2, 0, p3);  // 调用扩展填充函数，左侧填充为0
}                                                           // 函数结束
																			// 空行
// ggml_pad_circular - 循环填充操作
// 使用循环方式在张量各维度两侧添加填充
																			// 空行
struct ggml_tensor * ggml_pad_circular(                     // 定义循环填充函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   p0,                           // 维度0的循环填充大小
        int                   p1,                           // 维度1的循环填充大小
        int                   p2,                           // 维度2的循环填充大小
        int                   p3) {                         // 维度3的循环填充大小
    return ggml_pad_ext_circular(ctx, a, 0, p0, 0, p1, 0, p2, 0, p3);  // 调用循环扩展填充函数
}                                                           // 函数结束
																			// 空行
// ggml_pad_ext - 扩展填充操作
// 允许分别指定每个维度的左侧和右侧填充大小
struct ggml_tensor * ggml_pad_ext(                          // 定义扩展填充函数
            struct ggml_context * ctx,                      // 上下文指针
            struct ggml_tensor  * a,                        // 输入张量
            int                  lp0,                       // 维度0左侧填充
            int                  rp0,                       // 维度0右侧填充
            int                  lp1,                       // 维度1左侧填充
            int                  rp1,                       // 维度1右侧填充
            int                  lp2,                       // 维度2左侧填充
            int                  rp2,                       // 维度2右侧填充
            int                  lp3,                       // 维度3左侧填充
            int                  rp3                        // 维度3右侧填充
            ) {                                             // 参数列表结束
    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, a->type,  // 创建新的4D张量，类型与输入相同
            a->ne[0] + lp0 + rp0,                           // 维度0 = 原始大小 + 左右填充
            a->ne[1] + lp1 + rp1,                           // 维度1 = 原始大小 + 左右填充
            a->ne[2] + lp2 + rp2,                           // 维度2 = 原始大小 + 左右填充
            a->ne[3] + lp3 + rp3);                          // 维度3 = 原始大小 + 左右填充
																			// 空行
    ggml_set_op_params_i32(result, 0, lp0);                 // 存储维度0左侧填充参数
    ggml_set_op_params_i32(result, 1, rp0);                 // 存储维度0右侧填充参数
    ggml_set_op_params_i32(result, 2, lp1);                 // 存储维度1左侧填充参数
    ggml_set_op_params_i32(result, 3, rp1);                 // 存储维度1右侧填充参数
    ggml_set_op_params_i32(result, 4, lp2);                 // 存储维度2左侧填充参数
    ggml_set_op_params_i32(result, 5, rp2);                 // 存储维度2右侧填充参数
    ggml_set_op_params_i32(result, 6, lp3);                 // 存储维度3左侧填充参数
    ggml_set_op_params_i32(result, 7, rp3);                 // 存储维度3右侧填充参数
    ggml_set_op_params_i32(result, 8, 0); // not circular by default  // 默认非循环填充标志设为0
																			// 空行
																			// 空行
    result->op     = GGML_OP_PAD;                           // 设置操作类型为PAD
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_pad_ext_circular - 扩展循环填充操作
// 与扩展填充类似，但使用循环填充方式
																			// 空行
struct ggml_tensor * ggml_pad_ext_circular(                 // 定义扩展循环填充函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                  lp0,                           // 维度0左侧循环填充
        int                  rp0,                           // 维度0右侧循环填充
        int                  lp1,                           // 维度1左侧循环填充
        int                  rp1,                           // 维度1右侧循环填充
        int                  lp2,                           // 维度2左侧循环填充
        int                  rp2,                           // 维度2右侧循环填充
        int                  lp3,                           // 维度3左侧循环填充
        int                  rp3                            // 维度3右侧循环填充
        ) {                                                 // 参数列表结束
    struct ggml_tensor * result = ggml_pad_ext(ctx, a, lp0, rp0, lp1, rp1, lp2, rp2, lp3, rp3);  // 先创建普通填充张量
    ggml_set_op_params_i32(result, 8, 1); // circular       // 将循环填充标志设为1
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_pad_reflect_1d - 一维反射填充操作
// 使用镜像反射方式在一维方向上进行填充
																			// 空行
struct ggml_tensor * ggml_pad_reflect_1d(                   // 定义一维反射填充函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   p0,                           // 维度0左侧反射填充大小
        int                   p1) {                         // 维度0右侧反射填充大小
    GGML_ASSERT(p0 >= 0);                                   // 断言：左侧填充大小非负
    GGML_ASSERT(p1 >= 0);                                   // 断言：右侧填充大小非负
																			// 空行
    GGML_ASSERT(p0 < a->ne[0]); // padding length on each size must be less than the  // 断言：左侧填充小于维度0大小
    GGML_ASSERT(p1 < a->ne[0]); // existing length of the dimension being padded      // 断言：右侧填充小于维度0大小
																			// 空行
    GGML_ASSERT(ggml_is_contiguous(a));                     // 断言：输入张量必须连续
    GGML_ASSERT(a->type == GGML_TYPE_F32);                  // 断言：输入张量必须为F32类型
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, a->type,  // 创建新的4D张量
            a->ne[0] + p0 + p1,                             // 维度0 = 原始大小 + 左右填充
            a->ne[1],                                       // 维度1保持不变
            a->ne[2],                                       // 维度2保持不变
            a->ne[3]);                                      // 维度3保持不变
																			// 空行
    int32_t params[] = { p0, p1 };                          // 构建参数数组：左右填充大小
    ggml_set_op_params(result, params, sizeof(params));     // 设置操作参数
																			// 空行
    result->op     = GGML_OP_PAD_REFLECT_1D;                // 设置操作类型为一维反射填充
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_roll - 张量滚动操作
// 将张量元素沿指定维度进行循环移位
																			// 空行
struct ggml_tensor * ggml_roll(                             // 定义滚动函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   shift0,                       // 维度0的移位量
        int                   shift1,                       // 维度1的移位量
        int                   shift2,                       // 维度2的移位量
        int                   shift3) {                     // 维度3的移位量
    GGML_ASSERT(a->nb[0] == ggml_type_size(a->type));       // 断言：最内层步长等于类型大小（即连续）
    GGML_ASSERT(abs(shift0) < a->ne[0]);                    // 断言：维度0移位量小于维度0大小
    GGML_ASSERT(abs(shift1) < a->ne[1]);                    // 断言：维度1移位量小于维度1大小
    GGML_ASSERT(abs(shift2) < a->ne[2]);                    // 断言：维度2移位量小于维度2大小
    GGML_ASSERT(abs(shift3) < a->ne[3]);                    // 断言：维度3移位量小于维度3大小
																			// 空行
    struct ggml_tensor * result = ggml_dup_tensor(ctx, a);  // 复制输入张量的形状和类型
																			// 空行
    ggml_set_op_params_i32(result, 0, shift0);              // 存储维度0移位量
    ggml_set_op_params_i32(result, 1, shift1);              // 存储维度1移位量
    ggml_set_op_params_i32(result, 2, shift2);              // 存储维度2移位量
    ggml_set_op_params_i32(result, 3, shift3);              // 存储维度3移位量
																			// 空行
    result->op     = GGML_OP_ROLL;                          // 设置操作类型为ROLL
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_timestep_embedding - 时间步嵌入操作
// 将时间步转换为正弦/余弦位置嵌入，用于扩散模型等
																			// 空行
struct ggml_tensor * ggml_timestep_embedding(               // 定义时间步嵌入函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * timesteps,                    // 时间步输入张量
        int                   dim,                          // 嵌入维度
        int                   max_period) {                 // 最大周期参数
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_2d(ctx, GGML_TYPE_F32, dim, timesteps->ne[0]);  // 创建2D结果张量：[嵌入维度, 时间步数量]
																			// 空行
    ggml_set_op_params_i32(result, 0, dim);                 // 存储嵌入维度参数
    ggml_set_op_params_i32(result, 1, max_period);          // 存储最大周期参数
																			// 空行
    result->op     = GGML_OP_TIMESTEP_EMBEDDING;            // 设置操作类型为时间步嵌入
    result->src[0] = timesteps;                             // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_tri - 三角矩阵操作
// 生成上三角或下三角矩阵
																			// 空行
struct ggml_tensor * ggml_tri(                              // 定义三角矩阵函数
    struct ggml_context * ctx,                              // 上下文指针
    struct ggml_tensor  * a,                                // 输入张量
    enum ggml_tri_type    type) {                           // 三角类型（上三角或下三角）
    GGML_ASSERT(a->type == GGML_TYPE_F32);                  // 断言：输入必须为F32类型
																			// 空行
    GGML_ASSERT(ggml_is_contiguous(a));                     // 断言：输入张量必须连续
    GGML_ASSERT(a->ne[0] == a->ne[1]);                      // 断言：输入必须是方阵（维度0等于维度1）
																			// 空行
    struct ggml_tensor * result = ggml_dup_tensor(ctx, a);  // 复制输入张量的形状和类型
																			// 空行（原文无此空行，为代码风格）
    ggml_set_op_params_i32(result, 0, type);                // 存储三角类型参数
																			// 空行
    result->op = GGML_OP_TRI;                               // 设置操作类型为TRI
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_fill - 张量填充操作
// 用指定常数值填充整个张量
																			// 空行
static struct ggml_tensor * ggml_fill_impl(                 // 定义填充实现函数（静态内部函数）
    struct ggml_context * ctx,                              // 上下文指针
    struct ggml_tensor  * a,                                // 输入张量（决定输出形状）
    float                 c,                                // 填充常数值
    bool                  inplace) {                        // 是否原地操作标志
    GGML_ASSERT(a->type == GGML_TYPE_F32);                  // 断言：输入必须为F32类型
    GGML_ASSERT(ggml_is_contiguous(a));                     // 断言：输入张量必须连续
																			// 空行
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a);  // 原地则创建视图，否则复制张量
																			// 空行
    ggml_set_op_params_f32(result, 0, c);                   // 存储填充常数值参数
																			// 空行
    result->op = GGML_OP_FILL;                              // 设置操作类型为FILL
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_fill - 非原地填充
struct ggml_tensor * ggml_fill(                             // 定义非原地填充函数
    struct ggml_context * ctx,                              // 上下文指针
    struct ggml_tensor  * a,                                // 输入张量
    float                 c) {                              // 填充常数值
    return ggml_fill_impl(ctx, a, c, false);                // 调用实现函数，inplace=false
}                                                           // 函数结束
																			// 空行
// ggml_fill_inplace - 原地填充
struct ggml_tensor * ggml_fill_inplace(                     // 定义原地填充函数
    struct ggml_context * ctx,                              // 上下文指针
    struct ggml_tensor  * a,                                // 输入张量
    float                 c) {                              // 填充常数值
    return ggml_fill_impl(ctx, a, c, true);                 // 调用实现函数，inplace=true
}                                                           // 函数结束
																			// 空行
// ggml_argsort - 参数排序操作
// 返回排序后的索引张量
																			// 空行
struct ggml_tensor * ggml_argsort(                          // 定义参数排序函数
        struct ggml_context  * ctx,                         // 上下文指针
        struct ggml_tensor   * a,                           // 输入张量
        enum ggml_sort_order   order) {                     // 排序顺序（升序或降序）
    GGML_ASSERT(a->ne[0] <= INT32_MAX);                     // 断言：维度0大小不超过INT32最大值
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_I32, GGML_MAX_DIMS, a->ne);  // 创建与输入同形状的I32类型张量
																			// 空行
    ggml_set_op_params_i32(result, 0, (int32_t) order);    // 存储排序顺序参数
																			// 空行
    result->op     = GGML_OP_ARGSORT;                       // 设置操作类型为ARGSORT
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_argsort_top_k - Top-K参数排序操作
// 返回降序排列前k个最大元素的索引
																			// 空行
struct ggml_tensor * ggml_argsort_top_k(                    // 定义Top-K参数排序函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   k) {                          // 返回的top-k数量
    GGML_ASSERT(a->ne[0] >= k);                             // 断言：维度0大小不小于k
																			// 空行
    struct ggml_tensor * result = ggml_argsort(ctx, a, GGML_SORT_ORDER_DESC);  // 先按降序排序获取全部索引
																			// 空行
    result = ggml_view_4d(ctx, result,                      // 创建4D视图，截取前k个元素
                k, result->ne[1], result->ne[2], result->ne[3],  // 视图维度：k x 原维度1 x 原维度2 x 原维度3
                   result->nb[1], result->nb[2], result->nb[3],  // 视图步长保持不变
                0);                                         // 偏移量为0
																			// 空行
    return result;                                          // 返回截取后的结果张量
}                                                           // 函数结束
																			// 空行
// ggml_top_k - Top-K操作
// 直接返回前k个最大元素的索引
																			// 空行
struct ggml_tensor * ggml_top_k(                            // 定义Top-K函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   k) {                          // 返回的top-k数量
    GGML_ASSERT(a->ne[0] >= k);                             // 断言：维度0大小不小于k
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, GGML_TYPE_I32, k, a->ne[1], a->ne[2], a->ne[3]);  // 创建k x ne1 x ne2 x ne3的I32张量
																			// 空行
    result->op     = GGML_OP_TOP_K;                         // 设置操作类型为TOP_K
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_arange - 等差数列生成操作
// 生成从start到stop，步长为step的等差数列
																			// 空行
struct ggml_tensor * ggml_arange(                           // 定义等差数列生成函数
        struct ggml_context * ctx,                          // 上下文指针
        float                 start,                        // 起始值
        float                 stop,                         // 终止值（不包含）
        float                 step) {                       // 步长
    GGML_ASSERT(stop > start);                              // 断言：终止值必须大于起始值
																			// 空行
    const int64_t steps = (int64_t) ceilf((stop - start) / step);  // 计算总步数，向上取整
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, GGML_TYPE_F32, steps);  // 创建1D F32张量
																			// 空行
    ggml_set_op_params_f32(result, 0, start);               // 存储起始值参数
    ggml_set_op_params_f32(result, 1, stop);                // 存储终止值参数
    ggml_set_op_params_f32(result, 2, step);                // 存储步长参数
																			// 空行
    result->op = GGML_OP_ARANGE;                            // 设置操作类型为ARANGE
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_flash_attn_ext - 扩展Flash Attention操作
// 高效的注意力机制实现，支持mask和偏置
																			// 空行
struct ggml_tensor * ggml_flash_attn_ext(                   // 定义扩展Flash Attention函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * q,                            // 查询张量Q
        struct ggml_tensor  * k,                            // 键张量K
        struct ggml_tensor  * v,                            // 值张量V
        struct ggml_tensor  * mask,                         // 注意力掩码（可为NULL）
        float                 scale,                        // 缩放因子
        float                 max_bias,                     // 最大偏置（用于ALiBi等）
        float                 logit_softcap) {              // logit软上限（用于Gemini等模型）
    GGML_ASSERT(ggml_can_mul_mat(k, q));                    // 断言：K和Q可以进行矩阵乘法
    // TODO: check if vT can be multiplied by (k*qT)       // 待办：检查V转置是否能与K*Q^T相乘
																			// 空行
    GGML_ASSERT(q->ne[3] == k->ne[3]);                      // 断言：Q和K的维度3（头数）必须相同
    GGML_ASSERT(q->ne[3] == v->ne[3]);                      // 断言：Q和V的维度3（头数）必须相同
																			// 空行
    if (mask) {                                             // 如果提供了掩码
        GGML_ASSERT(mask->type == GGML_TYPE_F16);           // 断言：掩码类型必须为F16
        GGML_ASSERT(ggml_is_contiguous(mask));              // 断言：掩码必须连续
        //GGML_ASSERT(ggml_can_repeat_rows(mask, qk));      // 已注释：检查掩码是否能重复行
																			// 空行
        GGML_ASSERT(q->ne[2] % mask->ne[2] == 0);          // 断言：Q的序列长度能被掩码序列长度整除
        GGML_ASSERT(q->ne[3] % mask->ne[3] == 0);          // 断言：Q的批次维度能被掩码批次维度整除
    }                                                       // if结束
																			// 空行
    if (max_bias > 0.0f) {                                  // 如果最大偏置大于0（使用ALiBi）
        GGML_ASSERT(mask);                                  // 断言：使用偏置时必须提供掩码
    }                                                       // if结束
																			// 空行
    // permute(0, 2, 1, 3)                                  // 对输出维度进行排列
    int64_t ne[4] = { v->ne[0], q->ne[2], q->ne[1], q->ne[3] };  // 输出形状：[V维度0, Q序列长度, Q头维度, 批次数]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);  // 创建4D F32结果张量
																			// 空行
    float params[] = { scale, max_bias, logit_softcap };    // 构建参数数组
    ggml_set_op_params(result, params, sizeof(params));     // 设置操作参数
																			// 空行
    result->op     = GGML_OP_FLASH_ATTN_EXT;                // 设置操作类型为扩展Flash Attention
    result->src[0] = q;                                     // 设置源张量Q
    result->src[1] = k;                                     // 设置源张量K
    result->src[2] = v;                                     // 设置源张量V
    result->src[3] = mask;                                  // 设置源张量mask
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_flash_attn_ext_set_prec - 设置Flash Attention精度
void ggml_flash_attn_ext_set_prec(                          // 定义设置精度函数
        struct ggml_tensor * a,                              // Flash Attention结果张量
        enum ggml_prec       prec) {                        // 精度枚举值
    GGML_ASSERT(a->op == GGML_OP_FLASH_ATTN_EXT);          // 断言：操作类型必须是FLASH_ATTN_EXT
																			// 空行
    const int32_t prec_i32 = (int32_t) prec;                // 将精度枚举转换为int32
																			// 空行
    ggml_set_op_params_i32(a, 3, prec_i32); // scale is on first pos, max_bias on second  // 存储精度到参数位置3
}                                                           // 函数结束
																			// 空行
// ggml_flash_attn_ext_get_prec - 获取Flash Attention精度
enum ggml_prec ggml_flash_attn_ext_get_prec(                // 定义获取精度函数
        const struct ggml_tensor * a) {                     // Flash Attention结果张量
    GGML_ASSERT(a->op == GGML_OP_FLASH_ATTN_EXT);          // 断言：操作类型必须是FLASH_ATTN_EXT
																			// 空行
    const int32_t prec_i32 = ggml_get_op_params_i32(a, 3); // 从参数位置3获取精度值
																			// 空行
    return (enum ggml_prec) prec_i32;                       // 转换为精度枚举并返回
}                                                           // 函数结束
																			// 空行
// ggml_flash_attn_ext_add_sinks - 添加注意力汇聚点
// 用于支持流式注意力中的sink tokens
void ggml_flash_attn_ext_add_sinks(                         // 定义添加汇聚点函数
        struct ggml_tensor * a,                              // Flash Attention结果张量
        struct ggml_tensor * sinks) {                       // 汇聚点张量
    if (!sinks) {                                           // 如果汇聚点为NULL
        a->src[4] = NULL;                                   // 将第5个源张量设为NULL
        return;                                             // 直接返回
    }                                                       // if结束
																			// 空行
    GGML_ASSERT(a->op == GGML_OP_FLASH_ATTN_EXT);          // 断言：操作类型必须是FLASH_ATTN_EXT
    GGML_ASSERT(a->src[4] == NULL);                         // 断言：第5个源张量尚未设置
    GGML_ASSERT(a->src[0]->ne[2] == sinks->ne[0]);         // 断言：Q序列长度等于汇聚点维度0
    GGML_ASSERT(sinks->type == GGML_TYPE_F32);              // 断言：汇聚点必须为F32类型
																			// 空行
    a->src[4] = sinks;                                      // 设置汇聚点张量
}                                                           // 函数结束
																			// 空行
// ggml_flash_attn_back - Flash Attention反向传播（已弃用）
																			// 空行
struct ggml_tensor * ggml_flash_attn_back(                  // 定义Flash Attention反向传播函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * q,                            // 查询张量Q
        struct ggml_tensor  * k,                            // 键张量K
        struct ggml_tensor  * v,                            // 值张量V
        struct ggml_tensor  * d,                            // 梯度张量D
        bool                  masked) {                     // 是否使用掩码
    GGML_ABORT("TODO: adapt to ggml_flash_attn_ext() changes");  // 此函数已弃用，调用将中止
																			// 空行
    GGML_ASSERT(ggml_can_mul_mat(k, q));                    // 断言：K和Q可以进行矩阵乘法（永远不会执行）
    // TODO: check if vT can be multiplied by (k*qT)       // 待办：检查V转置是否能与K*Q^T相乘
																			// 空行
    // d shape [D,N,ne2,ne3]                                // d的形状：[D, N, ne2, ne3]
    // q shape [D,N,ne2,ne3]                                // q的形状：[D, N, ne2, ne3]
    // k shape [D,M,kvne2,ne3]                              // k的形状：[D, M, kvne2, ne3]
    // v shape [M,D,kvne2,ne3]                              // v的形状：[M, D, kvne2, ne3]
																			// 空行
    const int64_t     D = q->ne[0];                         // 头维度D
    const int64_t     N = q->ne[1];                         // 查询序列长度N
    const int64_t     M = k->ne[1];                         // 键值序列长度M
    const int64_t   ne2 = q->ne[2];                         // 头数ne2
    const int64_t   ne3 = q->ne[3];                         // 批次数ne3
    const int64_t kvne2 = k->ne[2];                         // KV头数（可能因GQA而不同）
																			// 空行
    GGML_ASSERT(k->ne[0] == D);                             // 断言：K的头维度必须为D
    GGML_ASSERT(v->ne[0] == M);                             // 断言：V的维度0必须为M
    GGML_ASSERT(v->ne[1] == D);                             // 断言：V的维度1必须为D
    GGML_ASSERT(d->ne[0] == D);                             // 断言：D的维度0必须为D
    GGML_ASSERT(d->ne[1] == N);                             // 断言：D的维度1必须为N
    GGML_ASSERT(k->ne[2] == kvne2);                         // 断言：K的维度2必须为kvne2
    GGML_ASSERT(k->ne[3] == ne3);                           // 断言：K的维度3必须为ne3
    GGML_ASSERT(v->ne[2] == kvne2);                         // 断言：V的维度2必须为kvne2
    GGML_ASSERT(v->ne[3] == ne3);                           // 断言：V的维度3必须为ne3
    GGML_ASSERT(d->ne[2] == ne2);                           // 断言：D的维度2必须为ne2
    GGML_ASSERT(d->ne[3] == ne3);                           // 断言：D的维度3必须为ne3
																			// 空行
    GGML_ASSERT(ne2 % kvne2 == 0);                          // 断言：头数能被KV头数整除（GQA条件）
																			// 空行
    // store gradients of q, k and v as continuous tensors concatenated in result.  // 将Q、K、V的梯度作为连续张量连接在结果中
    // note: v and gradv are actually transposed, i.e. v->ne[0] != D.  // 注意：V和gradV实际上是转置的
    const int64_t elem_q = ggml_nelements(q);               // Q的元素总数
    const int64_t elem_k = ggml_nelements(k);               // K的元素总数
    const int64_t elem_v = ggml_nelements(v);               // V的元素总数
																			// 空行
    enum ggml_type result_type = GGML_TYPE_F32;             // 结果类型为F32
    GGML_ASSERT(ggml_blck_size(result_type) == 1);          // 断言：F32的块大小为1
    const size_t tsize = ggml_type_size(result_type);       // 获取类型大小（字节）
																			// 空行
    const size_t offs_q = 0;                                // Q梯度在结果中的偏移量（起始位置）
    const size_t offs_k = offs_q + GGML_PAD(elem_q * tsize, GGML_MEM_ALIGN);  // K梯度的偏移量（Q之后，对齐）
    const size_t offs_v = offs_k + GGML_PAD(elem_k * tsize, GGML_MEM_ALIGN);  // V梯度的偏移量（K之后，对齐）
    const size_t end    = offs_v + GGML_PAD(elem_v * tsize, GGML_MEM_ALIGN);  // 总大小的末尾
																			// 空行
    const size_t nelements = (end + tsize - 1)/tsize;       // 计算总元素数量
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, GGML_TYPE_F32, nelements);  // 创建1D结果张量
																			// 空行
    int32_t masked_i = masked ? 1 : 0;                      // 将布尔掩码转换为整数
    ggml_set_op_params(result, &masked_i, sizeof(masked_i));  // 存储掩码参数
																			// 空行
    result->op     = GGML_OP_FLASH_ATTN_BACK;               // 设置操作类型为FLASH_ATTN_BACK
    result->src[0] = q;                                     // 设置源张量Q
    result->src[1] = k;                                     // 设置源张量K
    result->src[2] = v;                                     // 设置源张量V
    result->src[3] = d;                                     // 设置源张量D（梯度）
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_ssm_conv - SSM卷积操作
// 状态空间模型（Mamba）中的1D卷积
																			// 空行
struct ggml_tensor * ggml_ssm_conv(                         // 定义SSM卷积函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * sx,                           // 输入序列张量（含填充）
        struct ggml_tensor  * c) {                          // 卷积权重张量
    GGML_ASSERT(ggml_is_3d(sx));                            // 断言：输入必须是3D张量
    GGML_ASSERT(ggml_is_matrix(c));                         // 断言：卷积核必须是矩阵（2D）
																			// 空行
    const int64_t d_conv  = c->ne[0];                       // 卷积核大小
    const int64_t d_inner = c->ne[1];                       // 内部维度（隐藏状态大小）
    const int64_t n_t     = sx->ne[0] - d_conv + 1; // tokens per sequence  // 每序列的token数
    const int64_t n_s     = sx->ne[2];                      // 序列数量
																			// 空行
    // TODO: maybe support other strides than 1?             // 待办：可能支持非1的步长
    GGML_ASSERT(sx->ne[0] == d_conv - 1 + n_t);            // 断言：输入维度0 = 卷积核大小-1 + token数
    GGML_ASSERT(sx->ne[1] == d_inner);                      // 断言：输入维度1必须等于内部维度
    GGML_ASSERT(n_t >= 0);                                  // 断言：token数非负
																			// 空行
    struct ggml_tensor * result = ggml_new_tensor_3d(ctx, GGML_TYPE_F32, d_inner, n_t, n_s);  // 创建3D结果张量
																			// 空行
    result->op     = GGML_OP_SSM_CONV;                      // 设置操作类型为SSM_CONV
    result->src[0] = sx;                                    // 设置输入序列张量
    result->src[1] = c;                                     // 设置卷积权重张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_ssm_scan - SSM扫描操作
// 状态空间模型的核心递归扫描操作
																			// 空行
struct ggml_tensor * ggml_ssm_scan(                         // 定义SSM扫描函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * s,                            // 状态张量
        struct ggml_tensor  * x,                            // 输入张量
        struct ggml_tensor  * dt,                           // 时间步长张量
        struct ggml_tensor  * A,                            // 状态转移矩阵A
        struct ggml_tensor  * B,                            // 输入矩阵B
        struct ggml_tensor  * C,                            // 输出矩阵C
        struct ggml_tensor  * ids) {                        // 序列ID张量（用于变长序列）
    GGML_ASSERT(ggml_is_contiguous(s));                     // 断言：状态张量必须连续
    GGML_ASSERT(ggml_is_contiguous(dt));                    // 断言：时间步长张量必须连续
    GGML_ASSERT(ggml_is_contiguous(A));                     // 断言：矩阵A必须连续
    GGML_ASSERT(x->nb[0] == ggml_type_size(x->type));       // 断言：x的最内层步长等于类型大小
    GGML_ASSERT(B->nb[0] == ggml_type_size(B->type));       // 断言：B的最内层步长等于类型大小
    GGML_ASSERT(C->nb[0] == ggml_type_size(C->type));       // 断言：C的最内层步长等于类型大小
    GGML_ASSERT(x->nb[1] == x->ne[0]*x->nb[0]);            // 断言：x在维度1上连续
    GGML_ASSERT(B->nb[1] == B->ne[0]*B->nb[0]);            // 断言：B在维度1上连续
    GGML_ASSERT(C->nb[1] == C->ne[0]*C->nb[0]);            // 断言：C在维度1上连续
    GGML_ASSERT(ggml_are_same_shape(B, C));                 // 断言：B和C形状相同
    GGML_ASSERT(ids->type == GGML_TYPE_I32);                // 断言：序列ID必须为I32类型
																			// 空行
    {                                                       // 开始维度检查块
        const int64_t d_state      = s->ne[0];              // 状态维度
        const int64_t head_dim     = x->ne[0];              // 头维度
        const int64_t n_head       = x->ne[1];              // 头数量
        const int64_t n_seq_tokens = x->ne[2];              // 每序列token数
        const int64_t n_seqs       = x->ne[3];              // 序列总数
																			// 空行
        GGML_ASSERT(dt->ne[0] == n_head);                   // 断言：dt维度0等于头数量
        GGML_ASSERT(dt->ne[1] == n_seq_tokens);             // 断言：dt维度1等于每序列token数
        GGML_ASSERT(dt->ne[2] == n_seqs);                   // 断言：dt维度2等于序列总数
        GGML_ASSERT(ggml_is_3d(dt));                         // 断言：dt必须是3D张量
        GGML_ASSERT(s->ne[1] == head_dim);                  // 断言：状态维度1等于头维度
        GGML_ASSERT(s->ne[2] == n_head);                    // 断言：状态维度2等于头数量
        GGML_ASSERT(B->ne[0] == d_state);                   // 断言：B维度0等于状态维度
        GGML_ASSERT(B->ne[2] == n_seq_tokens);              // 断言：B维度2等于每序列token数
        GGML_ASSERT(B->ne[3] == n_seqs);                    // 断言：B维度3等于序列总数
        GGML_ASSERT(ids->ne[0] == n_seqs);                  // 断言：序列ID数量等于序列总数
        GGML_ASSERT(ggml_is_vector(ids));                    // 断言：序列ID必须是向量（1D）
        GGML_ASSERT(A->ne[1] == n_head);                    // 断言：A维度1等于头数量
        GGML_ASSERT(ggml_is_matrix(A));                      // 断言：A必须是矩阵（2D）
																			// 空行
        if (A->ne[0] != 1) {                                // 如果A维度0不为1
            // Mamba-1 has more granular decay factors      // Mamba-1有更细粒度的衰减因子
            GGML_ASSERT(A->ne[0] == d_state);               // 断言：A维度0必须等于状态维度
        }                                                   // if结束
    }                                                       // 维度检查块结束
																			// 空行
    // concatenated y + ssm_states                          // 连接输出y和SSM状态
    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, GGML_TYPE_F32, ggml_nelements(x) + s->ne[0]*s->ne[1]*s->ne[2]*ids->ne[0]);  // 创建1D结果张量，包含输出和更新后的状态
																			// 空行
    result->op   = GGML_OP_SSM_SCAN;                        // 设置操作类型为SSM_SCAN
    result->src[0] = s;                                     // 设置源张量：状态s
    result->src[1] = x;                                     // 设置源张量：输入x
    result->src[2] = dt;                                    // 设置源张量：时间步长dt
    result->src[3] = A;                                     // 设置源张量：转移矩阵A
    result->src[4] = B;                                     // 设置源张量：输入矩阵B
    result->src[5] = C;                                     // 设置源张量：输出矩阵C
    result->src[6] = ids;                                   // 设置源张量：序列ID
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_win_part - 窗口分割操作
// 将输入张量分割为不重叠的窗口，用于Swin Transformer等
																			// 空行
struct ggml_tensor * ggml_win_part(                         // 定义窗口分割函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        int                   w) {                          // 窗口大小
    GGML_ASSERT(a->ne[3] == 1);                             // 断言：维度3必须为1
    GGML_ASSERT(a->type  == GGML_TYPE_F32);                 // 断言：输入必须为F32类型
																			// 空行
    // padding                                              // 填充计算
    const int px = (w - a->ne[1]%w)%w;                      // 维度1方向的填充量
    const int py = (w - a->ne[2]%w)%w;                      // 维度2方向的填充量
																			// 空行
    const int npx = (px + a->ne[1])/w;                      // 维度1方向的窗口数量
    const int npy = (py + a->ne[2])/w;                      // 维度2方向的窗口数量
    const int np  = npx*npy;                                // 总窗口数量
																			// 空行
    const int64_t ne[4] = { a->ne[0], w, w, np, };         // 输出形状：[通道数, 窗口宽, 窗口高, 窗口数]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);  // 创建4D结果张量
																			// 空行
    int32_t params[] = { npx, npy, w };                     // 构建参数数组
    ggml_set_op_params(result, params, sizeof(params));     // 设置操作参数
																			// 空行
    result->op     = GGML_OP_WIN_PART;                      // 设置操作类型为WIN_PART
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_win_unpart - 窗口逆分割操作
// 将窗口分割后的张量还原为原始形状
																			// 空行
struct ggml_tensor * ggml_win_unpart(                       // 定义窗口逆分割函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量（窗口形式）
        int                   w0,                           // 目标宽度
        int                   h0,                           // 目标高度
        int                   w) {                          // 窗口大小
    GGML_ASSERT(a->type == GGML_TYPE_F32);                  // 断言：输入必须为F32类型
																			// 空行
    const int64_t ne[4] = { a->ne[0], w0, h0, 1, };       // 输出形状：[通道数, 宽度, 高度, 1]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 3, ne);  // 创建3D结果张量
																			// 空行
    int32_t params[] = { w };                               // 构建参数数组
    ggml_set_op_params(result, params, sizeof(params));     // 设置操作参数
																			// 空行
    result->op     = GGML_OP_WIN_UNPART;                    // 设置操作类型为WIN_UNPART
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_get_rel_pos - 获取相对位置嵌入
// 从相对位置偏置表中提取指定位置的偏置值
																			// 空行
struct ggml_tensor * ggml_get_rel_pos(                      // 定义获取相对位置函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 相对位置偏置表张量
        int                   qh,                           // 查询头数（高度方向）
        int                   kh) {                         // 键头数（高度方向）
    GGML_ASSERT(qh == kh);                                  // 断言：查询和键的头数必须相同
    GGML_ASSERT(2*MAX(qh, kh) - 1 == a->ne[1]);            // 断言：偏置表维度1 = 2*max(qh,kh)-1
																			// 空行
    const int64_t ne[4] = { a->ne[0], kh, qh, 1, };       // 输出形状：[嵌入维度, 键头数, 查询头数, 1]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F16, 3, ne);  // 创建3D F16结果张量
																			// 空行
    result->op     = GGML_OP_GET_REL_POS;                   // 设置操作类型为GET_REL_POS
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_add_rel_pos - 添加相对位置偏置
// 将水平和垂直相对位置偏置添加到注意力分数中
																			// 空行
static struct ggml_tensor * ggml_add_rel_pos_impl(          // 定义添加相对位置偏置实现函数（静态）
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 注意力分数张量
        struct ggml_tensor  * pw,                           // 水平方向位置偏置
        struct ggml_tensor  * ph,                           // 垂直方向位置偏置
        bool                  inplace) {                    // 是否原地操作标志
    GGML_ASSERT(ggml_are_same_shape(pw, ph));               // 断言：水平偏置和垂直偏置形状必须相同
    GGML_ASSERT(ggml_is_contiguous(a));                     // 断言：注意力分数张量必须连续
    GGML_ASSERT(ggml_is_contiguous(pw));                    // 断言：水平偏置必须连续
    GGML_ASSERT(ggml_is_contiguous(ph));                    // 断言：垂直偏置必须连续
    GGML_ASSERT(ph->type == GGML_TYPE_F32);                 // 断言：垂直偏置必须为F32类型
    GGML_ASSERT(pw->type == GGML_TYPE_F32);                 // 断言：水平偏置必须为F32类型
    GGML_ASSERT(pw->ne[3] == a->ne[2]);                     // 断言：偏置维度3等于注意力维度2
    GGML_ASSERT(pw->ne[0]*pw->ne[0] == a->ne[0]);          // 断言：偏置维度0的平方等于注意力维度0
    GGML_ASSERT(pw->ne[1]*pw->ne[2] == a->ne[1]);          // 断言：偏置维度1乘以维度2等于注意力维度1
																			// 空行
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a);  // 原地则创建视图，否则复制张量
    ggml_set_op_params_i32(result, 0, inplace ? 1 : 0);    // 存储原地操作标志
																			// 空行
    result->op     = GGML_OP_ADD_REL_POS;                   // 设置操作类型为ADD_REL_POS
    result->src[0] = a;                                     // 设置源张量：注意力分数
    result->src[1] = pw;                                    // 设置源张量：水平偏置
    result->src[2] = ph;                                    // 设置源张量：垂直偏置
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_add_rel_pos - 非原地添加相对位置偏置
struct ggml_tensor * ggml_add_rel_pos(                      // 定义非原地添加相对位置偏置函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 注意力分数张量
        struct ggml_tensor  * pw,                           // 水平偏置
        struct ggml_tensor  * ph) {                         // 垂直偏置
    return ggml_add_rel_pos_impl(ctx, a, pw, ph, false);    // 调用实现函数，inplace=false
}                                                           // 函数结束
																			// 空行
// ggml_add_rel_pos_inplace - 原地添加相对位置偏置
struct ggml_tensor * ggml_add_rel_pos_inplace(              // 定义原地添加相对位置偏置函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 注意力分数张量
        struct ggml_tensor  * pw,                           // 水平偏置
        struct ggml_tensor  * ph) {                         // 垂直偏置
    return ggml_add_rel_pos_impl(ctx, a, pw, ph, true);     // 调用实现函数，inplace=true
}                                                           // 函数结束
																			// 空行
// ggml_rwkv_wkv6 - RWKV WKV6操作
// RWKV模型第六版本的W-K-V（加权键值）时间混合核心操作
																			// 空行
struct ggml_tensor * ggml_rwkv_wkv6(                        // 定义RWKV WKV6函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * k,                            // 键张量
        struct ggml_tensor  * v,                            // 值张量
        struct ggml_tensor  * r,                            // 拒绝/遗忘门张量
        struct ggml_tensor  * tf,                           // 时间衰减因子
        struct ggml_tensor  * td,                           // 时间衰减
        struct ggml_tensor  * state) {                      // RWKV状态张量
    GGML_ASSERT(ggml_is_contiguous(k));                     // 断言：键张量必须连续
    GGML_ASSERT(ggml_is_contiguous(v));                     // 断言：值张量必须连续
    GGML_ASSERT(ggml_is_contiguous(r));                     // 断言：拒绝门张量必须连续
    GGML_ASSERT(ggml_is_contiguous(tf));                    // 断言：时间衰减因子必须连续
    GGML_ASSERT(ggml_is_contiguous(td));                    // 断言：时间衰减必须连续
    GGML_ASSERT(ggml_is_contiguous(state));                 // 断言：状态张量必须连续
																			// 空行
    const int64_t S = k->ne[0];                             // 状态大小（嵌入维度）
    const int64_t H = k->ne[1];                             // 头数量
    const int64_t n_tokens = k->ne[2];                      // token数量
    const int64_t n_seqs = state->ne[1];                    // 序列数量
    {                                                       // 开始维度验证块
        GGML_ASSERT(v->ne[0] == S && v->ne[1] == H && v->ne[2] == n_tokens);  // 断言：V形状为 [S, H, n_tokens]
        GGML_ASSERT(r->ne[0] == S && r->ne[1] == H && r->ne[2] == n_tokens);  // 断言：R形状为 [S, H, n_tokens]
        GGML_ASSERT(td->ne[0] == S && td->ne[1] == H && td->ne[2] == n_tokens);  // 断言：TD形状为 [S, H, n_tokens]
        GGML_ASSERT(ggml_nelements(state) == S * S * H * n_seqs);  // 断言：状态元素数 = S*S*H*序列数
    }                                                       // 维度验证块结束
																			// 空行
    // concat output and new_state                          // 连接输出和新状态
    const int64_t ne[4] = { S * H, n_tokens + S * n_seqs, 1, 1 };  // 输出形状：[S*H, token数 + S*序列数, 1, 1]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);  // 创建4D F32结果张量
																			// 空行
    result->op     = GGML_OP_RWKV_WKV6;                     // 设置操作类型为RWKV_WKV6
    result->src[0] = k;                                     // 设置源张量：键K
    result->src[1] = v;                                     // 设置源张量：值V
    result->src[2] = r;                                     // 设置源张量：拒绝门R
    result->src[3] = tf;                                    // 设置源张量：时间衰减因子TF
    result->src[4] = td;                                    // 设置源张量：时间衰减TD
    result->src[5] = state;                                 // 设置源张量：状态
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_gated_linear_attn - 门控线性注意力操作
// 用于Gated Linear Attention (GLA)模型
																			// 空行
struct ggml_tensor * ggml_gated_linear_attn(                // 定义门控线性注意力函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * k,                            // 键张量
        struct ggml_tensor  * v,                            // 值张量
        struct ggml_tensor  * q,                            // 查询张量
        struct ggml_tensor  * g,                            // 门控张量
        struct ggml_tensor  * state,                        // 注意力状态张量
        float scale) {                                      // 缩放因子
    GGML_ASSERT(ggml_is_contiguous(k));                     // 断言：键张量必须连续
    GGML_ASSERT(ggml_is_contiguous(v));                     // 断言：值张量必须连续
    GGML_ASSERT(ggml_is_contiguous(q));                     // 断言：查询张量必须连续
    GGML_ASSERT(ggml_is_contiguous(g));                     // 断言：门控张量必须连续
    GGML_ASSERT(ggml_is_contiguous(state));                 // 断言：状态张量必须连续
																			// 空行
    const int64_t S = k->ne[0];                             // 状态维度
    const int64_t H = k->ne[1];                             // 头数量
    const int64_t n_tokens = k->ne[2];                      // token数量
    const int64_t n_seqs = state->ne[1];                    // 序列数量
    {                                                       // 开始维度验证块
        GGML_ASSERT(v->ne[0] == S && v->ne[1] == H && v->ne[2] == n_tokens);  // 断言：V形状正确
        GGML_ASSERT(q->ne[0] == S && q->ne[1] == H && q->ne[2] == n_tokens);  // 断言：Q形状正确
        GGML_ASSERT(g->ne[0] == S && g->ne[1] == H && g->ne[2] == n_tokens);  // 断言：G形状正确
        GGML_ASSERT(ggml_nelements(state) == S * S * H * n_seqs);  // 断言：状态元素数正确
    }                                                       // 维度验证块结束
																			// 空行
    // concat output and new_state                          // 连接输出和新状态
    const int64_t ne[4] = { S * H, n_tokens + S * n_seqs, 1, 1 };  // 输出形状
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);  // 创建4D F32结果张量
																			// 空行
    ggml_set_op_params_f32(result, 0, scale);               // 存储缩放因子参数
																			// 空行
    result->op     = GGML_OP_GATED_LINEAR_ATTN;             // 设置操作类型为GATED_LINEAR_ATTN
    result->src[0] = k;                                     // 设置源张量：键K
    result->src[1] = v;                                     // 设置源张量：值V
    result->src[2] = q;                                     // 设置源张量：查询Q
    result->src[3] = g;                                     // 设置源张量：门控G
    result->src[4] = state;                                 // 设置源张量：状态
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_rwkv_wkv7 - RWKV WKV7操作
// RWKV模型第七版本的W-K-V时间混合核心操作
																			// 空行
struct ggml_tensor * ggml_rwkv_wkv7(                        // 定义RWKV WKV7函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * r,                            // 拒绝/遗忘门张量
        struct ggml_tensor  * w,                            // 权重张量
        struct ggml_tensor  * k,                            // 键张量
        struct ggml_tensor  * v,                            // 值张量
        struct ggml_tensor  * a,                            // 额外参数张量A
        struct ggml_tensor  * b,                            // 额外参数张量B
        struct ggml_tensor  * state) {                      // RWKV状态张量
    GGML_ASSERT(ggml_is_contiguous(r));                     // 断言：拒绝门张量必须连续
    GGML_ASSERT(ggml_is_contiguous(w));                     // 断言：权重张量必须连续
    GGML_ASSERT(ggml_is_contiguous(k));                     // 断言：键张量必须连续
    GGML_ASSERT(ggml_is_contiguous(v));                     // 断言：值张量必须连续
    GGML_ASSERT(ggml_is_contiguous(a));                     // 断言：参数A张量必须连续
    GGML_ASSERT(ggml_is_contiguous(b));                     // 断言：参数B张量必须连续
    GGML_ASSERT(ggml_is_contiguous(state));                 // 断言：状态张量必须连续
																			// 空行
    const int64_t S = k->ne[0];                             // 状态大小（嵌入维度）
    const int64_t H = k->ne[1];                             // 头数量
    const int64_t n_tokens = k->ne[2];                      // token数量
    const int64_t n_seqs = state->ne[1];                    // 序列数量
    {                                                       // 开始维度验证块
        GGML_ASSERT(w->ne[0] == S && w->ne[1] == H && w->ne[2] == n_tokens);  // 断言：W形状正确
        GGML_ASSERT(k->ne[0] == S && k->ne[1] == H && k->ne[2] == n_tokens);  // 断言：K形状正确
        GGML_ASSERT(v->ne[0] == S && v->ne[1] == H && v->ne[2] == n_tokens);  // 断言：V形状正确
        GGML_ASSERT(a->ne[0] == S && a->ne[1] == H && a->ne[2] == n_tokens);  // 断言：A形状正确
        GGML_ASSERT(b->ne[0] == S && b->ne[1] == H && b->ne[2] == n_tokens);  // 断言：B形状正确
        GGML_ASSERT(ggml_nelements(state) == S * S * H * n_seqs);  // 断言：状态元素数正确
    }                                                       // 维度验证块结束
																			// 空行
    // concat output and new_state                          // 连接输出和新状态
    const int64_t ne[4] = { S * H, n_tokens + S * n_seqs, 1, 1 };  // 输出形状
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);  // 创建4D F32结果张量
																			// 空行
    result->op     = GGML_OP_RWKV_WKV7;                     // 设置操作类型为RWKV_WKV7
    result->src[0] = r;                                     // 设置源张量：拒绝门R
    result->src[1] = w;                                     // 设置源张量：权重W
    result->src[2] = k;                                     // 设置源张量：键K
    result->src[3] = v;                                     // 设置源张量：值V
    result->src[4] = a;                                     // 设置源张量：参数A
    result->src[5] = b;                                     // 设置源张量：参数B
    result->src[6] = state;                                 // 设置源张量：状态
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_unary - 一元操作
// 通用的张量一元操作，支持多种函数（sin、cos、abs等）
																			// 空行
static struct ggml_tensor * ggml_unary_impl(                // 定义一元操作实现函数（静态）
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        enum ggml_unary_op    op,                           // 一元操作类型枚举
        bool                  inplace) {                    // 是否原地操作标志
    GGML_ASSERT(ggml_is_contiguous_rows(a));                // 断言：输入张量必须行连续
																			// 空行
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a);  // 原地则创建视图，否则复制张量
																			// 空行
    ggml_set_op_params_i32(result, 0, (int32_t) op);       // 存储一元操作类型参数
																			// 空行
    result->op     = GGML_OP_UNARY;                         // 设置操作类型为UNARY
    result->src[0] = a;                                     // 设置输入张量
																			// 空行
    return result;                                          // 返回结果张量
}                                                           // 函数结束
																			// 空行
// ggml_unary - 非原地一元操作
struct ggml_tensor * ggml_unary(                            // 定义非原地一元操作函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        enum ggml_unary_op    op) {                         // 一元操作类型
    return ggml_unary_impl(ctx, a, op, false);              // 调用实现函数，inplace=false
}                                                           // 函数结束
																			// 空行
// ggml_unary_inplace - 原地一元操作
struct ggml_tensor * ggml_unary_inplace(                    // 定义原地一元操作函数
        struct ggml_context * ctx,                          // 上下文指针
        struct ggml_tensor  * a,                            // 输入张量
        enum ggml_unary_op    op) {                         // 一元操作类型
    return ggml_unary_impl(ctx, a, op, true);               // 调用实现函数，inplace=true
}                                                           // 函数结束
