// ggml_leaky_relu // Leaky ReLU 激活函数标记注释（带负斜率的 ReLU）

struct ggml_tensor * ggml_leaky_relu( // Leaky ReLU 激活函数
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 输入张量
        float                 negative_slope, // 负区间的斜率系数
        bool                  inplace) { // 是否原地操作的标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    ggml_set_op_params(result, &negative_slope, sizeof(negative_slope)); // 将负斜率参数保存到操作参数中

    result->op     = GGML_OP_LEAKY_RELU; // 设置操作类型为 Leaky ReLU
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

