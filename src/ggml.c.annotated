void * ggml_aligned_malloc(size_t size) { // 对齐内存分配函数
#if defined(__s390x__) // 如果是s390x架构（IBM大型机）
    const int alignment = 256; // s390x架构使用256字节对齐
#else // 其他架构
    const int alignment = 64; // 默认使用64字节对齐（匹配缓存行大小）
#endif // 架构判断结束

#if defined(_MSC_VER) || defined(__MINGW32__) // 如果是MSVC或MinGW编译器
    return _aligned_malloc(size, alignment); // 使用MSVC的对齐分配函数
#else // 非Windows平台
    if (size == 0) { // 如果请求分配0字节
        GGML_LOG_WARN("Behavior may be unexpected when allocating 0 bytes for ggml_aligned_malloc!\n"); // 输出警告
        return NULL; // 返回空指针
    } // 零字节检查结束
    void * aligned_memory = NULL; // 对齐内存指针，初始为空
  #ifdef GGML_USE_CPU_HBM // 如果使用CPU高带宽内存
    int result = hbw_posix_memalign(&aligned_memory, alignment, size); // 使用高带宽内存对齐分配
  #elif TARGET_OS_OSX // 如果是macOS系统
    GGML_UNUSED(alignment); // 忽略alignment参数（macOS使用vm_allocate）
    kern_return_t alloc_status = vm_allocate((vm_map_t) mach_task_self(), (vm_address_t *) &aligned_memory, size, VM_FLAGS_ANYWHERE); // 使用Mach虚拟内存分配
    int result = EFAULT; // 默认错误码
    switch (alloc_status) { // 根据分配状态设置错误码
        case KERN_SUCCESS: // 分配成功
            result = 0; // 设置结果为0（成功）
            break; // 跳出switch
        case KERN_INVALID_ADDRESS: // 无效地址
            result = EINVAL; // 设置为无效参数错误
            break; // 跳出switch
        case KERN_NO_SPACE: // 没有足够空间
            result = ENOMEM; // 设置为内存不足错误
            break; // 跳出switch
        default: // 其他错误
            result = EFAULT; // 设置为一般错误
            break; // 跳出switch
    } // switch结束
  #else // 其他POSIX平台
    int result = posix_memalign(&aligned_memory, alignment, size); // 使用POSIX对齐内存分配
  #endif // 平台判断结束
    if (result != 0) { // 如果分配失败
        // Handle allocation failure // 处理分配失败
        const char *error_desc = "unknown allocation error"; // 默认错误描述
        switch (result) { // 根据错误码设置描述
            case EINVAL: // 无效参数
                error_desc = "invalid alignment value"; // 无效对齐值
                break; // 跳出switch
            case ENOMEM: // 内存不足
                error_desc = "insufficient memory"; // 内存不足
                break; // 跳出switch
        } // switch结束
        GGML_LOG_ERROR("%s: %s (attempted to allocate %6.2f MB)\n", __func__, error_desc, size/(1024.0*1024.0)); // 输出错误信息
        return NULL; // 返回空指针
    } // 分配失败检查结束
    return aligned_memory; // 返回对齐内存指针
#endif // 平台判断结束
} // ggml_aligned_malloc 函数结束

void ggml_aligned_free(void * ptr, size_t size) { // 释放对齐分配的内存
    GGML_UNUSED(size); // 忽略size参数（某些平台不需要）
#if defined(_MSC_VER) || defined(__MINGW32__) // 如果是MSVC或MinGW编译器
    _aligned_free(ptr); // 使用MSVC的对齐释放函数
#elif GGML_USE_CPU_HBM // 如果使用CPU高带宽内存
    if (ptr != NULL) { // 如果指针非空
        hbw_free(ptr); // 使用高带宽内存释放函数
    } // 空指针检查结束
#elif TARGET_OS_OSX // 如果是macOS系统
    if (ptr != NULL) { // 如果指针非空
        vm_deallocate((vm_map_t)mach_task_self(), (vm_address_t)ptr, size); // 使用Mach虚拟内存释放
    } // 空指针检查结束
#else // 其他平台
    free(ptr); // 使用标准free释放内存
#endif // 平台判断结束
} // ggml_aligned_free 函数结束


inline static void * ggml_malloc(size_t size) { // ggml内存分配包装函数
    if (size == 0) { // 如果请求分配0字节
        GGML_LOG_WARN("Behavior may be unexpected when allocating 0 bytes for ggml_malloc!\n"); // 输出警告
        return NULL; // 返回空指针
    } // 零字节检查结束
    void * result = malloc(size); // 调用标准malloc分配内存
    if (result == NULL) { // 如果分配失败
        GGML_LOG_ERROR("%s: failed to allocate %6.2f MB\n", __func__, size/(1024.0*1024.0)); // 输出错误信息
        GGML_ABORT("fatal error"); // 终止程序
    } // 分配失败检查结束
    return result; // 返回分配的内存指针
} // ggml_malloc 函数结束

// calloc // calloc内存分配
inline static void * ggml_calloc(size_t num, size_t size) { // ggml的calloc包装函数，分配并清零内存
    if (num == 0 || size == 0) { // 如果元素数或大小为0
        GGML_LOG_WARN("Behavior may be unexpected when allocating 0 bytes for ggml_calloc!\n"); // 输出警告
        return NULL; // 返回空指针
    } // 零检查结束
    void * result = calloc(num, size); // 调用标准calloc分配并清零内存
    if (result == NULL) { // 如果分配失败
        GGML_LOG_ERROR("%s: failed to allocate %6.2f MB\n", __func__, size/(1024.0*1024.0)); // 输出错误信息
        GGML_ABORT("fatal error"); // 终止程序
    } // 分配失败检查结束
    return result; // 返回分配的内存指针
} // ggml_calloc 函数结束

#define GGML_MALLOC(size)      ggml_malloc(size) // GGML_MALLOC宏，调用ggml_malloc
#define GGML_CALLOC(num, size) ggml_calloc(num, size) // GGML_CALLOC宏，调用ggml_calloc

#define GGML_FREE(ptr) free(ptr) // GGML_FREE宏，调用标准free

const char * ggml_status_to_string(enum ggml_status status) { // 将ggml状态枚举转换为字符串描述
    switch (status) { // 根据状态值匹配
        case GGML_STATUS_ALLOC_FAILED: return "GGML status: error (failed to allocate memory)"; // 内存分配失败
        case GGML_STATUS_FAILED:       return "GGML status: error (operation failed)"; // 操作失败
        case GGML_STATUS_SUCCESS:      return "GGML status: success"; // 操作成功
        case GGML_STATUS_ABORTED:      return "GGML status: warning (operation aborted)"; // 操作被中止
    } // switch结束

    return "GGML status: unknown"; // 未知状态
} // ggml_status_to_string 函数结束

float ggml_fp16_to_fp32(ggml_fp16_t x) { // 将半精度浮点数（FP16）转换为单精度浮点数（FP32）
#define ggml_fp16_to_fp32 do_not_use__ggml_fp16_to_fp32__in_ggml // 重定义宏，防止在ggml内部直接调用此函数名
    return GGML_FP16_TO_FP32(x); // 使用宏进行实际转换
} // ggml_fp16_to_fp32 函数结束

ggml_fp16_t ggml_fp32_to_fp16(float x) { // 将单精度浮点数（FP32）转换为半精度浮点数（FP16）
#define ggml_fp32_to_fp16 do_not_use__ggml_fp32_to_fp16__in_ggml // 重定义宏，防止在ggml内部直接调用此函数名
    return GGML_FP32_TO_FP16(x); // 使用宏进行实际转换
} // ggml_fp32_to_fp16 函数结束

float ggml_bf16_to_fp32(ggml_bf16_t x) { // 将BF16浮点数转换为单精度浮点数（FP32）
#define ggml_bf16_to_fp32 do_not_use__ggml_bf16_to_fp32__in_ggml // 重定义宏，防止在ggml内部直接调用此函数名
    return GGML_BF16_TO_FP32(x);  // it just left shifts // 实际只是左移操作
} // ggml_bf16_to_fp32 函数结束

ggml_bf16_t ggml_fp32_to_bf16(float x) { // 将单精度浮点数（FP32）转换为BF16浮点数
#define ggml_fp32_to_bf16 do_not_use__ggml_fp32_to_bf16__in_ggml // 重定义宏，防止在ggml内部直接调用此函数名
    return GGML_FP32_TO_BF16(x); // 使用宏进行实际转换
} // ggml_fp32_to_bf16 函数结束

void ggml_fp16_to_fp32_row(const ggml_fp16_t * x, float * y, int64_t n) { // 将FP16数组批量转换为FP32数组
    for (int64_t i = 0; i < n; i++) { // 遍历所有元素
        y[i] = GGML_FP16_TO_FP32(x[i]); // 逐个转换
    } // 循环结束
} // ggml_fp16_to_fp32_row 函数结束

void ggml_fp32_to_fp16_row(const float * x, ggml_fp16_t * y, int64_t n) { // 将FP32数组批量转换为FP16数组
    int i = 0; // 循环变量
    for (; i < n; ++i) { // 遍历所有元素
        y[i] = GGML_FP32_TO_FP16(x[i]); // 逐个转换
    } // 循环结束
} // ggml_fp32_to_fp16_row 函数结束

void ggml_bf16_to_fp32_row(const ggml_bf16_t * x, float * y, int64_t n) { // 将BF16数组批量转换为FP32数组
    int i = 0; // 循环变量
    for (; i < n; ++i) { // 遍历所有元素
        y[i] = GGML_BF16_TO_FP32(x[i]); // 逐个转换
    } // 循环结束
} // ggml_bf16_to_fp32_row 函数结束

void ggml_fp32_to_bf16_row_ref(const float * x, ggml_bf16_t * y, int64_t n) { // FP32到BF16的参考实现（逐个转换）
    for (int i = 0; i < n; i++) { // 遍历所有元素
        y[i] = ggml_compute_fp32_to_bf16(x[i]); // 使用计算函数逐个转换
    } // 循环结束
} // ggml_fp32_to_bf16_row_ref 函数结束

void ggml_fp32_to_bf16_row(const float * x, ggml_bf16_t * y, int64_t n) { // FP32到BF16的优化实现（使用SIMD加速）
  int i = 0; // 循环变量
#if defined(__AVX512BF16__) // 如果支持AVX512 BF16指令集
  // subnormals are flushed to zero on this platform // 在此平台上次正规数被刷新为零
  for (; i + 32 <= n; i += 32) { // 每次处理32个元素
        _mm512_storeu_si512( // 存储512位（64字节）数据到目标地址
            (__m512i *)(y + i), // 目标地址
            m512i(_mm512_cvtne2ps_pbh(_mm512_loadu_ps(x + i + 16), // 将后16个FP32转为BF16
                                _mm512_loadu_ps(x + i)))); // 将前16个FP32转为BF16
  } // SIMD循环结束
#endif // __AVX512BF16__ 判断结束
    for (; i < n; i++) { // 处理剩余不足32个的元素
        y[i] = GGML_FP32_TO_BF16(x[i]); // 逐个转换
    } // 标量循环结束
} // ggml_fp32_to_bf16_row 函数结束

bool ggml_guid_matches(ggml_guid_t guid_a, ggml_guid_t guid_b) { // 比较两个GUID是否匹配
    return memcmp(guid_a, guid_b, sizeof(ggml_guid)) == 0; // 使用memcmp逐字节比较
} // ggml_guid_matches 函数结束

const char * ggml_version(void) { // 获取ggml版本字符串
    return GGML_VERSION; // 返回编译时的版本号宏
} // ggml_version 函数结束

const char * ggml_commit(void) { // 获取ggml提交哈希字符串
    return GGML_COMMIT; // 返回编译时的提交哈希宏
} // ggml_commit 函数结束

// // 注释分隔符
// timing // 计时模块
// // 注释分隔符

#if defined(_MSC_VER) || defined(__MINGW32__) // 如果是MSVC或MinGW编译器
static int64_t timer_freq, timer_start; // 静态变量：计时器频率和起始值
void ggml_time_init(void) { // 初始化计时器
    LARGE_INTEGER t; // Windows高精度计数器值
    QueryPerformanceFrequency(&t); // 获取计数器频率
    timer_freq = t.QuadPart; // 保存频率值

    // The multiplication by 1000 or 1000000 below can cause an overflow if timer_freq // 下面的乘以1000或1000000可能在timer_freq较大时导致溢出
    // and the uptime is high enough. // 且运行时间足够长时
    // We subtract the program start time to reduce the likelihood of that happening. // 我们减去程序启动时间来降低这种可能性
    QueryPerformanceCounter(&t); // 获取当前计数器值
    timer_start = t.QuadPart; // 保存起始计数器值
} // ggml_time_init 函数结束
int64_t ggml_time_ms(void) { // 获取当前时间（毫秒）
    LARGE_INTEGER t; // Windows高精度计数器值
    QueryPerformanceCounter(&t); // 获取当前计数器值
    return ((t.QuadPart-timer_start) * 1000) / timer_freq; // 转换为毫秒
} // ggml_time_ms 函数结束
int64_t ggml_time_us(void) { // 获取当前时间（微秒）
    LARGE_INTEGER t; // Windows高精度计数器值
    QueryPerformanceCounter(&t); // 获取当前计数器值
    return ((t.QuadPart-timer_start) * 1000000) / timer_freq; // 转换为微秒
} // ggml_time_us 函数结束
#else // 非Windows平台
void ggml_time_init(void) {} // 初始化计时器（非Windows平台无需初始化）
int64_t ggml_time_ms(void) { // 获取当前时间（毫秒）
    struct timespec ts; // POSIX时间规格结构体
    clock_gettime(CLOCK_MONOTONIC, &ts); // 获取单调时钟时间
    return (int64_t)ts.tv_sec*1000 + (int64_t)ts.tv_nsec/1000000; // 转换为毫秒
} // ggml_time_ms 函数结束

int64_t ggml_time_us(void) { // 获取当前时间（微秒）
    struct timespec ts; // POSIX时间规格结构体
    clock_gettime(CLOCK_MONOTONIC, &ts); // 获取单调时钟时间
    return (int64_t)ts.tv_sec*1000000 + (int64_t)ts.tv_nsec/1000; // 转换为微秒
} // ggml_time_us 函数结束
#endif // 平台判断结束

int64_t ggml_cycles(void) { // 获取CPU时钟周期数
    return clock(); // 返回标准C库clock()值
} // ggml_cycles 函数结束

int64_t ggml_cycles_per_ms(void) { // 获取每毫秒的CPU时钟周期数
    return CLOCKS_PER_SEC/1000; // 使用CLOCKS_PER_SEC宏计算
} // ggml_cycles_per_ms 函数结束

// // 注释分隔符
// cross-platform UTF-8 file paths // 跨平台UTF-8文件路径处理
// // 注释分隔符

#ifdef _WIN32 // 如果是Windows系统
static wchar_t * ggml_mbstowcs(const char * mbs) { // 将多字节字符串（UTF-8）转换为宽字符字符串
    int wlen = MultiByteToWideChar(CP_UTF8, 0, mbs, -1, NULL, 0); // 计算需要的宽字符数量
    if (!wlen) { // 如果转换失败
        errno = EINVAL; // 设置错误号为无效参数
        return NULL; // 返回空指针
    } // 转换失败检查结束

    wchar_t * wbuf = GGML_MALLOC(wlen * sizeof(wchar_t)); // 分配宽字符缓冲区
    wlen = MultiByteToWideChar(CP_UTF8, 0, mbs, -1, wbuf, wlen); // 执行实际转换
    if (!wlen) { // 如果转换失败
        GGML_FREE(wbuf); // 释放已分配的缓冲区
        errno = EINVAL; // 设置错误号为无效参数
        return NULL; // 返回空指针
    } // 转换失败检查结束

    return wbuf; // 返回宽字符字符串
} // ggml_mbstowcs 函数结束
#endif // _WIN32 判断结束

FILE * ggml_fopen(const char * fname, const char * mode) { // 跨平台文件打开函数
#ifdef _WIN32 // 如果是Windows系统
    FILE * file = NULL; // 文件指针，初始为空

    // convert fname (UTF-8) // 转换文件名（UTF-8编码）
    wchar_t * wfname = ggml_mbstowcs(fname); // 将文件名转换为宽字符
    if (wfname) { // 如果转换成功
        // convert mode (ANSI) // 转换文件打开模式（ANSI编码）
        wchar_t * wmode = GGML_MALLOC((strlen(mode) + 1) * sizeof(wchar_t)); // 分配模式字符串的宽字符缓冲区
        wchar_t * wmode_p = wmode; // 宽字符模式指针
        do {
            *wmode_p++ = (wchar_t)*mode; // 逐个字符转换为宽字符
        } while (*mode++); // 直到遇到空字符

        // open file // 打开文件
        file = _wfopen(wfname, wmode); // 使用宽字符版本的fopen

        GGML_FREE(wfname); // 释放文件名缓冲区
        GGML_FREE(wmode); // 释放模式字符串缓冲区
    } // 转换成功检查结束

    return file; // 返回文件指针
#else // 非Windows平台
    return fopen(fname, mode); // 直接使用标准fopen
#endif // 平台判断结束

} // ggml_fopen 函数结束

static const struct ggml_type_traits type_traits[GGML_TYPE_COUNT] = { // 各数据类型的特征属性静态数组
    [GGML_TYPE_I8] = { // 8位有符号整数类型
