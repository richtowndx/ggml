struct backtrace_state { // 回溯状态结构体，用于记录调用栈
    void ** current; // 当前栈帧指针位置
    void ** end; // 栈帧缓冲区末尾
}; // backtrace_state 结构体结束

static _Unwind_Reason_Code unwind_callback(struct _Unwind_Context* context, void* arg) { // 栈展开回调函数，逐帧获取程序计数器
    struct backtrace_state * state = (struct backtrace_state *)arg; // 将参数转换为回溯状态结构体指针
    uintptr_t pc = _Unwind_GetIP(context); // 获取当前栈帧的程序计数器地址
    if (pc) { // 如果程序计数器非零
        if (state->current == state->end) { // 如果缓冲区已满
            return _URC_END_OF_STACK; // 返回栈结束标志
        } else { // 否则
            *state->current++ = (void*)pc; // 将程序计数器存入缓冲区并移动指针
        } // 缓冲区检查结束
    } // 程序计数器检查结束
    return _URC_NO_REASON; // 继续展开
} // unwind_callback 函数结束

static void ggml_print_backtrace_symbols(void) { // 打印回溯符号信息（Android平台实现）
    const int max = 100; // 最大回溯深度为100帧
    void* buffer[max]; // 存储栈帧地址的缓冲区

    struct backtrace_state state = {buffer, buffer + max}; // 初始化回溯状态
    _Unwind_Backtrace(unwind_callback, &state); // 执行栈展开

    int count = state.current - buffer; // 计算实际捕获的栈帧数量

    for (int idx = 0; idx < count; ++idx) { // 遍历所有捕获的栈帧
        const void * addr = buffer[idx]; // 获取当前栈帧地址
        const char * symbol = ""; // 符号名称，默认为空字符串

        Dl_info info; // 动态链接库信息结构体
        if (dladdr(addr, &info) && info.dli_sname) { // 查找地址对应的符号名称
            symbol = info.dli_sname; // 获取符号名称
        } // dladdr 检查结束

        fprintf(stderr, "%d: %p %s\n", idx, addr, symbol); // 输出栈帧索引、地址和符号名
    } // 栈帧遍历结束
} // ggml_print_backtrace_symbols 函数结束（Android）
#elif defined(__linux__) && defined(__GLIBC__) // 如果是Linux且使用glibc
#include <execinfo.h> // 包含回溯头文件
static void ggml_print_backtrace_symbols(void) { // 打印回溯符号信息（Linux glibc实现）
    void * trace[100]; // 存储栈帧地址的缓冲区，最大100帧
    int nptrs = backtrace(trace, sizeof(trace)/sizeof(trace[0])); // 获取调用栈
    backtrace_symbols_fd(trace, nptrs, STDERR_FILENO); // 将符号信息输出到标准错误
} // ggml_print_backtrace_symbols 函数结束（Linux glibc）
#elif defined(__APPLE__) // 如果是Apple平台
#include <execinfo.h> // 包含回溯头文件
static void ggml_print_backtrace_symbols(void) { // 打印回溯符号信息（macOS实现）
    void * trace[100]; // 存储栈帧地址的缓冲区，最大100帧
    int nptrs = backtrace(trace, sizeof(trace)/sizeof(trace[0])); // 获取调用栈
    backtrace_symbols_fd(trace, nptrs, STDERR_FILENO); // 将符号信息输出到标准错误
} // ggml_print_backtrace_symbols 函数结束（macOS）
#else // 其他不支持的平台
static void ggml_print_backtrace_symbols(void) { // 打印回溯符号信息的空实现
    // platform not supported // 平台不支持
} // ggml_print_backtrace_symbols 空函数结束
#endif // 平台判断结束

void ggml_print_backtrace(void) { // 打印调用回溯信息的主函数
    const char * GGML_NO_BACKTRACE = getenv("GGML_NO_BACKTRACE"); // 检查环境变量是否禁用回溯
    if (GGML_NO_BACKTRACE) { // 如果设置了禁用回溯
        return; // 直接返回
    } // 环境变量检查结束
#if defined(__APPLE__) // 如果是Apple平台
    // On macOS, fork+debugger attachment is problematic due to: // macOS上fork+调试器附加存在问题，原因：
    // 1. libdispatch "poisons" forked child processes // 1. libdispatch会"污染"fork的子进程
    // 2. lldb has issues attaching to parent from forked child // 2. lldb从子进程附加到父进程有问题
    // Use simple backtrace() instead to avoid Terminal.app crashes // 使用简单的backtrace()来避免Terminal.app崩溃
    const char * GGML_BACKTRACE_LLDB = getenv("GGML_BACKTRACE_LLDB"); // 检查是否启用lldb回溯
    if (!GGML_BACKTRACE_LLDB) { // 如果未启用lldb回溯
        fprintf(stderr, "WARNING: Using native backtrace. Set GGML_BACKTRACE_LLDB for more info.\n"); // 输出警告信息
        fprintf(stderr, "WARNING: GGML_BACKTRACE_LLDB may cause native MacOS Terminal.app to crash.\n"); // 输出lldb可能导致崩溃的警告
        fprintf(stderr, "See: https://github.com/ggml-org/llama.cpp/pull/17869\n"); // 输出参考链接
        ggml_print_backtrace_symbols(); // 使用本地回溯函数
        return; // 直接返回
    } // lldb检查结束
#endif // __APPLE__ 判断结束
#if defined(__linux__) // 如果是Linux系统
    FILE * f = fopen("/proc/self/status", "r"); // 打开进程状态文件
    size_t size = 0; // 行缓冲区大小
    char * line = NULL; // 行缓冲区指针
    ssize_t length = 0; // 读取的行长度
    while ((length = getline(&line, &size, f)) > 0) { // 逐行读取进程状态
        if (!strncmp(line, "TracerPid:", sizeof("TracerPid:") - 1) && // 如果找到TracerPid行
            (length != sizeof("TracerPid:\t0\n") - 1 || line[length - 2] != '0')) { // 且正在被调试器跟踪
            // Already being debugged, and the breakpoint is the later abort() // 已经被调试器附加，断点是后面的abort()
            free(line); // 释放行缓冲区
            fclose(f); // 关闭文件
            return; // 直接返回
        } // TracerPid检查结束
    } // 行读取循环结束
    free(line); // 释放行缓冲区
    fclose(f); // 关闭文件
    int lock[2] = { -1, -1 }; // 管道锁，用于同步父子进程
    (void) !pipe(lock); // Don't start gdb until after PR_SET_PTRACER // 创建管道，在设置PR_SET_PTRACER之前不启动gdb
#endif // __linux__ 判断结束
    const int parent_pid = getpid(); // 获取父进程（当前进程）PID
    const int child_pid = fork(); // 创建子进程
    if (child_pid < 0) { // error // fork失败
#if defined(__linux__) // 如果是Linux系统
        close(lock[1]); // 关闭管道写端
        close(lock[0]); // 关闭管道读端
#endif // __linux__ 判断结束
        return; // 直接返回
    } else if (child_pid == 0) { // child // 子进程分支
        char attach[32]; // 存储附加命令字符串
        snprintf(attach, sizeof(attach), "attach %d", parent_pid); // 构造gdb附加命令
#if defined(__linux__) // 如果是Linux系统
        close(lock[1]); // 关闭管道写端
        (void) !read(lock[0], lock, 1); // 等待父进程设置PR_SET_PTRACER
        close(lock[0]); // 关闭管道读端
#endif // __linux__ 判断结束
        // try gdb // 尝试使用gdb调试器
        execlp("gdb", "gdb", "--batch", // 以批处理模式运行gdb
            "-ex", "set style enabled on", // 启用样式
            "-ex", attach, // 附加到父进程
            "-ex", "bt -frame-info source-and-location", // 打印带源码位置信息的回溯
            "-ex", "detach", // 分离调试
            "-ex", "quit", // 退出gdb
            (char *) NULL); // 参数列表结束
        // try lldb // 如果gdb不可用，尝试lldb
        execlp("lldb", "lldb", "--batch", // 以批处理模式运行lldb
            "-o", "bt", // 执行backtrace命令
            "-o", "quit", // 退出lldb
            "-p", &attach[sizeof("attach ") - 1], // 指定附加的进程ID
            (char *) NULL); // 参数列表结束
        // gdb failed, fallback to backtrace_symbols // gdb失败，回退到backtrace_symbols
        ggml_print_backtrace_symbols(); // 使用基本回溯符号打印
        _Exit(0); // 子进程退出
    } else { // parent // 父进程分支
#if defined(__linux__) // 如果是Linux系统
        prctl(PR_SET_PTRACER, child_pid); // 允许子进程跟踪父进程
        close(lock[1]); // 关闭管道写端，通知子进程可以开始
        close(lock[0]); // 关闭管道读端
#endif // __linux__ 判断结束
        waitpid(child_pid, NULL, 0); // 等待子进程结束
    } // fork分支结束
} // ggml_print_backtrace 函数结束
#else // 不支持回溯的平台
void ggml_print_backtrace(void) { // 打印回溯的空实现
    // platform not supported // 平台不支持
} // ggml_print_backtrace 空函数结束
#endif // 平台判断结束

static ggml_abort_callback_t g_abort_callback = NULL; // 全局中止回调函数指针，初始为空

// Set the abort callback (passing null will restore original abort functionality: printing a message to stdout) // 设置中止回调函数（传入NULL将恢复原始中止功能：向stdout打印消息）
GGML_API ggml_abort_callback_t ggml_set_abort_callback(ggml_abort_callback_t callback) { // 设置中止回调函数
    ggml_abort_callback_t ret_val = g_abort_callback; // 保存旧的回调函数指针
    g_abort_callback = callback; // 设置新的回调函数指针
    return ret_val; // 返回旧的回调函数指针
} // ggml_set_abort_callback 函数结束

void ggml_abort(const char * file, int line, const char * fmt, ...) { // ggml中止函数，打印错误信息并终止程序
    fflush(stdout); // 刷新标准输出缓冲区

    char message[2048]; // 存储错误消息的缓冲区
    int offset = snprintf(message, sizeof(message), "%s:%d: ", file, line); // 格式化文件名和行号

    va_list args; // 可变参数列表
    va_start(args, fmt); // 初始化可变参数
    vsnprintf(message + offset, sizeof(message) - offset, fmt, args); // 格式化错误消息
    va_end(args); // 结束可变参数处理

    if (g_abort_callback) { // 如果设置了中止回调函数
        g_abort_callback(message); // 调用回调函数处理错误消息
    } else { // 否则使用默认处理
        // default: print error and backtrace to stderr // 默认行为：打印错误和回溯到标准错误
        fprintf(stderr, "%s\n", message); // 输出错误消息
        ggml_print_backtrace(); // 打印调用回溯
    } // 回调检查结束

    abort(); // 终止程序
} // ggml_abort 函数结束

// ggml_print_backtrace is registered with std::set_terminate by ggml.cpp // ggml_print_backtrace通过std::set_terminate在ggml.cpp中注册

// // 注释分隔符
// logging // 日志模块
// // 注释分隔符

struct ggml_logger_state { // 日志记录器状态结构体
    ggml_log_callback log_callback; // 日志回调函数指针
    void * log_callback_user_data; // 日志回调函数的用户数据
}; // ggml_logger_state 结构体结束
static struct ggml_logger_state g_logger_state = {ggml_log_callback_default, NULL}; // 全局日志状态，默认回调为ggml_log_callback_default

static void ggml_log_internal_v(enum ggml_log_level level, const char * format, va_list args) { // 内部日志函数（可变参数列表版本）
    if (format == NULL) { // 如果格式字符串为空
        return; // 直接返回
    } // 空检查结束
    va_list args_copy; // 可变参数的副本
    va_copy(args_copy, args); // 复制可变参数列表
    char buffer[128]; // 小型缓冲区，用于短消息
    int len = vsnprintf(buffer, 128, format, args); // 尝试格式化消息到小缓冲区
    if (len < 128) { // 如果消息适合小缓冲区
        g_logger_state.log_callback(level, buffer, g_logger_state.log_callback_user_data); // 直接使用小缓冲区调用回调
    } else { // 否则消息太长
        char * buffer2 = (char *) calloc(len + 1, sizeof(char)); // 动态分配足够的缓冲区
        vsnprintf(buffer2, len + 1, format, args_copy); // 格式化消息到大缓冲区
        buffer2[len] = 0; // 确保字符串以空字符结尾
        g_logger_state.log_callback(level, buffer2, g_logger_state.log_callback_user_data); // 使用大缓冲区调用回调
        free(buffer2); // 释放动态分配的缓冲区
    } // 缓冲区长度检查结束
    va_end(args_copy); // 结束可变参数副本的处理
} // ggml_log_internal_v 函数结束

void ggml_log_internal(enum ggml_log_level level, const char * format, ...) { // 内部日志函数（可变参数版本）
    va_list args; // 可变参数列表
    va_start(args, format); // 初始化可变参数
    ggml_log_internal_v(level, format, args); // 调用可变参数列表版本的日志函数
    va_end(args); // 结束可变参数处理
} // ggml_log_internal 函数结束

void ggml_log_callback_default(enum ggml_log_level level, const char * text, void * user_data) { // 默认日志回调函数
    (void) level; // 忽略日志级别参数
    (void) user_data; // 忽略用户数据参数
    fputs(text, stderr); // 将日志文本输出到标准错误
    fflush(stderr); // 刷新标准错误缓冲区
} // ggml_log_callback_default 函数结束

