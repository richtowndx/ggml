}

struct ggml_tensor * ggml_silu_inplace( // SiLU 激活函数的原地版本
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量，也用于存储结果
    return ggml_unary_inplace(ctx, a, GGML_UNARY_OP_SILU); // 调用通用一元原地操作接口
}

// ggml_xielu // XIELU 激活函数标记注释

struct ggml_tensor * ggml_xielu( // XIELU 激活函数实现
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 输入张量
        float alpha_n, // 负区间的 alpha 参数
        float alpha_p, // 正区间的 alpha 参数
        float beta, // beta 参数
        float eps) { // epsilon 参数，用于数值稳定性
    struct ggml_tensor * result = ggml_dup_tensor(ctx, a); // 创建与输入相同形状的结果张量

    ggml_set_op_params_i32(result, 0, (int32_t) GGML_UNARY_OP_XIELU); // 设置操作类型参数为 XIELU
    ggml_set_op_params_f32(result, 1, beta + ggml_compute_softplus_f32(alpha_n)); // 计算并设置 alpha_n 相关参数
    ggml_set_op_params_f32(result, 2, ggml_compute_softplus_f32(alpha_p)); // 计算并设置 alpha_p 相关参数
    ggml_set_op_params_f32(result, 3, beta); // 设置 beta 参数
    ggml_set_op_params_f32(result, 4, eps); // 设置 epsilon 参数

    result->op     = GGML_OP_UNARY; // 设置操作类型为一元操作
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_silu_back // SiLU 反向传播标记注释

struct ggml_tensor * ggml_silu_back( // SiLU 激活函数的反向传播（梯度计算）
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 前向传播的输入张量
        struct ggml_tensor  * b) { // 来自上层的梯度张量
    struct ggml_tensor * result = ggml_dup_tensor(ctx, a); // 创建与 a 相同形状的结果张量

    result->op     = GGML_OP_SILU_BACK; // 设置操作类型为 SiLU 反向传播
    result->src[0] = a; // 设置第一个源张量（前向输入）
    result->src[1] = b; // 设置第二个源张量（上层梯度）

    return result; // 返回结果张量
}

