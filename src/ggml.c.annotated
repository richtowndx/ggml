uint64_t ggml_graph_next_uid(void) { // 获取下一个计算图唯一标识符（原子递增）
#ifdef _MSC_VER // 如果是MSVC编译器
#if defined(_WIN32) // 如果是32位Windows
    static volatile LONG counter = 1; // 静态计数器，初始值为1
    return (uint64_t) InterlockedIncrement(&counter) - 1; // 原子递增并返回递增前的值
#else // 非32位Windows
    static volatile long long counter = 1; // 静态64位计数器，初始值为1
    return (uint64_t) _InterlockedIncrement64(&counter) - 1; // 原子递增64位计数器并返回递增前的值
#endif // _WIN32 判断结束
#else // 非MSVC编译器
    static uint64_t counter = 1; // 静态64位计数器，初始值为1
    return __atomic_fetch_add(&counter, 1, __ATOMIC_RELAXED); // 使用GCC原子操作进行宽松模式的递增
#endif // _MSC_VER 判断结束
} // ggml_graph_next_uid 函数结束

