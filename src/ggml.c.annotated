        .type_size                = sizeof(block_q4_0), // 类型大小（字节）
        .is_quantized             = true, // 是否为量化类型
        .to_float                 = (ggml_to_float_t) dequantize_row_q4_0, // 反量化函数指针
        .from_float_ref           = (ggml_from_float_t) quantize_row_q4_0_ref, // 量化参考函数指针
    }, // GGML_TYPE_Q4_0 结束
    [GGML_TYPE_Q4_1] = { // Q4_1量化类型（4位量化，方式1，带偏移）
        .type_name                = "q4_1", // 类型名称
        .blck_size                = QK4_1, // 量化块大小
        .type_size                = sizeof(block_q4_1), // 类型大小（字节）
        .is_quantized             = true, // 是否为量化类型
        .to_float                 = (ggml_to_float_t) dequantize_row_q4_1, // 反量化函数指针
        .from_float_ref           = (ggml_from_float_t) quantize_row_q4_1_ref, // 量化参考函数指针
