struct ggml_tensor * ggml_swiglu_oai(                                    // swiglu_oai：OpenAI 风格的 SiLU 门控线性单元，带 alpha 和 limit 参数
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        struct ggml_tensor  * b,                                         // 输入张量 b
        float                 alpha,                                     // alpha 缩放参数
        float                 limit) {                                   // limit 截断参数
    struct ggml_tensor * result = ggml_glu_impl(ctx, a, b, GGML_GLU_OP_SWIGLU_OAI, false); // 创建 SWIGLU_OAI 操作结果张量
    ggml_set_op_params_f32(result, 2, alpha);                            // 设置操作参数中的 alpha 值（偏移2）
    ggml_set_op_params_f32(result, 3, limit);                            // 设置操作参数中的 limit 值（偏移3）

    return result;                                                       // 返回结果张量
}

// ggml_norm                                                         // 归一化操作注释标记

static struct ggml_tensor * ggml_norm_impl(                              // 归一化操作的内部实现
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 eps,                                       // 防止除零的 epsilon 值
        bool                  inplace) {                                 // 是否原地操作标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    ggml_set_op_params(result, &eps, sizeof(eps));                       // 将 epsilon 参数写入操作参数

    result->op     = GGML_OP_NORM;                                       // 设置操作类型为 NORM
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_norm(                                          // 归一化操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 eps) {                                     // epsilon 值
    return ggml_norm_impl(ctx, a, eps, false);                           // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_norm_inplace(                                  // 归一化操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        float                 eps) {                                     // epsilon 值
    return ggml_norm_impl(ctx, a, eps, true);                            // 调用内部实现，inplace=true
}

// ggml_rms_norm                                                     // 均方根归一化操作注释标记

static struct ggml_tensor * ggml_rms_norm_impl(                          // RMS 归一化操作的内部实现
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 eps,                                       // 防止除零的 epsilon 值
        bool                  inplace) {                                 // 是否原地操作标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    ggml_set_op_params(result, &eps, sizeof(eps));                       // 将 epsilon 参数写入操作参数

    result->op     = GGML_OP_RMS_NORM;                                   // 设置操作类型为 RMS_NORM
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_rms_norm(                                      // RMS 归一化操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 eps) {                                     // epsilon 值
    return ggml_rms_norm_impl(ctx, a, eps, false);                       // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_rms_norm_inplace(                              // RMS 归一化操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        float                 eps) {                                     // epsilon 值
    return ggml_rms_norm_impl(ctx, a, eps, true);                        // 调用内部实现，inplace=true
}

// ggml_rms_norm_back                                                // RMS 归一化反向传播注释标记

struct ggml_tensor * ggml_rms_norm_back(                                 // RMS 归一化的反向传播操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 前向输入张量
        struct ggml_tensor  * b,                                         // 梯度张量
        float                 eps) {                                     // epsilon 值
    struct ggml_tensor * result = ggml_dup_tensor(ctx, a);               // 创建与 a 同形状的新张量

    ggml_set_op_params(result, &eps, sizeof(eps));                       // 将 epsilon 参数写入操作参数

    result->op     = GGML_OP_RMS_NORM_BACK;                              // 设置操作类型为 RMS_NORM_BACK
    result->src[0] = a;                                                  // 设置第一个源张量为 a
    result->src[1] = b;                                                  // 设置第二个源张量为 b

    return result;                                                       // 返回结果张量
}

// ggml_group_norm                                                   // 组归一化操作注释标记

static struct ggml_tensor * ggml_group_norm_impl(                        // 组归一化操作的内部实现
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   n_groups,                                  // 分组数量
        float                 eps,                                       // epsilon 值
        bool                  inplace) {                                 // 是否原地操作标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    ggml_set_op_params_i32(result, 0, n_groups);                         // 将分组数量写入操作参数（偏移0，int32）
    ggml_set_op_params_f32(result, 1, eps);                              // 将 epsilon 写入操作参数（偏移1，float32）

    result->op     = GGML_OP_GROUP_NORM;                                 // 设置操作类型为 GROUP_NORM
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_group_norm(                                    // 组归一化操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   n_groups,                                  // 分组数量
        float                 eps) {                                     // epsilon 值
    return ggml_group_norm_impl(ctx, a, n_groups, eps, false);           // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_group_norm_inplace(                            // 组归一化操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        int                   n_groups,                                  // 分组数量
        float                 eps) {                                     // epsilon 值
    return ggml_group_norm_impl(ctx, a, n_groups, eps, true);            // 调用内部实现，inplace=true
}

// ggml_l2_norm                                                      // L2 归一化操作注释标记

static struct ggml_tensor * ggml_l2_norm_impl(                           // L2 归一化操作的内部实现
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 eps,                                       // epsilon 值
        bool                  inplace) {                                 // 是否原地操作标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    ggml_set_op_params_f32(result, 0, eps);                              // 将 epsilon 写入操作参数（偏移0，float32）

    result->op     = GGML_OP_L2_NORM;                                    // 设置操作类型为 L2_NORM
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_l2_norm(                                       // L2 归一化操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 eps) {                                     // epsilon 值
    return ggml_l2_norm_impl(ctx, a, eps, false);                        // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_l2_norm_inplace(                               // L2 归一化操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        float                 eps) {                                     // epsilon 值
    return ggml_l2_norm_impl(ctx, a, eps, true);                         // 调用内部实现，inplace=true
}

// ggml_mul_mat                                                      // 矩阵乘法操作注释标记

static inline bool ggml_can_mul_mat(const struct ggml_tensor * t0, const struct ggml_tensor * t1) { // 判断两个张量是否可以进行矩阵乘法
    static_assert(GGML_MAX_DIMS == 4, "GGML_MAX_DIMS is not 4 - update this function"); // 静态断言：最大维度必须为4

    return (t0->ne[0]           == t1->ne[0])  &&                        // t0 和 t1 的最内维度必须相等（矩阵乘法要求）
           (t1->ne[2]%t0->ne[2] == 0)          && // verify t0 is broadcastable  // t0 的第2维必须能广播到 t1
           (t1->ne[3]%t0->ne[3] == 0);                                   // t0 的第3维必须能广播到 t1
}
// 验证 t0 可广播                                                    // 中文翻译：验证 t0 可广播

struct ggml_tensor * ggml_mul_mat(                                       // 矩阵乘法操作的公开接口
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 左操作数矩阵 a
        struct ggml_tensor  * b) {                                       // 右操作数矩阵 b
    GGML_ASSERT(ggml_can_mul_mat(a, b));                                 // 断言：a 和 b 可以进行矩阵乘法
    GGML_ASSERT(!ggml_is_transposed(a));                                 // 断言：a 不能是转置的

    const int64_t ne[4] = { a->ne[1], b->ne[1], b->ne[2], b->ne[3] };   // 结果张量的维度：[a的行数, b的行数, b的第2维, b的第3维]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建新的 F32 类型4维张量作为结果

    result->op     = GGML_OP_MUL_MAT;                                    // 设置操作类型为 MUL_MAT
    result->src[0] = a;                                                  // 设置第一个源张量为 a
    result->src[1] = b;                                                  // 设置第二个源张量为 b

    return result;                                                       // 返回结果张量
}

void ggml_mul_mat_set_prec(                                              // 设置矩阵乘法的精度
        struct ggml_tensor * a,                                          // 目标张量
        enum ggml_prec       prec) {                                     // 精度枚举值
    GGML_ASSERT(a->op == GGML_OP_MUL_MAT);                               // 断言：操作类型必须是 MUL_MAT

    const int32_t prec_i32 = (int32_t) prec;                             // 将精度枚举转换为 int32

    ggml_set_op_params_i32(a, 0, prec_i32);                              // 将精度参数写入操作参数
}

// ggml_mul_mat_id                                                   // 带ID的矩阵乘法操作注释标记

/*
    c = ggml_mul_mat_id(ctx, as, b, ids);                                // 使用示例
                                                                         // c = 使用 mul_mat_id 计算的结果
    as  -> [cols, rows, n_expert]                                         // as: 专家矩阵集合，形状为 [列数, 行数, 专家数]
    b   -> [cols, n_expert_used, n_tokens]                                // b: 输入矩阵，形状为 [列数, 使用专家数, token数]
    ids -> [n_expert_used, n_tokens] (i32)                                // ids: 专家索引矩阵，形状为 [使用专家数, token数]，类型为 I32
    c   -> [rows, n_expert_used, n_tokens]                                // c: 结果矩阵，形状为 [行数, 使用专家数, token数]
                                                                         //
    in b, n_expert_used can be broadcasted to match the n_expert_used of ids  // b 中的 n_expert_used 可以广播以匹配 ids
                                                                         //
    c ~= as[:,:,i] @ b[:,i%r,t], i = ids[e,t] for all e,t in ids        // 计算公式近似描述
*/                                                                       // 注释块结束
struct ggml_tensor * ggml_mul_mat_id(                                    // 带专家ID的矩阵乘法操作（用于混合专家模型 MoE）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * as,                                        // 专家矩阵集合张量
        struct ggml_tensor  * b,                                         // 输入张量 b
        struct ggml_tensor  * ids) {                                     // 专家ID索引张量
    GGML_ASSERT(!ggml_is_transposed(as));                                 // 断言：as 不能是转置的
    GGML_ASSERT(ids->type == GGML_TYPE_I32);                             // 断言：ids 的类型必须是 I32

    GGML_ASSERT(as->ne[3] == 1); // as is 3d (one matrix per expert)    // 断言：as 的第3维为1，即 as 是3维张量（每个专家一个矩阵）
    GGML_ASSERT(b->ne[3] == 1); // b is 3d                              // 断言：b 的第3维为1，即 b 是3维张量
    GGML_ASSERT(ids->ne[2] == 1 && ids->ne[3] == 1); // ids is 2d       // 断言：ids 的第2和第3维都为1，即 ids 是2维张量
    GGML_ASSERT(ids->ne[1] == b->ne[2]); // must have an expert list per b row  // 断言：ids 的行数必须等于 b 的第2维
    GGML_ASSERT(as->ne[0] == b->ne[0]); // can_mul_mat                  // 断言：as 和 b 的最内维度必须相等（矩阵乘法要求）
    GGML_ASSERT(ids->ne[0] % b->ne[1] == 0); // can broadcast           // 断言：ids 的第0维必须能广播到 b 的第1维
// as 是3维的（每个专家一个矩阵）                                      // 中文翻译
// b 是3维的                                                          // 中文翻译
// ids 是2维的                                                        // 中文翻译
// 每个 b 的行必须有一个专家列表                                      // 中文翻译
// 可进行矩阵乘法                                                     // 中文翻译
// 可广播                                                             // 中文翻译

    const int64_t ne[4] = { as->ne[1], ids->ne[0], b->ne[2], 1 };       // 结果张量的维度：[as的行数, ids的第0维, b的第2维, 1]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建新的 F32 类型4维张量作为结果

    result->op     = GGML_OP_MUL_MAT_ID;                                 // 设置操作类型为 MUL_MAT_ID
    result->src[0] = as;                                                 // 设置第一个源张量为 as（专家矩阵）
    result->src[1] = b;                                                  // 设置第二个源张量为 b（输入）
    result->src[2] = ids;                                                // 设置第三个源张量为 ids（专家索引）

    return result;                                                       // 返回结果张量
}

// ggml_out_prod                                                      // 外积操作注释标记

static inline bool ggml_can_out_prod(const struct ggml_tensor * t0, const struct ggml_tensor * t1) { // 判断两个张量是否可以计算外积
    static_assert(GGML_MAX_DIMS == 4, "GGML_MAX_DIMS is not 4 - update this function"); // 静态断言：最大维度必须为4

    return (t0->ne[1] == t1->ne[1])   &&                                // t0 和 t1 的第1维必须相等
           (t1->ne[2]%t0->ne[2] == 0) && // verify t0 is broadcastable  // t0 的第2维必须能广播到 t1
           (t1->ne[3]%t0->ne[3] == 0);                                   // t0 的第3维必须能广播到 t1
}
// 验证 t0 可广播                                                    // 中文翻译：验证 t0 可广播

struct ggml_tensor * ggml_out_prod(                                      // 外积操作的公开接口
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        struct ggml_tensor  * b) {                                       // 输入张量 b
    GGML_ASSERT(ggml_can_out_prod(a, b));                                // 断言：a 和 b 可以计算外积
    GGML_ASSERT(!ggml_is_transposed(a));                                 // 断言：a 不能是转置的

    // a is broadcastable to b for ne[2] and ne[3] -> use b->ne[2] and b->ne[3]  // a 在第2和第3维可广播到 b，因此使用 b 的维度
    const int64_t ne[4] = { a->ne[0], b->ne[0], b->ne[2], b->ne[3] };   // 结果维度：[a的第0维, b的第0维, b的第2维, b的第3维]
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建新的 F32 类型4维张量作为结果

    result->op     = GGML_OP_OUT_PROD;                                   // 设置操作类型为 OUT_PROD
    result->src[0] = a;                                                  // 设置第一个源张量为 a
    result->src[1] = b;                                                  // 设置第二个源张量为 b

    return result;                                                       // 返回结果张量
}

// ggml_scale                                                        // 缩放操作注释标记

static struct ggml_tensor * ggml_scale_impl(                             // 缩放操作的内部实现（支持偏置）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 s,                                         // 缩放因子
        float                 b,                                         // 偏置值
        bool                  inplace) {                                 // 是否原地操作标志
    GGML_ASSERT(ggml_is_padded_1d(a));                                   // 断言：a 必须是填充的1维张量

    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    float params[2] = { s, b };                                          // 参数数组：[缩放因子, 偏置值]
    ggml_set_op_params(result, &params, sizeof(params));                  // 将参数写入操作参数

    result->op     = GGML_OP_SCALE;                                      // 设置操作类型为 SCALE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_scale(                                         // 缩放操作的公开接口（非原地，无偏置）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 s) {                                       // 缩放因子
    return ggml_scale_impl(ctx, a, s, 0.0, false);                       // 调用内部实现，偏置为0，inplace=false
}

struct ggml_tensor * ggml_scale_inplace(                                 // 缩放操作的原地版本（无偏置）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        float                 s) {                                       // 缩放因子
    return ggml_scale_impl(ctx, a, s, 0.0, true);                        // 调用内部实现，偏置为0，inplace=true
}

struct ggml_tensor * ggml_scale_bias(                                    // 带偏置的缩放操作（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        float                 s,                                         // 缩放因子
        float                 b) {                                       // 偏置值
    return ggml_scale_impl(ctx, a, s, b, false);                         // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_scale_bias_inplace(                            // 带偏置的缩放操作（原地版本）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        float                 s,                                         // 缩放因子
        float                 b) {                                       // 偏置值
    return ggml_scale_impl(ctx, a, s, b, true);                          // 调用内部实现，inplace=true
}

// ggml_set                                                          // 集合（写入子张量）操作注释标记

static struct ggml_tensor * ggml_set_impl(                               // set 操作的内部实现：将 b 写入 a 的指定位置
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a
        struct ggml_tensor  * b,                                         // 源张量 b（要写入的数据）
        size_t                nb1,                                       // 第1维的字节步长
        size_t                nb2,                                       // 第2维的字节步长
        size_t                nb3,                                       // 第3维的字节步长
        size_t                offset,                                    // 起始偏移量（字节）
        bool                  inplace) {                                 // 是否原地操作标志
    GGML_ASSERT(ggml_nelements(a) >= ggml_nelements(b));                 // 断言：a 的元素数必须 >= b 的元素数

    // make a view of the destination                                    // 创建目标张量的视图
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    GGML_ASSERT(offset < (size_t)(1 << 30));                             // 断言：偏移量必须小于 2^30（约1GB）
    int32_t params[] = { nb1, nb2, nb3, offset, inplace ? 1 : 0 };      // 操作参数数组：步长、偏移量、原地标志
    ggml_set_op_params(result, params, sizeof(params));                   // 将参数写入操作参数

    result->op     = GGML_OP_SET;                                        // 设置操作类型为 SET
    result->src[0] = a;                                                  // 设置第一个源张量为 a（目标）
    result->src[1] = b;                                                  // 设置第二个源张量为 b（源数据）

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_set(                                           // set 操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a
        struct ggml_tensor  * b,                                         // 源张量 b
        size_t                nb1,                                       // 第1维字节步长
        size_t                nb2,                                       // 第2维字节步长
        size_t                nb3,                                       // 第3维字节步长
        size_t                offset) {                                  // 起始偏移量
    return ggml_set_impl(ctx, a, b, nb1, nb2, nb3, offset, false);       // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_set_inplace(                                   // set 操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a（结果将覆盖此张量）
        struct ggml_tensor  * b,                                         // 源张量 b
        size_t                nb1,                                       // 第1维字节步长
        size_t                nb2,                                       // 第2维字节步长
        size_t                nb3,                                       // 第3维字节步长
        size_t                offset) {                                  // 起始偏移量
    return ggml_set_impl(ctx, a, b, nb1, nb2, nb3, offset, true);        // 调用内部实现，inplace=true
}

struct ggml_tensor * ggml_set_1d(                                        // 1维 set 操作（非原地）：使用 a 自身的步长
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a
        struct ggml_tensor  * b,                                         // 源张量 b
        size_t                offset) {                                  // 起始偏移量
    return ggml_set_impl(ctx, a, b, a->nb[1], a->nb[2], a->nb[3], offset, false); // 使用 a 的步长调用内部实现
}

struct ggml_tensor * ggml_set_1d_inplace(                                // 1维 set 操作（原地版本）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a（结果将覆盖此张量）
        struct ggml_tensor  * b,                                         // 源张量 b
        size_t                offset) {                                  // 起始偏移量
    return ggml_set_impl(ctx, a, b, a->nb[1], a->nb[2], a->nb[3], offset, true); // 使用 a 的步长调用内部实现
}

struct ggml_tensor * ggml_set_2d(                                        // 2维 set 操作（非原地）：自定义 nb1 步长
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a
        struct ggml_tensor  * b,                                         // 源张量 b
        size_t                nb1,                                       // 第1维自定义字节步长
        size_t                offset) {                                  // 起始偏移量
    return ggml_set_impl(ctx, a, b, nb1, a->nb[2], a->nb[3], offset, false); // 使用自定义 nb1，其余用 a 的步长
}

struct ggml_tensor * ggml_set_2d_inplace(                                // 2维 set 操作（原地版本）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a（结果将覆盖此张量）
        struct ggml_tensor  * b,                                         // 源张量 b
        size_t                nb1,                                       // 第1维自定义字节步长
        size_t                offset) {                                  // 起始偏移量
    return ggml_set_impl(ctx, a, b, nb1, a->nb[2], a->nb[3], offset, true); // 使用自定义 nb1，其余用 a 的步长
}

// ggml_cpy                                                          // 拷贝操作注释标记

static struct ggml_tensor * ggml_cpy_impl(                               // 拷贝操作的内部实现：将 a 拷贝到 b
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        struct ggml_tensor  * b) {                                       // 目标张量 b
    GGML_ASSERT(ggml_nelements(a) == ggml_nelements(b));                 // 断言：a 和 b 的元素数必须相等

    // make a view of the destination                                    // 创建目标张量的视图
    struct ggml_tensor * result = ggml_view_tensor(ctx, b);              // 创建 b 的视图作为结果
    if (strlen(b->name) > 0) {                                           // 如果 b 有名称
        ggml_format_name(result, "%s (copy of %s)", b->name, a->name);   // 格式化名称为 "b的名称 (copy of a的名称)"
    } else {                                                             // 否则
        ggml_format_name(result, "%s (copy)", a->name);                  // 格式化名称为 "a的名称 (copy)"
    }

    result->op     = GGML_OP_CPY;                                        // 设置操作类型为 CPY
    result->src[0] = a;                                                  // 设置第一个源张量为 a（源）
    result->src[1] = b;                                                  // 设置第二个源张量为 b（目标）

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_cpy(                                           // 拷贝操作的公开接口
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor * a,                                          // 源张量 a
        struct ggml_tensor * b) {                                        // 目标张量 b
    return ggml_cpy_impl(ctx, a, b);                                     // 调用内部实现
}

struct ggml_tensor * ggml_cast(                                          // 类型转换操作：将 a 转换为指定类型
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        enum   ggml_type      type) {                                    // 目标数据类型
    struct ggml_tensor * result = ggml_new_tensor(ctx, type, GGML_MAX_DIMS, a->ne); // 创建新类型的新张量，形状与 a 相同
    ggml_format_name(result, "%s (copy)", a->name);                      // 格式化名称

    result->op     = GGML_OP_CPY;                                        // 设置操作类型为 CPY（复用拷贝操作）
    result->src[0] = a;                                                  // 设置第一个源张量为 a
    result->src[1] = result; // note: this self-reference might seem redundant, but it's actually needed by some  // 自引用：看起来多余，但某些后端需要
                             //       backends for consistency with ggml_cpy_impl() above                 // 为了与上面的 ggml_cpy_impl 保持一致

    return result;                                                       // 返回结果张量
}
// 注意：这个自引用看起来可能多余，但实际上某些后端需要它                   // 中文翻译
// 为了与上面的 ggml_cpy_impl() 保持一致性                                // 中文翻译

// ggml_cont                                                         // 连续化操作注释标记

static struct ggml_tensor * ggml_cont_impl(                              // 连续化操作的内部实现：创建连续内存布局的副本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a) {                                       // 输入张量 a
    struct ggml_tensor * result = ggml_dup_tensor(ctx, a);               // 复制张量结构（不复制数据）
    ggml_format_name(result, "%s (cont)", a->name);                      // 格式化名称为 "a的名称 (cont)"

    result->op     = GGML_OP_CONT;                                       // 设置操作类型为 CONT
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_cont(                                          // 连续化操作的公开接口
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor * a) {                                        // 输入张量 a
    return ggml_cont_impl(ctx, a);                                       // 调用内部实现
}

// make contiguous, with new shape                                     // 创建连续内存布局，使用新形状
GGML_API struct ggml_tensor * ggml_cont_1d(                              // 1维连续化操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0) {                                     // 新的第0维度大小
    return ggml_cont_4d(ctx, a, ne0, 1, 1, 1);                          // 委托给 4维版本，其余维度为1
}

GGML_API struct ggml_tensor * ggml_cont_2d(                              // 2维连续化操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0,                                       // 新的第0维度大小
        int64_t               ne1) {                                     // 新的第1维度大小
    return ggml_cont_4d(ctx, a, ne0, ne1, 1, 1);                        // 委托给 4维版本，其余维度为1
}

GGML_API struct ggml_tensor * ggml_cont_3d(                              // 3维连续化操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0,                                       // 新的第0维度大小
        int64_t               ne1,                                       // 新的第1维度大小
        int64_t               ne2) {                                     // 新的第2维度大小
    return ggml_cont_4d(ctx, a, ne0, ne1, ne2, 1);                      // 委托给 4维版本，第3维度为1
}

struct ggml_tensor * ggml_cont_4d(                                       // 4维连续化操作：创建连续内存布局并指定新的4维形状
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0,                                       // 新的第0维度大小
        int64_t               ne1,                                       // 新的第1维度大小
        int64_t               ne2,                                       // 新的第2维度大小
        int64_t               ne3) {                                     // 新的第3维度大小
    GGML_ASSERT(ggml_nelements(a) == (ne0*ne1*ne2*ne3));                 // 断言：元素总数必须匹配

    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, a->type, ne0, ne1, ne2, ne3); // 创建新形状的4维张量
    ggml_format_name(result, "%s (cont)", a->name);                      // 格式化名称

    result->op     = GGML_OP_CONT;                                       // 设置操作类型为 CONT
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

// ggml_reshape                                                      // 重塑操作注释标记

struct ggml_tensor * ggml_reshape(                                       // 重塑操作：使用另一个张量 b 的形状重塑 a
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor * a,                                          // 输入张量 a
        struct ggml_tensor * b) {                                        // 形状参考张量 b
    GGML_ASSERT(ggml_is_contiguous(a));                                  // 断言：a 必须是连续的
    // as only the shape of b is relevant, and not its memory layout, b is allowed to be non contiguous.  // 只使用 b 的形状，不关心其内存布局，因此 b 可以不连续
    GGML_ASSERT(ggml_nelements(a) == ggml_nelements(b));                 // 断言：a 和 b 的元素数必须相等
// 因为只使用 b 的形状而不关心其内存布局，所以 b 允许不连续             // 中文翻译

    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, GGML_MAX_DIMS, b->ne, a, 0); // 创建新张量，使用 b 的形状，共享 a 的数据
    ggml_format_name(result, "%s (reshaped)", a->name);                  // 格式化名称

    result->op     = GGML_OP_RESHAPE;                                    // 设置操作类型为 RESHAPE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_reshape_1d(                                    // 1维重塑操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0) {                                     // 新的第0维度大小
    GGML_ASSERT(ggml_is_contiguous(a));                                  // 断言：a 必须是连续的
    GGML_ASSERT(ggml_nelements(a) == ne0);                               // 断言：元素数必须等于 ne0

    const int64_t ne[1] = { ne0 };                                       // 1维形状数组
    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, 1, ne, a, 0); // 创建1维新张量，共享 a 的数据
    ggml_format_name(result, "%s (reshaped)", a->name);                  // 格式化名称

    result->op     = GGML_OP_RESHAPE;                                    // 设置操作类型为 RESHAPE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_reshape_2d(                                    // 2维重塑操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0,                                       // 新的第0维度大小
        int64_t               ne1) {                                     // 新的第1维度大小
    GGML_ASSERT(ggml_is_contiguous(a));                                  // 断言：a 必须是连续的
    GGML_ASSERT(ggml_nelements(a) == ne0*ne1);                           // 断言：元素数必须等于 ne0*ne1

    const int64_t ne[2] = { ne0, ne1 };                                  // 2维形状数组
    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, 2, ne, a, 0); // 创建2维新张量，共享 a 的数据
    ggml_format_name(result, "%s (reshaped)", a->name);                  // 格式化名称

    result->op     = GGML_OP_RESHAPE;                                    // 设置操作类型为 RESHAPE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_reshape_3d(                                    // 3维重塑操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0,                                       // 新的第0维度大小
        int64_t               ne1,                                       // 新的第1维度大小
        int64_t               ne2) {                                     // 新的第2维度大小
    GGML_ASSERT(ggml_is_contiguous(a));                                  // 断言：a 必须是连续的
    GGML_ASSERT(ggml_nelements(a) == ne0*ne1*ne2);                       // 断言：元素数必须等于 ne0*ne1*ne2

    const int64_t ne[3] = { ne0, ne1, ne2 };                             // 3维形状数组
    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, 3, ne, a, 0); // 创建3维新张量，共享 a 的数据
    ggml_format_name(result, "%s (reshaped)", a->name);                  // 格式化名称

    result->op     = GGML_OP_RESHAPE;                                    // 设置操作类型为 RESHAPE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_reshape_4d(                                    // 4维重塑操作
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int64_t               ne0,                                       // 新的第0维度大小
        int64_t               ne1,                                       // 新的第1维度大小
        int64_t               ne2,                                       // 新的第2维度大小
        int64_t               ne3) {                                     // 新的第3维度大小
    GGML_ASSERT(ggml_is_contiguous(a));                                  // 断言：a 必须是连续的
    GGML_ASSERT(ggml_nelements(a) == ne0*ne1*ne2*ne3);                   // 断言：元素数必须等于 ne0*ne1*ne2*ne3

    const int64_t ne[4] = { ne0, ne1, ne2, ne3 };                        // 4维形状数组
    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, 4, ne, a, 0); // 创建4维新张量，共享 a 的数据
    ggml_format_name(result, "%s (reshaped)", a->name);                  // 格式化名称

    result->op     = GGML_OP_RESHAPE;                                    // 设置操作类型为 RESHAPE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

static struct ggml_tensor * ggml_view_impl(                              // 视图操作的内部实现：创建张量的视图（共享底层数据）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        int                   n_dims,                                    // 视图的维度数
        const int64_t       * ne,                                        // 视图的形状数组
        size_t                offset) {                                  // 数据偏移量（字节）
    struct ggml_tensor * result = ggml_new_tensor_impl(ctx, a->type, n_dims, ne, a, offset); // 创建新张量视图，共享 a 的数据
    ggml_format_name(result, "%s (view)", a->name);                      // 格式化名称

    ggml_set_op_params(result, &offset, sizeof(offset));                  // 将偏移量写入操作参数

    result->op     = GGML_OP_VIEW;                                       // 设置操作类型为 VIEW
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

// ggml_view_1d                                                      // 1维视图操作注释标记

struct ggml_tensor * ggml_view_1d(                                       // 1维视图操作：创建1维视图
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        int64_t               ne0,                                       // 视图的第0维度大小
        size_t                offset) {                                  // 数据偏移量（字节）
    struct ggml_tensor * result = ggml_view_impl(ctx, a, 1, &ne0, offset); // 调用内部实现，1维

    return result;                                                       // 返回结果张量
}

// ggml_view_2d                                                      // 2维视图操作注释标记

struct ggml_tensor * ggml_view_2d(                                       // 2维视图操作：创建2维视图
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        int64_t               ne0,                                       // 视图的第0维度大小
        int64_t               ne1,                                       // 视图的第1维度大小
        size_t                nb1,                                       // 第1维的自定义字节步长
        size_t                offset) {                                  // 数据偏移量（字节）
    const int64_t ne[2] = { ne0, ne1 };                                  // 2维形状数组

    struct ggml_tensor * result = ggml_view_impl(ctx, a, 2, ne, offset); // 调用内部实现，2维

    result->nb[1] = nb1;                                                 // 设置第1维字节步长
    result->nb[2] = result->nb[1]*ne1;                                   // 计算第2维字节步长 = nb1 * ne1
    result->nb[3] = result->nb[2];                                       // 第3维字节步长等于第2维

    return result;                                                       // 返回结果张量
}

// ggml_view_3d                                                      // 3维视图操作注释标记

struct ggml_tensor * ggml_view_3d(                                       // 3维视图操作：创建3维视图
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        int64_t               ne0,                                       // 视图的第0维度大小
        int64_t               ne1,                                       // 视图的第1维度大小
        int64_t               ne2,                                       // 视图的第2维度大小
        size_t                nb1,                                       // 第1维的自定义字节步长
        size_t                nb2,                                       // 第2维的自定义字节步长
        size_t                offset) {                                  // 数据偏移量（字节）
    const int64_t ne[3] = { ne0, ne1, ne2 };                             // 3维形状数组

    struct ggml_tensor * result = ggml_view_impl(ctx, a, 3, ne, offset); // 调用内部实现，3维

    result->nb[1] = nb1;                                                 // 设置第1维字节步长
    result->nb[2] = nb2;                                                 // 设置第2维字节步长
    result->nb[3] = result->nb[2]*ne2;                                   // 计算第3维字节步长 = nb2 * ne2

    return result;                                                       // 返回结果张量
}

// ggml_view_4d                                                      // 4维视图操作注释标记

struct ggml_tensor * ggml_view_4d(                                       // 4维视图操作：创建4维视图
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 源张量 a
        int64_t               ne0,                                       // 视图的第0维度大小
        int64_t               ne1,                                       // 视图的第1维度大小
        int64_t               ne2,                                       // 视图的第2维度大小
        int64_t               ne3,                                       // 视图的第3维度大小
        size_t                nb1,                                       // 第1维的自定义字节步长
        size_t                nb2,                                       // 第2维的自定义字节步长
        size_t                nb3,                                       // 第3维的自定义字节步长
        size_t                offset) {                                  // 数据偏移量（字节）
    const int64_t ne[4] = { ne0, ne1, ne2, ne3 };                        // 4维形状数组

    struct ggml_tensor * result = ggml_view_impl(ctx, a, 4, ne, offset); // 调用内部实现，4维

    result->nb[1] = nb1;                                                 // 设置第1维字节步长
    result->nb[2] = nb2;                                                 // 设置第2维字节步长
    result->nb[3] = nb3;                                                 // 设置第3维字节步长

    return result;                                                       // 返回结果张量
}

// ggml_permute                                                      // 维度排列操作注释标记

struct ggml_tensor * ggml_permute(                                       // 维度排列操作：重新排列张量的维度顺序
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   axis0,                                     // 原第0维映射到的新位置
        int                   axis1,                                     // 原第1维映射到的新位置
        int                   axis2,                                     // 原第2维映射到的新位置
        int                   axis3) {                                   // 原第3维映射到的新位置
    GGML_ASSERT(axis0 >= 0 && axis0 < GGML_MAX_DIMS);                    // 断言：axis0 在合法范围内
    GGML_ASSERT(axis1 >= 0 && axis1 < GGML_MAX_DIMS);                    // 断言：axis1 在合法范围内
    GGML_ASSERT(axis2 >= 0 && axis2 < GGML_MAX_DIMS);                    // 断言：axis2 在合法范围内
    GGML_ASSERT(axis3 >= 0 && axis3 < GGML_MAX_DIMS);                    // 断言：axis3 在合法范围内

    GGML_ASSERT(axis0 != axis1);                                         // 断言：所有轴必须不同
    GGML_ASSERT(axis0 != axis2);                                         // 断言：axis0 不等于 axis2
    GGML_ASSERT(axis0 != axis3);                                         // 断言：axis0 不等于 axis3
    GGML_ASSERT(axis1 != axis2);                                         // 断言：axis1 不等于 axis2
    GGML_ASSERT(axis1 != axis3);                                         // 断言：axis1 不等于 axis3
    GGML_ASSERT(axis2 != axis3);                                         // 断言：axis2 不等于 axis3

    struct ggml_tensor * result = ggml_view_tensor(ctx, a);              // 创建 a 的视图（共享数据）
    ggml_format_name(result, "%s (permuted)", a->name);                  // 格式化名称

    int ne[GGML_MAX_DIMS];                                               // 临时数组：存储排列后的维度大小
    int nb[GGML_MAX_DIMS];                                               // 临时数组：存储排列后的字节步长

    ne[axis0] = a->ne[0];                                                // 将原第0维放到 axis0 指定的位置
    ne[axis1] = a->ne[1];                                                // 将原第1维放到 axis1 指定的位置
    ne[axis2] = a->ne[2];                                                // 将原第2维放到 axis2 指定的位置
    ne[axis3] = a->ne[3];                                                // 将原第3维放到 axis3 指定的位置

    nb[axis0] = a->nb[0];                                                // 将原第0维步长放到 axis0 指定的位置
    nb[axis1] = a->nb[1];                                                // 将原第1维步长放到 axis1 指定的位置
    nb[axis2] = a->nb[2];                                                // 将原第2维步长放到 axis2 指定的位置
    nb[axis3] = a->nb[3];                                                // 将原第3维步长放到 axis3 指定的位置

    result->ne[0] = ne[0];                                               // 设置结果的第0维度大小
    result->ne[1] = ne[1];                                               // 设置结果的第1维度大小
    result->ne[2] = ne[2];                                               // 设置结果的第2维度大小
    result->ne[3] = ne[3];                                               // 设置结果的第3维度大小

    result->nb[0] = nb[0];                                               // 设置结果的第0维字节步长
    result->nb[1] = nb[1];                                               // 设置结果的第1维字节步长
    result->nb[2] = nb[2];                                               // 设置结果的第2维字节步长
    result->nb[3] = nb[3];                                               // 设置结果的第3维字节步长

    result->op     = GGML_OP_PERMUTE;                                    // 设置操作类型为 PERMUTE
    result->src[0] = a;                                                  // 设置源张量为 a

    int32_t params[] = { axis0, axis1, axis2, axis3 };                    // 排列参数数组
    ggml_set_op_params(result, params, sizeof(params));                   // 将排列参数写入操作参数

    return result;                                                       // 返回结果张量
}

// ggml_transpose                                                    // 转置操作注释标记

struct ggml_tensor * ggml_transpose(                                     // 转置操作：交换张量的前两个维度
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a) {                                       // 输入张量 a
    struct ggml_tensor * result = ggml_view_tensor(ctx, a);              // 创建 a 的视图（共享数据）
    ggml_format_name(result, "%s (transposed)", a->name);                // 格式化名称

    result->ne[0] = a->ne[1];                                            // 交换：结果的第0维 = a 的第1维
    result->ne[1] = a->ne[0];                                            // 交换：结果的第1维 = a 的第0维

    result->nb[0] = a->nb[1];                                            // 交换步长：结果的第0维步长 = a 的第1维步长
    result->nb[1] = a->nb[0];                                            // 交换步长：结果的第1维步长 = a 的第0维步长

    result->op     = GGML_OP_TRANSPOSE;                                  // 设置操作类型为 TRANSPOSE
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

// ggml_get_rows                                                     // 获取行操作注释标记

struct ggml_tensor * ggml_get_rows(                                      // 获取行操作：根据索引张量 b 从 a 中选取行
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（数据源）
        struct ggml_tensor  * b) {                                       // 索引张量 b（I32类型的行索引）
    GGML_ASSERT(a->ne[2] == b->ne[1]);                                   // 断言：a 的第2维等于 b 的第1维
    GGML_ASSERT(a->ne[3] == b->ne[2]);                                   // 断言：a 的第3维等于 b 的第2维
    GGML_ASSERT(b->ne[3] == 1);                                          // 断言：b 的第3维必须为1
    GGML_ASSERT(b->type == GGML_TYPE_I32);                               // 断言：b 的类型必须是 I32

    // TODO: implement non F32 return                                    // 待办：实现非 F32 返回类型
    enum ggml_type type = GGML_TYPE_F32;                                 // 默认返回 F32 类型
    if (a->type == GGML_TYPE_I32) {                                      // 如果 a 的类型是 I32
        type = a->type;                                                  // 则返回类型也设为 I32
    }
    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, type, a->ne[0], b->ne[0], b->ne[1], b->ne[2]); // 创建4维结果张量

    result->op     = GGML_OP_GET_ROWS;                                   // 设置操作类型为 GET_ROWS
    result->src[0] = a;                                                  // 设置第一个源张量为 a
    result->src[1] = b;                                                  // 设置第二个源张量为 b

    return result;                                                       // 返回结果张量
}

// ggml_get_rows_back                                                // 获取行反向传播操作注释标记

struct ggml_tensor * ggml_get_rows_back(                                 // 获取行操作的反向传播
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 前向传播的输出梯度
        struct ggml_tensor  * b,                                         // 索引张量（I32类型）
        struct ggml_tensor  * c) {                                       // 形状参考张量
    GGML_ASSERT(ggml_is_matrix(a) && ggml_is_vector(b) && b->type == GGML_TYPE_I32); // 断言：a 是矩阵，b 是 I32 向量
    GGML_ASSERT(ggml_is_matrix(c) && (a->ne[0] == c->ne[0]));            // 断言：c 是矩阵且与 a 的列数相同

    // TODO: implement non F32 return                                    // 待办：实现非 F32 返回类型
    //struct ggml_tensor * result = ggml_new_tensor_2d(ctx, a->type, a->ne[0], b->ne[0]);  // 注释掉的替代实现
    struct ggml_tensor * result = ggml_new_tensor_2d(ctx, GGML_TYPE_F32, c->ne[0], c->ne[1]); // 创建 F32 类型2维结果张量

    result->op     = GGML_OP_GET_ROWS_BACK;                              // 设置操作类型为 GET_ROWS_BACK
    result->src[0] = a;                                                  // 设置第一个源张量为 a
    result->src[1] = b;                                                  // 设置第二个源张量为 b

    return result;                                                       // 返回结果张量
}

// ggml_set_rows                                                     // 设置行操作注释标记

struct ggml_tensor * ggml_set_rows(                                      // 设置行操作：根据索引张量 c 将 b 的行写入 a
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 目标张量 a
        struct ggml_tensor  * b,                                         // 源数据张量 b
        struct ggml_tensor  * c) {                                       // 行索引张量 c（I32 或 I64 类型）
    GGML_ASSERT(a->ne[0] == b->ne[0]);                                   // 断言：a 和 b 的第0维必须相等
    GGML_ASSERT(a->ne[2] == b->ne[2]);                                   // 断言：a 和 b 的第2维必须相等
    GGML_ASSERT(a->ne[3] == b->ne[3]);                                   // 断言：a 和 b 的第3维必须相等
    GGML_ASSERT(b->ne[1] == c->ne[0]);                                   // 断言：b 的第1维等于 c 的第0维
    GGML_ASSERT(b->ne[2] % c->ne[1] == 0);                               // 断言：b 的第2维必须能被 c 的第1维整除
    GGML_ASSERT(b->ne[3] % c->ne[2] == 0);                               // 断言：b 的第3维必须能被 c 的第2维整除
    GGML_ASSERT(c->ne[3] == 1);                                          // 断言：c 的第3维必须为1
    GGML_ASSERT(b->type == GGML_TYPE_F32);                               // 断言：b 的类型必须是 F32
    GGML_ASSERT(c->type == GGML_TYPE_I64 || c->type == GGML_TYPE_I32);   // 断言：c 的类型必须是 I64 或 I32

    GGML_ASSERT(ggml_is_contiguous_rows(a));                             // 断言：a 必须是行连续的
    GGML_ASSERT(ggml_is_contiguous_rows(b));                             // 断言：b 必须是行连续的

    struct ggml_tensor * result = ggml_view_tensor(ctx, a);              // 创建 a 的视图作为结果

    result->op     = GGML_OP_SET_ROWS;                                   // 设置操作类型为 SET_ROWS
    result->src[0] = b;                                                  // 设置第一个源张量为 b（源数据）
    result->src[1] = c;                                                  // 设置第二个源张量为 c（行索引）
    result->src[2] = a; // note: order is weird due to legacy reasons (https://github.com/ggml-org/llama.cpp/pull/16063#discussion_r2385795931)  // 注意：顺序因历史原因较奇怪

    return result;                                                       // 返回结果张量
}
// 注意：源张量的顺序因历史遗留原因较奇怪                              // 中文翻译
// 详见 https://github.com/ggml-org/llama.cpp/pull/16063#discussion_r2385795931  // 中文翻译

// ggml_diag                                                         // 对角线操作注释标记

struct ggml_tensor * ggml_diag(                                          // 对角线操作：将向量扩展为对角矩阵
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a) {                                       // 输入向量张量 a
    GGML_ASSERT(a->ne[1] == 1);                                          // 断言：a 的第1维必须为1（即 a 是向量）

    const int64_t ne[4] = { a->ne[0], a->ne[0], a->ne[2], a->ne[3] };   // 结果形状：N x N 矩阵（对角线）
    struct ggml_tensor * result = ggml_new_tensor(ctx, a->type, 4, ne);  // 创建新张量

    result->op     = GGML_OP_DIAG;                                       // 设置操作类型为 DIAG
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

// ggml_diag_mask_inf                                                // 对角无穷掩码操作注释标记

static struct ggml_tensor * ggml_diag_mask_inf_impl(                     // 对角无穷掩码的内部实现
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   n_past,                                    // 过去的 token 数量（用于因果掩码）
        bool                  inplace) {                                 // 是否原地操作标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    int32_t params[] = { n_past };                                       // 操作参数：过去的 token 数量
    ggml_set_op_params(result, params, sizeof(params));                   // 将参数写入操作参数

    result->op     = GGML_OP_DIAG_MASK_INF;                              // 设置操作类型为 DIAG_MASK_INF
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_diag_mask_inf(                                 // 对角无穷掩码操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   n_past) {                                  // 过去的 token 数量
    return ggml_diag_mask_inf_impl(ctx, a, n_past, false);               // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_diag_mask_inf_inplace(                         // 对角无穷掩码操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        int                   n_past) {                                  // 过去的 token 数量
    return ggml_diag_mask_inf_impl(ctx, a, n_past, true);                // 调用内部实现，inplace=true
}

// ggml_diag_mask_zero                                               // 对角零掩码操作注释标记

static struct ggml_tensor * ggml_diag_mask_zero_impl(                    // 对角零掩码的内部实现
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   n_past,                                    // 过去的 token 数量（用于因果掩码）
        bool                  inplace) {                                 // 是否原地操作标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    int32_t params[] = { n_past };                                       // 操作参数：过去的 token 数量
    ggml_set_op_params(result, params, sizeof(params));                   // 将参数写入操作参数

    result->op     = GGML_OP_DIAG_MASK_ZERO;                             // 设置操作类型为 DIAG_MASK_ZERO
    result->src[0] = a;                                                  // 设置源张量为 a

    return result;                                                       // 返回结果张量
}

struct ggml_tensor * ggml_diag_mask_zero(                                // 对角零掩码操作的公开接口（非原地）
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a
        int                   n_past) {                                  // 过去的 token 数量
    return ggml_diag_mask_zero_impl(ctx, a, n_past, false);              // 调用内部实现，inplace=false
}

struct ggml_tensor * ggml_diag_mask_zero_inplace(                        // 对角零掩码操作的原地版本
        struct ggml_context * ctx,                                       // ggml 上下文指针
        struct ggml_tensor  * a,                                         // 输入张量 a（结果将覆盖此张量）
        int                   n_past) {                                  // 过去的 token 数量
    return ggml_diag_mask_zero_impl(ctx, a, n_past, true);               // 调用内部实现，inplace=true
}

// ggml_soft_max                                                     // softmax 操作注释标记

static struct ggml_tensor * ggml_soft_max_impl(                          // softmax 操作的内部实现（第4000行开始）
        struct ggml_context * ctx,                                       // ggml 上下文指针
/* 中文注释版本 - ggml.c 第4000-5000行 */
/* 本部分涵盖: softmax 操作、RoPE(旋转位置编码)、clamp、卷积操作(1D/2D/3D)、im2col、池化操作、上采样/插值 */

        struct ggml_context * ctx,                // 上下文指针，用于内存管理 / context pointer for memory management
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * mask,               // 掩码张量 / mask tensor
        float                 scale,              // 缩放因子 / scale factor
        float                 max_bias,           // 最大偏置（用于ALiBi等） / max bias (used in ALiBi etc.)
        bool                  inplace) {          // 是否原地操作 / whether to operate in-place
    GGML_ASSERT(ggml_is_contiguous(a));           // 断言：输入张量必须是连续的 / assert: input tensor must be contiguous

    if (mask) {                                    // 如果提供了掩码 / if mask is provided
        GGML_ASSERT(mask->type == GGML_TYPE_F16 || mask->type == GGML_TYPE_F32); // 掩码类型必须是F16或F32 / mask type must be F16 or F32
        GGML_ASSERT(ggml_is_contiguous(mask));    // 断言：掩码必须连续 / assert: mask must be contiguous
        GGML_ASSERT(mask->ne[0] == a->ne[0]);     // 掩码第0维必须等于输入第0维 / mask dim0 must equal input dim0
        GGML_ASSERT(mask->ne[1] >= a->ne[1]);     // 掩码第1维必须大于等于输入第1维 / mask dim1 must be >= input dim1
        GGML_ASSERT(a->ne[2]%mask->ne[2] == 0);   // 输入第2维必须能被掩码第2维整除 / input dim2 must be divisible by mask dim2
        GGML_ASSERT(a->ne[3]%mask->ne[3] == 0);   // 输入第3维必须能被掩码第3维整除 / input dim3 must be divisible by mask dim3
    }                                              // 结束掩码检查 / end mask check

    if (max_bias > 0.0f) {                        // 如果最大偏置大于0 / if max bias is greater than 0
        GGML_ASSERT(mask);                        // 断言：必须提供掩码 / assert: mask must be provided
    }                                              // 结束偏置检查 / end bias check

    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量 / create view if inplace, otherwise duplicate tensor

    float params[] = { scale, max_bias };         // 参数数组：缩放因子和最大偏置 / parameter array: scale and max_bias
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_SOFT_MAX;            // 设置操作类型为SOFT_MAX / set operation type to SOFT_MAX
    result->src[0] = a;                           // 设置源张量0为输入a / set source tensor 0 to input a
    result->src[1] = mask;                        // 设置源张量1为掩码 / set source tensor 1 to mask

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_soft_max_impl 函数 / end ggml_soft_max_impl function

struct ggml_tensor * ggml_soft_max(               // 标准softmax操作 / standard softmax operation
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a) {                // 输入张量 / input tensor
    return ggml_soft_max_impl(ctx, a, NULL, 1.0f, 0.0f, false); // 调用内部实现，无掩码，缩放=1，无偏置，非原地 / call impl with no mask, scale=1, no bias, not inplace
}                                                 // 结束 ggml_soft_max 函数 / end ggml_soft_max function

struct ggml_tensor * ggml_soft_max_inplace(       // 原地softmax操作 / in-place softmax operation
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a) {                // 输入张量（将被原地修改）/ input tensor (will be modified in-place)
    return ggml_soft_max_impl(ctx, a, NULL, 1.0f, 0.0f, true); // 调用内部实现，原地操作 / call impl with inplace=true
}                                                 // 结束 ggml_soft_max_inplace 函数 / end ggml_soft_max_inplace function

struct ggml_tensor * ggml_soft_max_ext(           // 扩展softmax操作（带掩码和缩放）/ extended softmax (with mask and scale)
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * mask,               // 掩码张量 / mask tensor
        float                 scale,              // 缩放因子 / scale factor
        float                 max_bias) {         // 最大偏置 / max bias
    return ggml_soft_max_impl(ctx, a, mask, scale, max_bias, false); // 调用内部实现，非原地 / call impl, not inplace
}                                                 // 结束 ggml_soft_max_ext 函数 / end ggml_soft_max_ext function

struct ggml_tensor * ggml_soft_max_ext_inplace(   // 原地扩展softmax操作 / in-place extended softmax
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * mask,               // 掩码张量 / mask tensor
        float                 scale,              // 缩放因子 / scale factor
        float                 max_bias) {         // 最大偏置 / max bias
    return ggml_soft_max_impl(ctx, a, mask, scale, max_bias, true); // 调用内部实现，原地操作 / call impl with inplace=true
}                                                 // 结束 ggml_soft_max_ext_inplace 函数 / end ggml_soft_max_ext_inplace function

void ggml_soft_max_add_sinks(                     // 为softmax添加汇聚（sink）张量 / add sinks tensor to softmax
        struct ggml_tensor * a,                   // softmax结果张量 / softmax result tensor
        struct ggml_tensor * sinks) {             // 汇聚张量 / sinks tensor
    if (!sinks) {                                 // 如果汇聚张量为空 / if sinks is NULL
        a->src[2] = NULL;                         // 将源张量2设为空 / set source tensor 2 to NULL
        return;                                   // 直接返回 / return immediately
    }                                             // 结束空值检查 / end null check

    GGML_ASSERT(a->op == GGML_OP_SOFT_MAX);      // 断言：a必须是SOFT_MAX操作 / assert: a must be SOFT_MAX op
    GGML_ASSERT(a->src[2] == NULL);               // 断言：源张量2必须为空 / assert: source tensor 2 must be NULL
    GGML_ASSERT(a->src[0]->ne[2] == sinks->ne[0]); // 断言：源0的第2维等于汇聚的第0维 / assert: src0 dim2 equals sinks dim0
    GGML_ASSERT(sinks->type == GGML_TYPE_F32);    // 断言：汇聚张量必须是F32类型 / assert: sinks must be F32 type

    a->src[2] = sinks;                            // 设置源张量2为汇聚 / set source tensor 2 to sinks
}                                                 // 结束 ggml_soft_max_add_sinks 函数 / end ggml_soft_max_add_sinks function

// ggml_soft_max_ext_back                         // softmax扩展反向传播 / softmax extended backward

static struct ggml_tensor * ggml_soft_max_ext_back_impl( // softmax反向传播内部实现 / softmax backward internal implementation
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 梯度张量 / gradient tensor
        float                 scale,              // 缩放因子 / scale factor
        float                 max_bias,           // 最大偏置 / max bias
        bool                  inplace) {          // 是否原地操作 / whether in-place
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 创建结果张量 / create result tensor

    result->op     = GGML_OP_SOFT_MAX_BACK;       // 设置操作类型为SOFT_MAX_BACK / set op type to SOFT_MAX_BACK
    result->src[0] = a;                           // 设置源张量0 / set source tensor 0
    result->src[1] = b;                           // 设置源张量1 / set source tensor 1

    memcpy((float *) result->op_params + 0, &scale,    sizeof(float)); // 复制scale到操作参数第0位 / copy scale to op_params[0]
    memcpy((float *) result->op_params + 1, &max_bias, sizeof(float)); // 复制max_bias到操作参数第1位 / copy max_bias to op_params[1]

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_soft_max_ext_back_impl 函数 / end function

struct ggml_tensor * ggml_soft_max_ext_back(      // softmax扩展反向传播（非原地）/ softmax extended backward (not inplace)
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 梯度张量 / gradient tensor
        float                 scale,              // 缩放因子 / scale factor
        float                 max_bias) {         // 最大偏置 / max bias
    return ggml_soft_max_ext_back_impl(ctx, a, b, scale, max_bias, false); // 调用内部实现，非原地 / call impl, not inplace
}                                                 // 结束 ggml_soft_max_ext_back 函数 / end function

struct ggml_tensor * ggml_soft_max_ext_back_inplace( // softmax扩展反向传播（原地）/ softmax extended backward (inplace)
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 梯度张量 / gradient tensor
        float                 scale,              // 缩放因子 / scale factor
        float                 max_bias) {         // 最大偏置 / max bias
    return ggml_soft_max_ext_back_impl(ctx, a, b, scale, max_bias, true); // 调用内部实现，原地 / call impl with inplace=true
}                                                 // 结束 ggml_soft_max_ext_back_inplace 函数 / end function

// ggml_rope                                      // 旋转位置编码（Rotary Position Embedding）操作 / RoPE operation

static struct ggml_tensor * ggml_rope_impl(       // RoPE内部实现函数 / RoPE internal implementation function
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入数据张量 / input data tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        struct ggml_tensor  * c,                  // 频率因子张量（可选）/ freq factors tensor (optional)
        int                   n_dims,             // 应用RoPE的维度数 / number of dimensions to apply RoPE
        int                   sections[GGML_MROPE_SECTIONS], // 多模态RoPE分段 / multimodal RoPE sections
        int                   mode,               // RoPE模式 / RoPE mode
        int                   n_ctx_orig,         // 原始上下文长度 / original context length
        float                 freq_base,          // 频率基准 / frequency base
        float                 freq_scale,         // 频率缩放 / frequency scale
        float                 ext_factor,         // 外推因子 / extrapolation factor
        float                 attn_factor,        // 注意力因子 / attention factor
        float                 beta_fast,          // YaRN快速修正参数 / YaRN fast correction parameter
        float                 beta_slow,          // YaRN慢速修正参数 / YaRN slow correction parameter
        bool                  inplace) {          // 是否原地操作 / whether in-place
    GGML_ASSERT((mode & 1) == 0 && "mode & 1 == 1 is no longer supported"); // 断言：旧模式不再支持 / assert: old mode no longer supported

    GGML_ASSERT(ggml_is_vector(b));               // 断言：b必须是向量 / assert: b must be a vector
    GGML_ASSERT(b->type == GGML_TYPE_I32);        // 断言：b必须是int32类型 / assert: b must be int32 type

    bool mrope_used = mode & GGML_ROPE_TYPE_MROPE; // 检查是否使用多模态RoPE / check if multimodal RoPE is used
    if (mrope_used) {                             // 如果使用多模态RoPE / if multimodal RoPE is used
        GGML_ASSERT(a->ne[2] * 4 == b->ne[0]);   // mrope expecting 4 position ids per token // mrope要求每个token有4个位置ID
    } else {                                      // 否则标准RoPE / otherwise standard RoPE
        GGML_ASSERT(a->ne[2] == b->ne[0]);        // 断言：输入第2维等于位置数 / assert: input dim2 equals number of positions
    }                                             // 结束mrope检查 / end mrope check

    if (c) {                                      // 如果提供了频率因子张量 / if freq factors tensor is provided
        GGML_ASSERT(c->type == GGML_TYPE_F32);    // 断言：c必须是F32类型 / assert: c must be F32 type
        GGML_ASSERT(c->ne[0] >= n_dims / 2);      // 断言：c第0维必须大于等于n_dims/2 / assert: c dim0 >= n_dims/2
    }                                             // 结束频率因子检查 / end freq factors check

    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 创建结果张量 / create result tensor

    int32_t params[15] = { /*n_past*/ 0, n_dims, mode, /*n_ctx*/ 0, n_ctx_orig }; // 初始化参数数组 / initialize parameter array
    memcpy(params +  5, &freq_base,    sizeof(float)); // 复制freq_base到参数第5位 / copy freq_base to params[5]
    memcpy(params +  6, &freq_scale,   sizeof(float)); // 复制freq_scale到参数第6位 / copy freq_scale to params[6]
    memcpy(params +  7, &ext_factor,   sizeof(float)); // 复制ext_factor到参数第7位 / copy ext_factor to params[7]
    memcpy(params +  8, &attn_factor,  sizeof(float)); // 复制attn_factor到参数第8位 / copy attn_factor to params[8]
    memcpy(params +  9, &beta_fast,    sizeof(float)); // 复制beta_fast到参数第9位 / copy beta_fast to params[9]
    memcpy(params + 10, &beta_slow,    sizeof(float)); // 复制beta_slow到参数第10位 / copy beta_slow to params[10]
    if (mrope_used && sections) {                 // 如果使用mrope且提供了分段 / if mrope used and sections provided
        memcpy(params + 11, sections,  sizeof(int32_t) * GGML_MROPE_SECTIONS); // 复制分段数据到参数 / copy sections data to params
    } else {                                      // 否则 / otherwise
        memset(params + 11, 0,         sizeof(int32_t) * GGML_MROPE_SECTIONS); // 将分段参数清零 / zero out section params
    }                                             // 结束分段处理 / end sections handling
    ggml_set_op_params(result, params, sizeof(params)); // 设置操作参数 / set operation parameters

    result->op     = GGML_OP_ROPE;                // 设置操作类型为ROPE / set op type to ROPE
    result->src[0] = a;                           // 设置源张量0为输入数据 / set source 0 to input data
    result->src[1] = b;                           // 设置源张量1为位置索引 / set source 1 to position indices
    result->src[2] = c;                           // 设置源张量2为频率因子 / set source 2 to freq factors

    return result;                                // 返回结果张量 / return result tensor
}                                                 // 结束 ggml_rope_impl 函数 / end ggml_rope_impl function

struct ggml_tensor * ggml_rope(                   // 基本RoPE操作 / basic RoPE operation
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        int                   n_dims,             // RoPE维度数 / number of RoPE dimensions
        int                   mode) {             // RoPE模式 / RoPE mode
    return ggml_rope_impl(                        // 调用内部实现 / call internal implementation
        ctx, a, b, NULL, n_dims, NULL, mode, 0, 10000.0f, 1.0f, 0.0f, 1.0f, 0.0f, 0.0f, false // 使用默认参数 / using default parameters
    );                                            // freq_base=10000, freq_scale=1, 无外推 / default freq_base=10000, no extrapolation
}                                                 // 结束 ggml_rope 函数 / end ggml_rope function

struct ggml_tensor * ggml_rope_multi(             // 多模态RoPE操作 / multimodal RoPE operation
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        struct ggml_tensor  * c,                  // 频率因子张量 / freq factors tensor
        int                   n_dims,             // RoPE维度数 / RoPE dimensions
        int                   sections[GGML_MROPE_SECTIONS], // 多模态分段 / multimodal sections
        int                   mode,               // RoPE模式 / RoPE mode
        int                   n_ctx_orig,         // 原始上下文长度 / original context length
        float                 freq_base,          // 频率基准 / frequency base
        float                 freq_scale,         // 频率缩放 / frequency scale
        float                 ext_factor,         // 外推因子 / extrapolation factor
        float                 attn_factor,        // 注意力因子 / attention factor
        float                 beta_fast,          // YaRN快速参数 / YaRN fast parameter
        float                 beta_slow) {        // YaRN慢速参数 / YaRN slow parameter
    return ggml_rope_impl(                        // 调用内部实现 / call internal implementation
        ctx, a, b, c, n_dims, sections, mode, n_ctx_orig, freq_base, freq_scale,
        ext_factor, attn_factor, beta_fast, beta_slow, false // 非原地操作 / not inplace
    );                                            // 传递所有参数 / pass all parameters
}                                                 // 结束 ggml_rope_multi 函数 / end ggml_rope_multi function

struct ggml_tensor * ggml_rope_multi_inplace(     // 原地多模态RoPE操作 / in-place multimodal RoPE
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        struct ggml_tensor  * c,                  // 频率因子张量 / freq factors tensor
        int                   n_dims,             // RoPE维度数 / RoPE dimensions
        int                   sections[GGML_MROPE_SECTIONS], // 多模态分段 / multimodal sections
        int                   mode,               // RoPE模式 / RoPE mode
        int                   n_ctx_orig,         // 原始上下文长度 / original context length
        float                 freq_base,          // 频率基准 / frequency base
        float                 freq_scale,         // 频率缩放 / frequency scale
        float                 ext_factor,         // 外推因子 / extrapolation factor
        float                 attn_factor,        // 注意力因子 / attention factor
        float                 beta_fast,          // YaRN快速参数 / YaRN fast parameter
        float                 beta_slow) {        // YaRN慢速参数 / YaRN slow parameter
    return ggml_rope_impl(                        // 调用内部实现 / call internal implementation
        ctx, a, b, c, n_dims, sections, mode, n_ctx_orig, freq_base, freq_scale,
        ext_factor, attn_factor, beta_fast, beta_slow, true // 原地操作 / inplace
    );                                            // 传递所有参数，inplace=true / pass all params, inplace=true
}                                                 // 结束 ggml_rope_multi_inplace 函数 / end function

struct ggml_tensor * ggml_rope_inplace(           // 原地基本RoPE操作 / in-place basic RoPE
        struct ggml_context * ctx,                // 上下文指针 / context pointer
        struct ggml_tensor  * a,                  // 输入张量 / input tensor
        struct ggml_tensor  * b,                  // 位置索引张量 / position index tensor
        int                   n_dims,             // RoPE维度数 / RoPE dimensions
