// ggml_sin // 正弦函数标记注释

static struct ggml_tensor * ggml_sin_impl( // 正弦函数的内部实现
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 输入张量（弧度值）
        bool                  inplace) { // 是否原地操作的标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    result->op     = GGML_OP_SIN; // 设置操作类型为正弦
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

struct ggml_tensor * ggml_sin( // 正弦函数的公共接口，非原地版本
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量（弧度值）
    return ggml_sin_impl(ctx, a, false); // 调用内部实现，非原地操作
}

struct ggml_tensor * ggml_sin_inplace( // 正弦函数的原地版本
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量，也用于存储结果
    return ggml_sin_impl(ctx, a, true); // 调用内部实现，原地操作
}

// ggml_cos // 余弦函数标记注释

static struct ggml_tensor * ggml_cos_impl( // 余弦函数的内部实现
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 输入张量（弧度值）
        bool                  inplace) { // 是否原地操作的标志
    struct ggml_tensor * result = inplace ? ggml_view_tensor(ctx, a) : ggml_dup_tensor(ctx, a); // 原地则创建视图，否则复制张量

    result->op     = GGML_OP_COS; // 设置操作类型为余弦
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

struct ggml_tensor * ggml_cos( // 余弦函数的公共接口，非原地版本
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量（弧度值）
    return ggml_cos_impl(ctx, a, false); // 调用内部实现，非原地操作
}

struct ggml_tensor * ggml_cos_inplace( // 余弦函数的原地版本
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量，也用于存储结果
    return ggml_cos_impl(ctx, a, true); // 调用内部实现，原地操作
}

// ggml_sum // 求和操作标记注释（将所有元素求和为一个标量）

struct ggml_tensor * ggml_sum( // 求和操作函数，将张量所有元素求和
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量
    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, a->type, 1); // 创建一个只有一个元素的1维张量作为结果

    result->op     = GGML_OP_SUM; // 设置操作类型为求和
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量（标量）
}

// ggml_sum_rows // 按行求和操作标记注释

struct ggml_tensor * ggml_sum_rows( // 按行求和操作，对每行的元素求和
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量
    int64_t ne[GGML_MAX_DIMS] = { 1 }; // 初始化结果维度数组，第0维为1（每行求和为一个值）
    for (int i = 1; i < GGML_MAX_DIMS; ++i) { // 遍历第1到最大维度
        ne[i] = a->ne[i]; // 保持其他维度不变
    }

    struct ggml_tensor * result = ggml_new_tensor(ctx, a->type, GGML_MAX_DIMS, ne); // 创建结果张量

    result->op     = GGML_OP_SUM_ROWS; // 设置操作类型为按行求和
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_cumsum // 累加和操作标记注释（前缀和）

struct ggml_tensor * ggml_cumsum( // 累加和操作函数，计算前缀和
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量
    GGML_ASSERT(a->type == GGML_TYPE_F32); // 断言：输入类型必须是 32 位浮点

    struct ggml_tensor * result = ggml_dup_tensor(ctx, a); // 创建与输入相同形状的结果张量

    result->op     = GGML_OP_CUMSUM; // 设置操作类型为累加和
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_mean // 均值操作标记注释

struct ggml_tensor * ggml_mean( // 均值操作函数，计算每行的平均值
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量
    int64_t ne[4] = { 1, a->ne[1], a->ne[2], a->ne[3] }; // 结果维度：第0维为1，其余维度保持不变
    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne); // 创建结果张量，类型为 F32

    result->op     = GGML_OP_MEAN; // 设置操作类型为均值
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_argmax // 最大值索引操作标记注释

struct ggml_tensor * ggml_argmax( // 最大值索引操作函数，返回每行中最大值的索引
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量
    GGML_ASSERT(ggml_is_matrix(a)); // 断言：输入必须是矩阵（2维张量）
    GGML_ASSERT(a->ne[0] <= INT32_MAX); // 断言：第0维大小不超过 INT32 最大值

    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, GGML_TYPE_I32, a->ne[1]); // 创建1维整数结果张量，长度为行数

    result->op     = GGML_OP_ARGMAX; // 设置操作类型为最大值索引
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_count_equal // 计数相等操作标记注释

struct ggml_tensor * ggml_count_equal( // 计数相等操作函数，统计两个张量中相等元素的数量
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 第一个输入张量
        struct ggml_tensor  * b) { // 第二个输入张量
    GGML_ASSERT(ggml_are_same_shape(a, b)); // 断言：两个张量形状必须相同

    struct ggml_tensor * result = ggml_new_tensor_1d(ctx, GGML_TYPE_I64, 1); // 创建一个 64 位整数的标量结果张量

    result->op     = GGML_OP_COUNT_EQUAL; // 设置操作类型为计数相等
    result->src[0] = a; // 设置第一个源张量
    result->src[1] = b; // 设置第二个源张量

    return result; // 返回结果张量（标量）
}

// ggml_repeat // 重复张量操作标记注释

struct ggml_tensor * ggml_repeat( // 重复张量操作函数，将张量 a 重复以匹配 b 的形状
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 待重复的输入张量
        struct ggml_tensor  * b) { // 目标形状参考张量
    GGML_ASSERT(ggml_can_repeat(a, b)); // 断言：a 可以通过重复来匹配 b 的形状

    struct ggml_tensor * result = ggml_new_tensor(ctx, a->type, GGML_MAX_DIMS, b->ne); // 创建与 b 相同形状的结果张量

    result->op     = GGML_OP_REPEAT; // 设置操作类型为重复
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

struct ggml_tensor * ggml_repeat_4d( // 4维重复张量操作函数，指定目标维度进行重复
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor * a, // 待重复的输入张量
        int64_t ne0, int64_t ne1, int64_t ne2, int64_t ne3) { // 目标的四个维度大小
    const bool can_repeat = ggml_is_empty(a) || ( // 检查是否可以重复：空张量或各维度均可整除
        (ne0 % a->ne[0] == 0) && // 检查第0维：目标维度能被 a 的第0维整除
        (ne1 % a->ne[1] == 0) && // 检查第1维：目标维度能被 a 的第1维整除
        (ne2 % a->ne[2] == 0) && // 检查第2维：目标维度能被 a 的第2维整除
        (ne3 % a->ne[3] == 0) // 检查第3维：目标维度能被 a 的第3维整除
    );
    GGML_ASSERT(can_repeat); // 断言：必须可以重复

    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, a->type, ne0, ne1, ne2, ne3); // 创建指定维度的结果张量

    result->op     = GGML_OP_REPEAT; // 设置操作类型为重复
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_repeat_back // 反向重复操作标记注释（重复的梯度反向传播）

struct ggml_tensor * ggml_repeat_back( // 反向重复操作函数，用于反向传播中重复操作的梯度计算
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a, // 输入梯度张量
        struct ggml_tensor  * b) { // 目标形状参考张量
    GGML_ASSERT(ggml_can_repeat(b, a)); // 断言：b 可以通过重复来匹配 a 的形状

    struct ggml_tensor * result = ggml_new_tensor(ctx, a->type, GGML_MAX_DIMS, b->ne); // 创建与 b 相同形状的结果张量

    result->op     = GGML_OP_REPEAT_BACK; // 设置操作类型为反向重复
    result->src[0] = a; // 设置源张量

    return result; // 返回结果张量
}

// ggml_concat // 张量拼接操作标记注释

struct ggml_tensor * ggml_concat( // 张量拼接操作函数，沿指定维度将两个张量拼接
    struct ggml_context * ctx, // ggml 上下文指针
    struct ggml_tensor  * a, // 第一个输入张量
    struct ggml_tensor  * b, // 第二个输入张量
    int                   dim) { // 拼接的维度索引
    GGML_ASSERT(dim >= 0 && dim < GGML_MAX_DIMS); // 断言：维度索引在有效范围内
    GGML_ASSERT(a->type == b->type); // 断言：两个张量的数据类型必须相同

    int64_t ne[GGML_MAX_DIMS]; // 结果张量的维度数组
    for (int d = 0; d < GGML_MAX_DIMS; ++d) { // 遍历所有维度
        if (d == dim) { // 如果是拼接维度
            ne[d] = a->ne[d] + b->ne[d]; // 该维度大小为两个张量之和
            continue; // 跳过后续检查
        }
        GGML_ASSERT(a->ne[d] == b->ne[d]); // 断言：非拼接维度的大小必须相同
        ne[d] = a->ne[d]; // 非拼接维度保持不变
    }

    struct ggml_tensor * result = ggml_new_tensor(ctx, a->type, GGML_MAX_DIMS, ne); // 创建结果张量

    ggml_set_op_params_i32(result, 0, dim); // 将拼接维度保存为操作参数

    result->op     = GGML_OP_CONCAT; // 设置操作类型为拼接
    result->src[0] = a; // 设置第一个源张量
    result->src[1] = b; // 设置第二个源张量

    return result; // 返回结果张量
}

// ggml_abs // 绝对值操作标记注释

struct ggml_tensor * ggml_abs( // 绝对值操作的公共接口
        struct ggml_context * ctx, // ggml 上下文指针
        struct ggml_tensor  * a) { // 输入张量
    return ggml_unary(ctx, a, GGML_UNARY_OP_ABS); // 调用通用一元操作接口，指定绝对值操作
}

struct ggml_tensor * ggml_abs_inplace( // 绝对值操作的原地版本
